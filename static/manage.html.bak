<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Red Nun Management</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0F0F11; --sidebar-bg: #18181B; --card-bg: #1E1E21;
  --border: rgba(255,255,255,0.08); --border2: rgba(255,255,255,0.15);
  --text: #F5F5F7; --text2: rgba(245,245,247,0.6); --text3: rgba(245,245,247,0.35);
  --red: #FF453A; --green: #30D158; --blue: #0A84FF; --orange: #FF9F0A;
  --purple: #BF5AF2; --yellow: #FFD60A;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); }

/* Layout */
.layout { display: flex; height: 100vh; }
.sidebar { width: 240px; background: var(--sidebar-bg); border-right: 1px solid var(--border); display: flex; flex-direction: column; }
.main-content { flex: 1; overflow-y: auto; }

/* Sidebar */
.sidebar-header { padding: 20px; border-bottom: 1px solid var(--border); }
.sidebar-logo { font-size: 20px; font-weight: 700; color: var(--red); }
.sidebar-nav { flex: 1; padding: 12px 0; }
.nav-item { padding: 10px 20px; display: flex; align-items: center; gap: 12px; color: var(--text2); cursor: pointer; transition: all 0.2s; border-left: 3px solid transparent; }
.nav-item:hover { background: rgba(255,255,255,0.03); color: var(--text); }
.nav-item.active { background: rgba(255,69,58,0.1); color: var(--red); border-left-color: var(--red); }
.nav-icon { width: 20px; height: 20px; opacity: 0.8; }

/* Page Tabs */
.page-tabs { background: rgba(28,28,30,0.85); backdrop-filter: blur(30px); border-bottom: 1px solid var(--border); display: flex; gap: 4px; padding: 12px 24px; position: sticky; top: 0; z-index: 99; }
.page-tab { padding: 8px 16px; border-radius: 8px; background: transparent; border: 1px solid transparent; color: var(--text2); font-size: 13px; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s; text-decoration: none; display: inline-block; }
.page-tab:hover { background: var(--card-bg); border-color: var(--border); }
.page-tab.active { background: rgba(255,69,58,0.1); border-color: rgba(255,69,58,0.3); color: var(--red); }

/* Top Bar */
.top-bar { padding: 16px 24px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: var(--sidebar-bg); }
.page-title { font-size: 24px; font-weight: 700; }
.top-actions { display: flex; gap: 12px; }
.btn { padding: 10px 18px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; }
.btn-primary { background: var(--red); color: #fff; }
.btn-primary:hover { background: #ff5a50; }
.btn-secondary { background: var(--card-bg); color: var(--text); border: 1px solid var(--border); }
.btn-secondary:hover { background: rgba(255,255,255,0.05); }

/* Content Area */
.content-area { padding: 24px; max-width: 1600px; margin: 0 auto; }
.view { display: none; }
.view.active { display: block; }

/* Cards */
.card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 16px; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.card-title { font-size: 18px; font-weight: 600; }

/* Tables */
.data-table { width: 100%; border-collapse: collapse; }
.data-table th { text-align: left; padding: 12px; font-size: 12px; font-weight: 600; color: var(--text3); text-transform: uppercase; border-bottom: 1px solid var(--border); }
.data-table td { padding: 12px; border-bottom: 1px solid var(--border); font-size: 14px; }
.data-table tbody tr:hover { background: rgba(255,255,255,0.02); }

/* Forms */
.form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-label { font-size: 13px; font-weight: 600; color: var(--text2); }
.form-input, .form-select { padding: 10px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-size: 14px; }
.form-input:focus, .form-select:focus { outline: none; border-color: var(--blue); }

/* Modal */
.modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center; }
.modal.active { display: flex; }
.modal-content { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 24px; max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.modal-title { font-size: 20px; font-weight: 700; }
.modal-close { background: none; border: none; color: var(--text2); font-size: 24px; cursor: pointer; }

/* Stats Cards */
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
.stat-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
.stat-label { font-size: 13px; color: var(--text3); margin-bottom: 8px; }
.stat-value { font-size: 28px; font-weight: 700; }
.stat-change { font-size: 12px; margin-top: 4px; }
.stat-up { color: var(--green); }
.stat-down { color: var(--red); }

/* Search Bar */
.search-bar { padding: 10px 16px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-size: 14px; width: 300px; }
.search-bar:focus { outline: none; border-color: var(--blue); }

/* Tags */
.tag { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 600; text-transform: uppercase; }
.tag-food { background: rgba(48,209,88,0.15); color: var(--green); }
.tag-beer { background: rgba(255,159,10,0.15); color: var(--orange); }
.tag-liquor { background: rgba(255,69,58,0.15); color: var(--red); }
.tag-wine { background: rgba(191,90,242,0.15); color: var(--purple); }
.tag-supplies { background: rgba(255,255,255,0.1); color: var(--text3); }

/* Mobile Responsive Layout */
@media(max-width:768px){
  .layout{display:block;height:auto}
  .sidebar{display:none}
  .main-content{overflow-y:visible}

  .page-tabs{padding:10px 16px;overflow-x:auto;scrollbar-width:none}
  .page-tabs::-webkit-scrollbar{display:none}
  .page-tab{font-size:12px;padding:6px 12px}

  .top-bar{padding:12px 16px;flex-wrap:wrap}
  .page-title{font-size:20px}
  .top-actions{width:100%;justify-content:flex-start;margin-top:8px}
  .btn{padding:8px 12px;font-size:12px}

  .content-area{padding:16px}
  .card{padding:16px}
  .form-grid{grid-template-columns:1fr}
  .stats-grid{grid-template-columns:repeat(2,1fr);gap:12px}

  /* Mobile Navigation */
  .mobile-nav{display:flex;gap:4px;padding:8px 16px;background:var(--sidebar-bg);border-bottom:1px solid var(--border);overflow-x:auto;scrollbar-width:none;position:sticky;top:44px;z-index:98}
  .mobile-nav::-webkit-scrollbar{display:none}
  .mobile-nav-item{padding:8px 14px;border-radius:8px;background:transparent;border:1px solid transparent;color:var(--text2);font-size:12px;font-weight:600;white-space:nowrap;cursor:pointer;transition:all .2s}
  .mobile-nav-item.active{background:rgba(255,69,58,0.1);border-color:rgba(255,69,58,0.3);color:var(--red)}
  .mobile-nav-item:hover{background:var(--card-bg)}

  /* Adjust modals for mobile */
  .modal-content{width:95%;max-width:none;padding:20px}
  .form-input,.form-select{font-size:16px}
}

@media(max-width:768px){
  .dash-desktop-only{display:none!important}
  .dash-mobile-only{display:block!important}
  #dash-thermo-row{flex-direction:column}
}
@media(min-width:769px){
  .dash-mobile-only{display:none!important}
}
@media(min-width:1025px){
  .mobile-nav{display:none}
}

/* Storage Layout */
.sl-loc-item{padding:12px 16px;border-bottom:1px solid var(--border);cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:all 0.15s}
.sl-loc-item:hover{background:rgba(255,255,255,0.03)}
.sl-loc-item.active{background:rgba(10,132,255,0.1);border-left:3px solid var(--blue)}
.sl-loc-item.unassigned{background:rgba(255,69,58,0.06)}
.sl-loc-item.unassigned.active{background:rgba(255,69,58,0.12);border-left-color:var(--red)}
.sl-count{font-size:11px;color:var(--text3);font-weight:600;background:var(--card-bg);padding:2px 8px;border-radius:8px}
.sl-count.warn{background:rgba(255,69,58,0.15);color:var(--red)}
.sl-badge{display:inline-block;background:var(--red);color:#fff;font-size:10px;font-weight:800;padding:1px 6px;border-radius:6px;margin-left:4px}
.sl-product{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--card-bg);border:1px solid var(--border);border-radius:8px;margin-bottom:4px;cursor:grab;user-select:none}
.sl-product:active{cursor:grabbing}
.sl-product.dragging{opacity:0.4;border-color:var(--blue)}
.sl-product.drag-over{border-color:var(--green);background:rgba(48,209,88,0.05)}
.sl-order{font-size:10px;color:var(--text3);font-weight:700;width:20px;text-align:center;flex-shrink:0}
.sl-handle{color:var(--text3);font-size:14px;flex-shrink:0}
.sl-name{font-size:13px;font-weight:600;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sl-remove{background:none;border:none;color:var(--text3);cursor:pointer;font-size:16px;padding:2px 6px;border-radius:4px;flex-shrink:0}
.sl-remove:hover{color:var(--red);background:rgba(255,69,58,0.1)}
.sl-unassigned{display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--card-bg);border:1px solid var(--border);border-radius:8px;margin-bottom:4px}
.sl-assign-btn{padding:5px 10px;border-radius:6px;background:rgba(10,132,255,0.1);color:var(--blue);font-size:11px;font-weight:700;border:1px solid rgba(10,132,255,0.25);cursor:pointer;flex-shrink:0}
.sl-assign-btn:hover{background:rgba(10,132,255,0.2)}
/* Count Sheet */
.cs-section{margin-bottom:20px}
.cs-section-hdr{padding:10px 14px;background:rgba(10,132,255,0.08);border:1px solid rgba(10,132,255,0.15);border-radius:8px 8px 0 0;display:flex;justify-content:space-between;align-items:center;font-size:14px;font-weight:700;color:var(--blue)}
.cs-section-count{font-size:11px;font-weight:600;color:var(--text3)}
.cs-row{display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border);border-left:1px solid var(--border);border-right:1px solid var(--border)}
.cs-row:last-child{border-radius:0 0 8px 8px}
.cs-name{flex:1;min-width:0;font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cs-prev{font-size:10px;color:var(--text3)}
.cs-input{width:70px;padding:8px;background:var(--bg);border:1.5px solid var(--border);border-radius:8px;color:var(--text);font-size:15px;font-weight:700;text-align:center;outline:none;-moz-appearance:textfield}
.cs-input::-webkit-inner-spin-button,.cs-input::-webkit-outer-spin-button{-webkit-appearance:none}
.cs-input:focus{border-color:var(--blue)}
.cs-input.has-val{border-color:var(--green);background:rgba(48,209,88,0.06)}
.cs-unit{font-size:10px;color:var(--text3);width:70px;text-align:center}
.cs-stat{background:var(--card-bg);border:1px solid var(--border);border-radius:8px;padding:10px 16px;flex-shrink:0}
.cs-stat-label{font-size:10px;color:var(--text3);font-weight:600;text-transform:uppercase}
.cs-stat-val{font-size:18px;font-weight:700;margin-top:2px}

/* Inventory sub-tabs */
.inv-tab{background:rgba(255,255,255,0.06)!important;color:var(--text)!important;border:1px solid rgba(255,255,255,0.15)!important;padding:10px 20px!important;font-size:14px!important;font-weight:600!important;display:inline-block!important;cursor:pointer!important;border-radius:8px!important}
.inv-tab.active{background:rgba(255,69,58,0.15)!important;border-color:rgba(255,69,58,0.4)!important;color:#FF453A!important}
.inv-panel{display:none}
.inv-panel.active{display:block}

/* Product setup tracking */








.sort-btn{padding:4px 10px;border-radius:6px;background:var(--card-bg);border:1px solid var(--border);color:var(--text2);font-size:11px;font-weight:600;cursor:pointer}
.sort-btn.active{background:rgba(255,159,10,0.1);border-color:rgba(255,159,10,0.3);color:var(--orange)}

.cs-tree{padding:8px 0}
.cs-branch{margin:0 0 2px 0}
.cs-branch.collapsed .cs-branch-body{display:none}
.cs-branch.collapsed .cs-chevron{transform:rotate(-90deg)}
.cs-branch-header{display:flex;align-items:center;gap:8px;padding:10px 16px;cursor:pointer;transition:background 0.15s;border-bottom:1px solid rgba(255,255,255,0.04)}
.cs-branch-header:hover{background:rgba(255,255,255,0.03)}
.cs-chevron{font-size:10px;color:var(--text3);transition:transform 0.2s;width:12px}
.cs-branch-icon{font-size:14px}
.cs-branch-name{font-size:13px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:0.3px}
.cs-general .cs-branch-name{color:var(--text3)}
.cs-branch-count{font-size:11px;color:var(--text3);background:rgba(255,255,255,0.06);padding:1px 6px;border-radius:8px}
.cs-branch-del{background:none;border:none;color:var(--text3);font-size:12px;cursor:pointer;margin-left:auto;opacity:0.3;transition:opacity 0.15s}
.cs-branch-del:hover{opacity:1;color:var(--red)}
.cs-branch-body{padding-left:20px}
.cs-empty-drop{padding:12px 16px;color:var(--text3);font-size:12px;font-style:italic;text-align:center;border:1px dashed rgba(255,255,255,0.1);border-radius:6px;margin:4px 8px}
.cs-row{display:flex;align-items:center;padding:7px 12px;border-bottom:1px solid rgba(255,255,255,0.03);gap:10px;cursor:grab;transition:background 0.15s;border-radius:4px;margin:1px 0;user-select:none}
.cs-row:hover{background:rgba(255,255,255,0.04)}
.cs-row-num{color:var(--text3);font-size:10px;width:20px;text-align:right;font-weight:600}
.cs-row-grip{color:var(--text3);font-size:12px;opacity:0.3}
.cs-row:hover .cs-row-grip{opacity:0.8}
.cs-row-name{flex:1;font-size:13px;font-weight:500}
.cs-row-unit{font-size:11px;color:var(--text3);width:50px;text-align:right}
.cs-sortable{min-height:8px;transition:all 0.2s;border-radius:4px}
.cs-sortable.drag-over{background:rgba(10,132,255,0.06);outline:1px dashed rgba(10,132,255,0.3);outline-offset:-1px}
.cs-row.dragging{opacity:0.3}

.nav-section { }
.nav-section .nav-item { position: relative; }
#recipe-subnav .nav-item { border-left: 2px solid var(--border); margin-left: 12px; }
#recipe-subnav .nav-item:hover { border-left-color: var(--green, #22c55e); }
#recipe-subnav .nav-item.active { border-left-color: var(--green, #22c55e); color: var(--green, #22c55e); }
</style>
<link rel="stylesheet" href="/static/sidebar.css">
</head>
<body>

<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <div style="display:flex;align-items:center;gap:12px">
        <div style="width:34px;height:34px;background:linear-gradient(135deg,var(--red),#FF6259);border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;color:#fff;box-shadow:0 4px 12px rgba(255,69,58,0.3)">RN</div>
        <div>
          <div style="font-size:17px;font-weight:700;letter-spacing:-0.3px">Red Nun Management</div>
          <div style="font-size:11px;color:var(--text3);font-weight:500;letter-spacing:0.5px;text-transform:uppercase">Dashboard · Settings</div>
        </div>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-item active" onclick="showView('dashboard')">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
        Dashboard
      </div>
      <div class="nav-item" onclick="showView('products')">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        Products
      </div>
      <div class="nav-item" onclick="showView('vendors')">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        Vendors
      </div>
      <div class="nav-item" onclick="showView('inv')">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        Inventory
      </div>
      <div class="nav-item" onclick="showView('orderguide')">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        Order Guide
      </div>
      <!-- Recipes Section -->
      <div style="margin-top:16px;padding-top:12px;border-top:1px solid var(--border)">
        <div style="padding:8px 16px;font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px">
          <svg style="width:16px;height:16px;vertical-align:-3px;margin-right:6px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          Recipes
        </div>
        <div class="nav-item" onclick="showView('recipes')" style="padding-left:38px;font-size:13px">
          Menu Items
        </div>
        <div class="nav-item" onclick="showView('prepared-items')" style="padding-left:38px;font-size:13px">
          Prepared Items
        </div>
        <div class="nav-item" onclick="showView('recipe-analysis')" style="padding-left:38px;font-size:13px">
          Menu Analysis
        </div>
        <div class="nav-item" onclick="showView('recipe-viewer')" style="padding-left:38px;font-size:13px">
          Recipe Viewer
        </div>
      </div>

      <!-- Settings Section -->
      <div style="margin-top:16px;padding-top:12px;border-top:1px solid var(--border)">
        <div style="padding:8px 16px;font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px">
          <svg style="width:16px;height:16px;vertical-align:-3px;margin-right:6px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Setup
        </div>
        <div class="nav-item" onclick="showView('prodsetup')" style="padding-left:38px;font-size:13px">
          Product Setup
        </div>
        <div class="nav-item" onclick="showView('settings')" style="padding-left:38px;font-size:13px">
          General Settings
        </div>
        <div class="nav-item" onclick="showView('data-export')" style="padding-left:38px;font-size:13px">
          Data Export
        </div>
        <div class="nav-item" onclick="showView('user-accounts')" style="padding-left:38px;font-size:13px">
          User Accounts
        </div>
      </div>
      <div class="nav-item" onclick="window.location.href='/invoices'">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Invoices
      </div>
      <div class="nav-item" onclick="window.location.href='/'">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Analytics
      </div>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <!-- Page Navigation Tabs -->
    <nav class="page-tabs">
      <a href="/" class="page-tab">Analytics</a>
      <a href="/manage" class="page-tab active">Management</a>
      <a href="/invoices" class="page-tab">Invoices</a>
      <a href="/catalog" class="page-tab">Catalog</a>
      <select id="global-location" onchange="setGlobalLocation(this.value)" style="margin-left:auto;padding:6px 12px;background:var(--card-bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:13px;font-weight:600;cursor:pointer">
        <option value="dennis">📍 Dennis Port</option>
        <option value="chatham">📍 Chatham</option>
      </select>
    </nav>

    <!-- Mobile Navigation (hidden on desktop) -->
    <div class="mobile-nav">
      <div class="mobile-nav-item active" onclick="showView('dashboard')">Dashboard</div>
      <div class="mobile-nav-item" onclick="showView('products')">Products</div>
      <div class="mobile-nav-item" onclick="showView('vendors')">Vendors</div>
      <div class="mobile-nav-item" onclick="showView('inv')">Inventory</div>
      <div class="mobile-nav-item" onclick="showView('recipes')">Recipes</div>
    </div>

    <!-- Top Bar -->
    <div class="top-bar">
      <div class="page-title" id="pageTitle">Dashboard</div>
      <div class="top-actions">
        <input type="text" class="search-bar" placeholder="Search..." id="globalSearch">
        <button class="btn btn-primary" id="primaryAction" style="display:none;">Add New</button>
      </div>
    </div>

    <!-- Content Area -->
    <div class="content-area">
      <!-- Dashboard View -->
      <div class="view active" id="view-dashboard">
        <!-- Mobile: Today + Thermostats -->
        <div class="dash-mobile-only" id="dash-mobile-cards">
          <div style="display:flex;gap:12px;margin-bottom:12px">
            <div style="flex:1;background:linear-gradient(135deg,#1a2744,#1e3352);border-radius:10px;padding:16px;border:1px solid rgba(59,130,246,0.3)">
              <div style="font-size:11px;color:var(--text3);text-transform:uppercase;margin-bottom:6px">Today's Sales</div>
              <div style="font-size:28px;font-weight:700" id="dash-mob-today-sales">--</div>
              <div style="font-size:12px;color:var(--text3);margin-top:4px" id="dash-mob-today-orders"></div>
            </div>
            <div style="flex:1;background:linear-gradient(135deg,#2a1a3e,#351e4d);border-radius:10px;padding:16px;border:1px solid rgba(168,85,247,0.3)">
              <div style="font-size:11px;color:var(--text3);text-transform:uppercase;margin-bottom:6px">This Week</div>
              <div style="font-size:28px;font-weight:700" id="dash-mob-week-sales">--</div>
              <div style="font-size:12px;color:var(--text3);margin-top:4px" id="dash-mob-week-vs"></div>
            </div>
          </div>
          <div id="dash-mobile-thermo" style="display:flex;flex-direction:column;gap:12px"></div>
        </div>

        <!-- Row 1: Sales + PTD/YTD -->
        <div class="dash-desktop-only" style="display:flex;gap:16px;align-items:flex-start">
          <!-- Sales Table -->
          <div class="card" style="flex:1;padding:16px">
            <div style="margin-bottom:12px">
              <span style="font-size:14px;font-weight:700;color:var(--green)">&#9733; SALES</span>
            </div>
            <div style="font-size:13px;color:var(--text3);margin-bottom:14px" id="dash-week-label">Week of --</div>
            <table style="width:100%;font-size:13px;border-collapse:collapse">
              <thead>
                <tr>
                  <th style="text-align:left;padding:8px 10px;width:50px"></th>
                  <th style="text-align:right;padding:8px 10px;font-weight:700;border-left:2px solid var(--border)">This Week</th>
                  <th style="text-align:right;padding:8px 10px;font-weight:700;border-left:2px solid var(--border)" colspan="2">Last Week</th>
                  <th style="text-align:right;padding:8px 10px;font-weight:700;border-left:2px solid var(--border)" colspan="2">Last Year</th>
                </tr>
                <tr style="border-bottom:2px solid var(--border)">
                  <th style="padding:4px 10px"></th>
                  <th style="text-align:right;padding:4px 10px;font-size:11px;color:var(--text3);font-weight:600;border-left:2px solid var(--border)">Actual</th>
                  <th style="text-align:right;padding:4px 10px;font-size:11px;color:var(--text3);font-weight:600;border-left:2px solid var(--border)">Actual</th>
                  <th style="text-align:right;padding:4px 10px;font-size:11px;color:var(--text3);font-weight:600">vs. Myself</th>
                  <th style="text-align:right;padding:4px 10px;font-size:11px;color:var(--text3);font-weight:600;border-left:2px solid var(--border)">Actual</th>
                  <th style="text-align:right;padding:4px 10px;font-size:11px;color:var(--text3);font-weight:600">vs. Myself</th>
                </tr>
              </thead>
              <tbody id="dash-daily-body"></tbody>
            </table>
          </div>

          <!-- PTD + YTD -->
          <div style="display:flex;flex-direction:column;gap:16px;width:340px;flex-shrink:0">
            <div style="background:linear-gradient(135deg,#1a2744,#1e3352);border-radius:10px;padding:16px 20px;border:1px solid rgba(10,132,255,0.25)">
              <div style="font-size:13px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:1px;text-align:center;margin-bottom:12px">Period to Date</div>
              <table style="width:100%;font-size:13px;border-collapse:collapse">
                <thead><tr style="border-bottom:1px solid rgba(255,255,255,0.1)">
                  <th style="text-align:left;padding:6px 0;font-size:12px;color:var(--text3);font-weight:600"></th>
                  <th style="text-align:right;padding:6px 0;font-size:12px;color:var(--text3);font-weight:600">Actual</th>
                  <th style="text-align:right;padding:6px 0;font-size:12px;color:var(--text3);font-weight:600">Change</th>
                </tr></thead>
                <tbody>
                  <tr style="border-bottom:1px solid rgba(255,255,255,0.06)">
                    <td style="padding:10px 0;font-weight:700;font-size:13px">This Year</td>
                    <td style="text-align:right;padding:10px 0;font-weight:700;font-size:18px" id="dash-ptd-ty">--</td>
                    <td style="text-align:right;padding:10px 0"></td>
                  </tr>
                  <tr>
                    <td style="padding:10px 0;font-weight:700;font-size:13px">Last Year</td>
                    <td style="text-align:right;padding:10px 0;font-weight:700;font-size:18px" id="dash-ptd-ly">--</td>
                    <td style="text-align:right;padding:10px 0;font-size:14px;font-weight:600" id="dash-ptd-change"></td>
                  </tr>
                </tbody>
              </table>
            </div>
            <div style="background:linear-gradient(135deg,#2a1a3e,#351e4d);border-radius:10px;padding:16px 20px;border:1px solid rgba(191,90,242,0.25)">
              <div style="font-size:13px;font-weight:700;color:var(--purple);text-transform:uppercase;letter-spacing:1px;text-align:center;margin-bottom:12px">Year to Date</div>
              <table style="width:100%;font-size:13px;border-collapse:collapse">
                <thead><tr style="border-bottom:1px solid rgba(255,255,255,0.1)">
                  <th style="text-align:left;padding:6px 0;font-size:12px;color:var(--text3);font-weight:600"></th>
                  <th style="text-align:right;padding:6px 0;font-size:12px;color:var(--text3);font-weight:600">Actual</th>
                  <th style="text-align:right;padding:6px 0;font-size:12px;color:var(--text3);font-weight:600">Change</th>
                </tr></thead>
                <tbody>
                  <tr style="border-bottom:1px solid rgba(255,255,255,0.06)">
                    <td style="padding:10px 0;font-weight:700;font-size:13px">This Year</td>
                    <td style="text-align:right;padding:10px 0;font-weight:700;font-size:18px" id="dash-ytd-ty">--</td>
                    <td style="text-align:right;padding:10px 0"></td>
                  </tr>
                  <tr>
                    <td style="padding:10px 0;font-weight:700;font-size:13px">Last Year</td>
                    <td style="text-align:right;padding:10px 0;font-weight:700;font-size:18px" id="dash-ytd-ly">--</td>
                    <td style="text-align:right;padding:10px 0;font-size:14px;font-weight:600" id="dash-ytd-change"></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Row 2: Monthly Trend + Labor -->
        <div class="dash-desktop-only" style="display:flex;gap:16px;margin-top:16px;align-items:stretch">
          <div class="card" style="flex:1;padding:16px">
            <div style="font-size:14px;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px">&#9650; Monthly Sales Trend</div>
            <div id="dash-monthly-chart" style="display:flex;align-items:flex-end;gap:3px;height:140px;padding:0 2px"></div>
            <div id="dash-monthly-labels" style="display:flex;gap:3px;padding:4px 2px 0"></div>
          </div>
          <div style="background:linear-gradient(135deg,#2a1a1a,#3d1e1e);border-radius:10px;padding:16px 20px;border:1px solid rgba(255,69,58,0.25);width:340px;flex-shrink:0;display:flex;flex-direction:column">
            <div style="font-size:14px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:1px;margin-bottom:16px">&#9881; Labor</div>
            <div style="display:flex;flex-direction:column;gap:14px;flex:1;justify-content:center">
              <div>
                <div style="font-size:11px;color:var(--text3);text-transform:uppercase;margin-bottom:2px">This Week</div>
                <div style="font-size:24px;font-weight:700" id="dash-labor-tw">--</div>
              </div>
              <div>
                <div style="font-size:11px;color:var(--text3);text-transform:uppercase;margin-bottom:2px">Last Week</div>
                <div style="font-size:24px;font-weight:700" id="dash-labor-lw">--</div>
              </div>
              <div style="border-top:1px solid rgba(255,69,58,0.2);padding-top:14px">
                <div style="font-size:11px;color:var(--text3);text-transform:uppercase;margin-bottom:2px">Labor % of Sales</div>
                <div style="font-size:28px;font-weight:700" id="dash-labor-pct">--</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Row 3: Thermostats (desktop) -->
        <div id="dash-thermo-row" class="dash-desktop-only" style="display:flex;gap:16px;margin-top:16px;flex-wrap:wrap">
        </div>

        <!-- Row 4: Pending Invoices Badge -->
        <div style="margin-top:16px">
          <div class="card" style="padding:12px 16px;cursor:pointer" onclick="showView('invoices')" title="Go to Invoices">
            <div style="display:flex;align-items:center;justify-content:space-between">
              <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text2)">&#128196; Invoices</div>
              <div id="dash-pending-inv-badge" style="font-size:13px;color:var(--text3)">Loading...</div>
            </div>
          </div>
        </div>

        <!-- Row 5: Price Movers -->
        <div style="margin-top:16px">
          <div class="card" style="padding:16px" id="dash-price-movers-card">
            <div style="font-size:14px;font-weight:700;color:var(--text1);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px">&#128200; Price Movers <span style="font-size:11px;color:var(--text3);font-weight:500;text-transform:none;letter-spacing:0">(Last 30 Days)</span></div>
            <div id="dash-price-movers-body" style="color:var(--text3);font-size:13px">Loading...</div>
          </div>
        </div>
      </div>

      <!-- Products View -->
      <div class="view" id="view-products">
        <div class="card">
          <div class="card-header">
            <div class="card-title">Products</div>
            <div style="display:flex;gap:12px;">
              <select class="form-select" id="products-category-filter" onchange="loadProducts()" style="max-width:150px;">
                <option value="">All Categories</option>
                <option value="FOOD">Food</option>
                <option value="BEER">Beer</option>
                <option value="LIQUOR">Liquor</option>
                <option value="WINE">Wine</option>
                <option value="NA_BEVERAGES">NA Beverages</option>
                <option value="SUPPLIES">Supplies</option>
              </select>
              <button class="btn btn-secondary" onclick="clearProductCache(); loadProducts(true);" title="Refresh from server">🔄 Refresh</button>
              <button class="btn btn-primary" onclick="openProductModal()">Add Product</button>
            </div>
          </div>
          <table class="data-table">
            <thead>
              <tr>
                <th style="cursor:pointer" onclick="sortProducts('name')">Name <span id="sort-ind-name"></span></th>
                <th style="cursor:pointer" onclick="sortProducts('category')">Category <span id="sort-ind-category"></span></th>
                <th style="cursor:pointer" onclick="sortProducts('vendor')">Vendor <span id="sort-ind-vendor"></span></th>
                <th style="cursor:pointer" onclick="sortProducts('price')">Price <span id="sort-ind-price"></span></th>
                <th style="cursor:pointer" onclick="sortProducts('storage')">Storage <span id="sort-ind-storage"></span></th>
                <th>Purchase Unit</th>
                <th>Inventory Unit</th>
                <th style="cursor:pointer" onclick="sortProducts('setup')">⭐ <span id="sort-ind-setup"></span></th>
              </tr>
            </thead>
            <tbody id="products-table"></tbody>
          </table>
        </div>
      </div>

      <!-- Vendors View -->
      <div class="view" id="view-vendors">
        <div class="card">
          <div class="card-header">
            <div class="card-title">Vendors</div>
            <button class="btn btn-primary" onclick="openVendorModal()">Add Vendor</button>
          </div>
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Contact</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="vendors-table"></tbody>
          </table>
        </div>
      </div>

      </div>

      <!-- Inventory View (Consolidated) -->
      <div class="view" id="view-inv">
        <!-- Sub-tabs -->
        <div style="display:flex;gap:6px;margin-bottom:16px;border-bottom:1px solid var(--border);padding-bottom:12px">
          <button class="btn inv-tab active" data-tab="countsheet" onclick="invTab(this)">Count Sheet</button>
          <button class="btn inv-tab" data-tab="storagesetup" onclick="invTab(this)">Storage</button>
          <button class="btn inv-tab" data-tab="counthistory" onclick="invTab(this)">Count History</button>
        </div>

        <!-- COUNT SHEET TAB -->
        <div class="inv-panel active" id="panel-countsheet">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
            <div>
              <div style="font-size:18px;font-weight:700">Count Sheet</div>
              <div style="font-size:12px;color:var(--text3)" id="cs-subtitle">Define what gets counted and where</div>
            </div>
            <div style="display:flex;gap:8px">
              <button class="btn btn-primary" onclick="csStartCount()" style="padding:8px 16px;font-size:13px;background:var(--red);border-color:var(--red)">Start Inventory Count</button>
            </div>
          </div>
          <div id="cs-active-banner" style="display:none;padding:12px 16px;background:rgba(255,159,10,0.1);border:1px solid rgba(255,159,10,0.3);border-radius:8px;margin-bottom:16px">
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div><span style="font-size:14px">📋</span> <strong>Count in progress</strong> <span id="cs-active-date" style="color:var(--text3);font-size:12px"></span></div>
              <a id="cs-active-link" href="/count" style="color:var(--blue);font-size:13px;font-weight:600">Continue Count →</a>
            </div>
          </div>
          <div style="display:flex;gap:0;border:1px solid var(--border);border-radius:12px;overflow:hidden;min-height:500px">
            <div id="cs-area-nav" style="width:220px;border-right:1px solid var(--border);background:rgba(255,255,255,0.01);flex-shrink:0"></div>
            <div id="cs-area-content" style="flex:1;overflow-y:auto;max-height:70vh">
              <div style="padding:40px;text-align:center;color:var(--text3)">Select a storage area</div>
            </div>
          </div>
        </div>
        <!-- STORAGE TAB -->
        <div class="inv-panel" id="panel-storagesetup">
          <div style="display:flex;gap:16px;height:calc(100vh - 240px);min-height:400px">
            <div style="width:250px;background:var(--card-bg);border:1px solid var(--border);border-radius:12px;overflow-y:auto;flex-shrink:0">
              <div style="padding:10px 14px;border-bottom:1px solid var(--border)">
                
                <div style="display:flex;justify-content:space-between;align-items:center"><div style="font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px">Storage Areas</div><button style="background:none;border:none;color:var(--blue);font-size:16px;cursor:pointer;padding:0 4px" onclick="slAddArea()" title="Add storage area">+</button></div>
              </div>
              <div id="sl-loc-list"></div>
            </div>
            <div style="flex:1;overflow-y:auto">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                <div>
                  <div style="font-size:16px;font-weight:700" id="sl-main-title">Select a storage area</div>
                  <div style="font-size:12px;color:var(--text2)" id="sl-main-sub">Click a location on the left</div>
                </div>
                <input class="search-bar" id="sl-search" placeholder="Search..." oninput="slRenderMain()" style="width:200px">
              </div>
              <div id="sl-main-content"></div>
            </div>
          </div>
        </div>

        <!-- COUNT HISTORY TAB -->
        <div class="inv-panel" id="panel-counthistory">
          <div style="font-size:18px;font-weight:700;margin-bottom:16px">Count History</div>
          <div id="cs-history">
            <div style="padding:20px;text-align:center;color:var(--text3)">Loading...</div>
          </div>
        </div>
      </div>

      <!-- Recipes View -->
      <div class="view" id="view-recipes">
        <div class="card">
          <div class="card-header">
            <div class="card-title">Recipes</div>
            <button class="btn btn-primary" onclick="openRecipeModal()">Add Recipe</button>
          </div>
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Location</th>
                <th>Category</th>
                <th>Menu Price</th>
                <th>Food Cost</th>
                <th>Cost %</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="recipes-table"></tbody>
          </table>
        </div>
      </div>

      <!-- Settings View -->
      <div class="view" id="view-settings">
        <div class="card">
          <div class="card-header">
            <div class="card-title">Settings</div>
          </div>
          <div style="padding:20px;color:var(--text2)">
            <div style="margin-bottom:16px">
              <div style="font-weight:600;color:var(--text);margin-bottom:8px">Product Categories</div>
              <div style="font-size:13px">FOOD · BEER · LIQUOR · WINE · NA_BEVERAGES · OTHER</div>
            </div>
            <div>
              <div style="font-weight:600;color:var(--text);margin-bottom:8px">System Info</div>
              <div style="font-size:13px">Database: toast_data.db (WAL mode)</div>
              <div style="font-size:13px">OCR: Claude Sonnet 4 (~$0.05/invoice)</div>
            </div>
          </div>
        </div>
      </div>


      <!-- Recipe Edit Full Page View -->
      <div class="view" id="view-recipe-edit">
        <div style="margin-bottom:16px;display:flex;align-items:center;gap:12px">
          <button class="btn btn-secondary" onclick="showView('recipes')" style="padding:6px 14px;font-size:13px">&larr; Back to Recipes</button>
          <span style="color:var(--text3);font-size:13px">Recipes &rsaquo;</span>
          <span id="recipe-edit-breadcrumb" style="font-size:13px;font-weight:600"></span>
        </div>

        <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
          <h2 id="recipe-page-title" style="font-size:24px;font-weight:700;margin:0">Edit Recipe</h2>
          <button onclick="editRecipeNamePage()" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:18px;padding:4px" title="Edit name">&#9998;</button>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
          <!-- LEFT COLUMN -->
          <div>
            <!-- Item Details -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Item Details</div></div>
              <div style="padding:20px">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                  <div class="form-group">
                    <label class="form-label">Category</label>
                    <select id="rp-category" class="form-select" style="background:var(--bg);border-color:var(--border)">
                      <option value="">Select...</option>
                      <option value="appetizer">Appetizer</option>
                      <option value="entree">Entree</option>
                      <option value="side">Side</option>
                      <option value="dessert">Dessert</option>
                      <option value="beverage">Beverage</option>
                      <option value="sauce">Sauce/Prep</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Location</label>
                    <div id="rp-location-display" style="padding:8px 0;font-weight:500"></div>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Menu Price</label>
                    <input type="number" step="0.01" id="rp-menu-price" class="form-input" style="background:var(--bg);border-color:var(--border)" placeholder="0.00">
                  </div>
                  <div class="form-group">
                    <label class="form-label">Prep Time (min)</label>
                    <input type="number" id="rp-prep-time" class="form-input" style="background:var(--bg);border-color:var(--border)" placeholder="0">
                  </div>
                </div>
                <div class="form-group" style="margin-top:12px">
                  <label class="form-label">Description</label>
                  <textarea id="rp-description" class="form-input" rows="2" style="background:var(--bg);border-color:var(--border)"></textarea>
                </div>
              </div>
            </div>

            <!-- Yields -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Yields</div></div>
              <div style="padding:20px">
                <div style="display:flex;gap:12px;align-items:center">
                  <input type="number" step="0.01" id="rp-yield-qty" class="form-input" style="width:80px;padding:8px;background:var(--bg);border-color:var(--border);text-align:center" value="1">
                  <select id="rp-yield-unit" class="form-select" style="width:140px;padding:8px;background:var(--bg);border-color:var(--border)">
                    <option value="Each">Each</option>
                    <option value="Serving">Serving</option>
                    <option value="Portion">Portion</option>
                    <option value="Batch">Batch</option>
                    <option value="oz">oz</option>
                    <option value="lb">lb</option>
                    <option value="gal">gal</option>
                    <option value="liter">liter</option>
                    <option value="quart">quart</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Recipe Settings -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Recipe Settings</div></div>
              <div style="padding:20px">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-bottom:12px">
                  <input type="checkbox" id="rp-restricted" style="width:16px;height:16px">
                  <span style="font-size:13px">Recipe should be restricted to certain Restaurants</span>
                </label>
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                  <input type="checkbox" id="rp-inventoried" style="width:16px;height:16px">
                  <span style="font-size:13px">Recipe should be inventoried</span>
                </label>
              </div>
            </div>

            <!-- Shelf Life -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Shelf Life</div></div>
              <div style="padding:20px">
                <div style="display:flex;gap:12px;align-items:center">
                  <input type="number" id="rp-shelf-qty" class="form-input" style="width:100px;padding:8px;background:var(--bg);border-color:var(--border)" placeholder="Enter qty">
                  <select id="rp-shelf-unit" class="form-select" style="width:120px;padding:8px;background:var(--bg);border-color:var(--border)">
                    <option value="Days">Days</option>
                    <option value="Hours">Hours</option>
                    <option value="Weeks">Weeks</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Toast Menu Links -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Toast Menu Links</div></div>
              <div style="padding:20px">
                <div id="rp-menu-links"></div>
              </div>
            </div>
          </div>

          <!-- RIGHT COLUMN -->
          <div>
            <!-- Preparation -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Preparation</div></div>
              <div style="padding:20px">
                <div style="margin-bottom:16px">
                  <div style="font-size:13px;font-weight:600;margin-bottom:8px">Equipment</div>
                  <div style="font-size:12px;color:var(--text3);margin-bottom:8px">Include any equipment used to make this menu item.</div>
                  <input type="text" id="rp-equipment" class="form-input" style="padding:8px;background:var(--bg);border-color:var(--border)" placeholder="e.g., Flat top grill, Deep fryer">
                </div>
                <div>
                  <div style="font-size:13px;font-weight:600;margin-bottom:8px">Method</div>
                  <div style="font-size:12px;color:var(--text3);margin-bottom:8px">Detail your full process step by step.</div>
                  <div id="rp-method-steps"></div>
                  <button class="btn btn-secondary" onclick="addMethodStepPage()" style="padding:6px 14px;font-size:12px;margin-top:8px">+ Add step</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Ingredients - Full Width -->
        <div style="margin-top:24px">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
            <h3 style="font-size:18px;font-weight:700;margin:0">Ingredients</h3>
            <div style="display:flex;gap:24px;align-items:center">
              <div><span style="font-size:12px;color:var(--text3)">Ingredient Total</span> <span id="rp-ingredient-total" style="font-weight:700;margin-left:8px;font-size:16px">$0.00</span></div>
              <div><span style="font-size:12px;color:var(--text3)">Menu Price</span> <span id="rp-menu-price-display" style="font-weight:700;margin-left:8px;font-size:16px">--</span></div>
              <div><span style="font-size:12px;color:var(--text3)">Plate Cost</span> <span id="rp-plate-cost" style="font-weight:700;margin-left:8px;font-size:16px">--</span></div>
            </div>
          </div>
          <div id="rp-ingredients-list" style="background:var(--card-bg);border:1px solid var(--border);border-radius:12px;overflow:hidden"></div>
        </div>

        <!-- Notes - Full Width -->
        <div class="card" style="margin-top:20px;margin-bottom:20px">
          <div class="card-header"><div class="card-title">Notes</div></div>
          <div style="padding:20px">
            <textarea id="rp-notes" class="form-input" rows="3" style="background:var(--bg);border-color:var(--border)" placeholder="Internal notes about this recipe..."></textarea>
          </div>
        </div>


        <!-- Bottom action bar -->
        <div style="position:sticky;bottom:0;background:var(--bg);padding:16px 0;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;margin-top:8px">
          <div style="display:flex;gap:12px">
            <button class="btn btn-primary" onclick="saveFullRecipe()" style="padding:10px 28px;font-size:14px">Save</button>
            <button class="btn btn-secondary" onclick="showView('recipes')" style="padding:10px 28px;font-size:14px">Cancel</button>
          </div>
          <div style="display:flex;gap:12px">
            <button class="btn btn-secondary" onclick="deleteRecipe()" style="padding:10px 20px;font-size:13px;color:#ef4444;border-color:#ef4444">Delete Recipe</button>
            <button class="btn btn-secondary" onclick="deactivateRecipe()" style="padding:10px 20px;font-size:13px;color:#f59e0b;border-color:#f59e0b">Deactivate</button>
          </div>
        </div>
      </div>


      <!-- Prepared Items View -->
      <div class="view" id="view-prepared-items">
        <div class="card">
          <div class="card-header">
            <div class="card-title">Prepared Items</div>
            <div style="font-size:12px;color:var(--text3);margin-bottom:0">Sauces, dressings, marinades, and prep items used as ingredients in recipes</div>
          </div>
          <div style="padding:0 20px 12px">
            <button class="btn btn-primary" onclick="openPrepItemModal()" style="margin-top:12px">+ Add Prepared Item</button>
          </div>
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Yield</th>
                <th>Cost</th>
                <th>Used In</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="prepared-items-table"></tbody>
          </table>
        </div>
      </div>

      <!-- Prepared Item Edit Full Page View -->
      <div class="view" id="view-prepared-edit">
        <div style="margin-bottom:16px;display:flex;align-items:center;gap:12px">
          <button class="btn btn-secondary" onclick="showView('prepared-items')" style="padding:6px 14px;font-size:13px">&larr; Back to Prepared Items</button>
          <span style="color:var(--text3);font-size:13px">Prepared Items &rsaquo;</span>
          <span id="prep-edit-breadcrumb" style="font-size:13px;font-weight:600"></span>
        </div>

        <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
          <h2 id="prep-page-title" style="font-size:24px;font-weight:700;margin:0">Edit Prepared Item</h2>
          <button onclick="editPrepNamePage()" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:18px;padding:4px">&#9998;</button>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
          <div>
            <!-- Item Details -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Item Details</div></div>
              <div style="padding:20px">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                  <div class="form-group">
                    <label class="form-label">Category</label>
                    <select id="pp-category" class="form-select" style="background:var(--bg);border-color:var(--border)">
                      <option value="">Select...</option>
                      <option value="sauce">Sauce</option>
                      <option value="dressing">Dressing</option>
                      <option value="marinade">Marinade</option>
                      <option value="batter">Batter/Breading</option>
                      <option value="base">Base/Stock</option>
                      <option value="garnish">Garnish/Topping</option>
                      <option value="mix">Mix/Blend</option>
                      <option value="other">Other Prep</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Location</label>
                    <div id="pp-location-display" style="padding:8px 0;font-weight:500"></div>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Prep Time (min)</label>
                    <input type="number" id="pp-prep-time" class="form-input" style="background:var(--bg);border-color:var(--border)" placeholder="0">
                  </div>
                </div>
                <div class="form-group" style="margin-top:12px">
                  <label class="form-label">Description</label>
                  <textarea id="pp-description" class="form-input" rows="2" style="background:var(--bg);border-color:var(--border)"></textarea>
                </div>
              </div>
            </div>

            <!-- Yields -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Yields</div></div>
              <div style="padding:20px">
                <div style="display:flex;gap:12px;align-items:center">
                  <input type="number" step="0.01" id="pp-yield-qty" class="form-input" style="width:80px;padding:8px;background:var(--bg);border-color:var(--border);text-align:center" value="1">
                  <select id="pp-yield-unit" class="form-select" style="width:140px;padding:8px;background:var(--bg);border-color:var(--border)">
                    <option value="Each">Each</option><option value="Batch">Batch</option><option value="oz">oz</option><option value="lb">lb</option><option value="cup">cup</option><option value="quart">quart</option><option value="gal">gal</option><option value="liter">liter</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Shelf Life -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Shelf Life</div></div>
              <div style="padding:20px">
                <div style="display:flex;gap:12px;align-items:center">
                  <input type="number" id="pp-shelf-qty" class="form-input" style="width:100px;padding:8px;background:var(--bg);border-color:var(--border)" placeholder="Enter qty">
                  <select id="pp-shelf-unit" class="form-select" style="width:120px;padding:8px;background:var(--bg);border-color:var(--border)">
                    <option value="Days">Days</option><option value="Hours">Hours</option><option value="Weeks">Weeks</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <div>
            <!-- Preparation -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Preparation</div></div>
              <div style="padding:20px">
                <div style="margin-bottom:16px">
                  <div style="font-size:13px;font-weight:600;margin-bottom:8px">Equipment</div>
                  <input type="text" id="pp-equipment" class="form-input" style="padding:8px;background:var(--bg);border-color:var(--border)" placeholder="e.g., Blender, Saucepan, Whisk">
                </div>
                <div>
                  <div style="font-size:13px;font-weight:600;margin-bottom:8px">Method</div>
                  <div id="pp-method-steps"></div>
                  <button class="btn btn-secondary" onclick="addPrepMethodStep()" style="padding:6px 14px;font-size:12px;margin-top:8px">+ Add step</button>
                </div>
              </div>
            </div>

            <!-- Ingredients -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Ingredients</div></div>
              <div style="padding:20px">
                <div id="pp-ingredients-list"></div>
                <div style="display:flex;gap:24px;margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
                  <div><span style="font-size:12px;color:var(--text3)">Total Cost</span> <span id="pp-ingredient-total" style="font-weight:700;margin-left:8px">$0.00</span></div>
                  <div><span style="font-size:12px;color:var(--text3)">Cost per Unit</span> <span id="pp-cost-per-unit" style="font-weight:700;margin-left:8px">--</span></div>
                </div>
              </div>
            </div>

            <!-- Notes -->
            <div class="card" style="margin-bottom:20px">
              <div class="card-header"><div class="card-title">Notes</div></div>
              <div style="padding:20px">
                <textarea id="pp-notes" class="form-input" rows="3" style="background:var(--bg);border-color:var(--border)" placeholder="Storage instructions, tips..."></textarea>
              </div>
            </div>
          </div>
        </div>

        <div style="position:sticky;bottom:0;background:var(--bg);padding:16px 0;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;margin-top:8px">
          <div style="display:flex;gap:12px">
            <button class="btn btn-primary" onclick="saveFullPrepItem()" style="padding:10px 28px;font-size:14px">Save</button>
            <button class="btn btn-secondary" onclick="showView('prepared-items')" style="padding:10px 28px;font-size:14px">Cancel</button>
          </div>
          <button class="btn btn-secondary" onclick="deletePrepItem()" style="padding:10px 20px;font-size:13px;color:#ef4444;border-color:#ef4444">Delete</button>
        </div>
      </div>

      <!-- Menu Analysis View -->
      <div class="view" id="view-recipe-analysis">
        <div class="card" style="text-align:center;padding:60px 24px">
          <div style="font-size:40px;margin-bottom:16px">📊</div>
          <div style="font-size:20px;font-weight:700;margin-bottom:8px">Menu Analysis</div>
          <div style="color:var(--text3);font-size:14px">Coming Soon</div>
        </div>
      </div>

      <!-- Recipe Viewer View -->
      <div class="view" id="view-recipe-viewer">
        <div class="card" style="text-align:center;padding:60px 24px">
          <div style="font-size:40px;margin-bottom:16px">📖</div>
          <div style="font-size:20px;font-weight:700;margin-bottom:8px">Recipe Viewer</div>
          <div style="color:var(--text3);font-size:14px">Coming Soon</div>
        </div>
      </div>

      <!-- Order Guide View -->
      <div class="view" id="view-orderguide">
        <div class="card">
          <div class="card-header">
            <div class="card-title">Order Guide</div>
            <button class="btn btn-primary" onclick="loadOrderGuide()">🔄 Refresh</button>
          </div>
          <div id="og-summary" style="padding:16px;background:rgba(48,209,88,0.05);border-bottom:1px solid var(--border)"></div>
          <div id="og-vendors"></div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Modals -->
<div class="modal" id="modal-product">
  <div class="modal-content">
    <div class="modal-header">
      <div class="modal-title">Add Product</div>
      <button class="modal-close" onclick="closeModal('modal-product')">&times;</button>
    </div>
    <form id="form-product" onsubmit="saveProduct(event)">
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label">Product Name</label>
          <input class="form-input" name="name" required>
        </div>
        <div class="form-group">
          <label class="form-label">Category</label>
          <select class="form-select" name="category" required>
            <option value="FOOD">Food</option>
            <option value="BEER">Beer</option>
            <option value="LIQUOR">Liquor</option>
            <option value="WINE">Wine</option>
            <option value="NA_BEVERAGES">NA Beverages</option>
            <option value="SUPPLIES">Supplies</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Purchase Unit</label>
          <select class="form-select" name="unit" required>
            <option value="">Select...</option>
            <option value="each">Each (ea)</option>
            <option value="case">Case</option>
            <option value="lb">Pound (lb)</option>
            <option value="oz">Ounce (oz)</option>
            <option value="gal">Gallon (gal)</option>
            <option value="liter">Liter (L)</option>
            <option value="keg (1/2 BBL)">Keg (1/2 BBL - 15.5 gal)</option>
            <option value="keg (1/6 BBL)">Keg (1/6 BBL - 5.16 gal)</option>
            <option value="keg (1/4 BBL)">Keg (1/4 BBL - 7.75 gal)</option>
            <option value="bag">Bag</option>
            <option value="box">Box</option>
            <option value="pallet">Pallet</option>
          </select>
          <small style="color:var(--text3);font-size:11px;">How you buy it</small>
        </div>
        <div class="form-group">
          <label class="form-label">Pack Size</label>
          <input class="form-input" type="number" step="0.01" name="pack_size" placeholder="24">
          <small style="color:var(--text3);font-size:11px;">Items per pack</small>
        </div>
        <div class="form-group">
          <label class="form-label">Inventory Unit</label>
          <select class="form-select" name="inventory_unit">
            <option value="">Select...</option>
            <option value="each">Each</option>
            <option value="bottle">Bottle</option>
            <option value="can">Can</option>
            <option value="keg">Keg</option>
            <option value="lb">Pound (lb)</option>
            <option value="oz">Ounce (oz)</option>
            <option value="gal">Gallon (gal)</option>
            <option value="liter">Liter (L)</option>
            <option value="serving">Serving</option>
            <option value="portion">Portion</option>
          </select>
          <small style="color:var(--text3);font-size:11px;">How you count it</small>
        </div>
        <div class="form-group">
          <label class="form-label">Unit Conversion</label>
          <input class="form-input" type="number" step="0.01" name="unit_conversion" placeholder="1">
          <small style="color:var(--text3);font-size:11px;">1 purchase = X inventory</small>
        </div>
        <div class="form-group">
          <label class="form-label">Current Price</label>
          <input class="form-input" type="number" step="0.01" name="current_price">
        </div>
        <div class="form-group">
          <label class="form-label">Par Level</label>
          <input class="form-input" type="number" step="0.01" name="par_level" placeholder="Minimum stock">
        </div>
        <div class="form-group">
          <label class="form-label">Reorder Point</label>
          <input class="form-input" type="number" step="0.01" name="reorder_point" placeholder="When to reorder">
        </div>
        <div class="form-group" style="grid-column: 1 / -1;">
          <label class="form-label">Storage Locations</label>
          <div id="storage-location-checkboxes" style="max-height:150px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;padding:12px;background:var(--bg);">
            <div style="color:var(--text3);font-size:13px;">Loading locations...</div>
          </div>
          <small style="color:var(--text3);font-size:11px;">Select all locations where this product is stored</small>
        </div>
      </div>
      <div class="form-group" style="margin-top:12px;">
        <label class="form-label">Notes</label>
        <textarea class="form-input" name="notes" rows="3" placeholder="Additional notes..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top:16px;width:100%;">Save Product</button>
    </form>
  </div>
</div>

<div class="modal" id="modal-vendor">
  <div class="modal-content">
    <div class="modal-header">
      <div class="modal-title">Add Vendor</div>
      <button class="modal-close" onclick="closeModal('modal-vendor')">&times;</button>
    </div>
    <form id="form-vendor" onsubmit="saveVendor(event)">
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label">Vendor Name</label>
          <input class="form-input" name="name" required>
        </div>
        <div class="form-group">
          <label class="form-label">Category</label>
          <select class="form-select" name="category">
            <option value="FOOD">Food</option>
            <option value="BEVERAGE">Beverage</option>
            <option value="SUPPLIES">Supplies</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Contact Name</label>
          <input class="form-input" name="contact_name">
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input class="form-input" type="email" name="email">
        </div>
        <div class="form-group">
          <label class="form-label">Phone</label>
          <input class="form-input" name="phone">
        </div>
        <div class="form-group">
          <label class="form-label">Payment Terms</label>
          <input class="form-input" name="payment_terms" placeholder="NET30">
        </div>
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top:16px;width:100%;">Save Vendor</button>
    </form>
  </div>
</div>

<!-- Inventory Count Modal -->
<div class="modal" id="modal-inventory">
  <div class="modal-content">
    <div class="modal-header">
      <div class="modal-title">Enter Inventory Count</div>
      <button class="modal-close" onclick="closeModal('modal-inventory')">&times;</button>
    </div>
    <form id="form-inventory" onsubmit="saveInventoryCount(event)">
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label">Location *</label>
          <select class="form-select" name="location" id="inv-modal-location" required>
            <option value="">Select location...</option>
            <option value="dennis">Dennis Port</option>
            <option value="chatham">Chatham</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Category Filter</label>
          <select class="form-select" id="inv-category-filter" onchange="filterInventoryProducts()">
            <option value="">All Categories</option>
            <option value="FOOD">Food</option>
            <option value="BEER">Beer</option>
            <option value="LIQUOR">Liquor</option>
            <option value="WINE">Wine</option>
            <option value="NA_BEVERAGES">NA Beverages</option>
            <option value="SUPPLIES">Supplies</option>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin-top:12px;">
        <label class="form-label">Product *</label>
        <input type="text" class="form-input" id="inv-product-search" placeholder="Search products..." onkeyup="searchInventoryProducts()">
        <select class="form-select" name="product_id" id="inv-product-select" size="8" required style="margin-top:8px;height:200px;">
          <option value="">Loading products...</option>
        </select>
      </div>
      <div class="form-grid" style="margin-top:12px;">
        <div class="form-group">
          <label class="form-label">Quantity *</label>
          <input class="form-input" type="number" step="0.01" name="quantity" id="inv-quantity" required>
        </div>
        <div class="form-group">
          <label class="form-label">Unit</label>
          <input class="form-input" name="unit" id="inv-unit" readonly style="background:var(--bg2);">
        </div>
      </div>
      <div class="form-group" style="margin-top:12px;">
        <label class="form-label">Notes</label>
        <textarea class="form-input" name="notes" rows="2" placeholder="Optional notes about this count..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top:16px;width:100%;">Save Count</button>
    </form>
  </div>
</div>

<!-- Add Storage Location Modal -->
<div class="modal" id="modal-add-location">
  <div class="modal-content" style="max-width:400px;">
    <div class="modal-header">
      <div class="modal-title">Add Storage Location</div>
      <button class="modal-close" onclick="closeModal('modal-add-location')">&times;</button>
    </div>
    <form id="form-add-location" onsubmit="saveStorageLocation(event)">
      <div class="form-group">
        <label class="form-label">Location Name *</label>
        <input class="form-input" name="name" required placeholder="e.g., Walk-in Cooler" autofocus>
        <small style="color:var(--text3);font-size:11px;margin-top:4px;display:block;">Give this storage location a descriptive name</small>
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top:16px;width:100%;">Add Location</button>
    </form>
  </div>
</div>

<div class="modal" id="modal-recipe">
  <div class="modal-content">
    <div class="modal-header">
      <div class="modal-title">Add Recipe</div>
      <button class="modal-close" onclick="closeModal('modal-recipe')">&times;</button>
    </div>
    <form id="form-recipe" onsubmit="saveRecipe(event)">
      <div class="form-grid">
        <div class="form-group" style="grid-column: 1 / -1">
          <label class="form-label">Recipe Name</label>
          <input class="form-input" name="name" required>
        </div>
        <div class="form-group">
          <label class="form-label">Category</label>
          <select class="form-select" name="category">
            <option value="">Select...</option>
            <option value="appetizer">Appetizer</option>
            <option value="entree">Entree</option>
            <option value="side">Side</option>
            <option value="dessert">Dessert</option>
            <option value="beverage">Beverage</option>
            <option value="sauce">Sauce/Prep</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Menu Price</label>
          <input class="form-input" type="number" step="0.01" name="menu_price" placeholder="0.00">
        </div>
        <div class="form-group">
          <label class="form-label">Serving Size</label>
          <input class="form-input" type="number" step="0.01" name="serving_size" value="1">
        </div>
        <div class="form-group">
          <label class="form-label">Serving Unit</label>
          <input class="form-input" name="serving_unit" value="portion" placeholder="portion, plate, bowl">
        </div>
        <div class="form-group">
          <label class="form-label">Restaurant</label>
          <select class="form-select" name="location">
            <option value="">Both Locations</option>
            <option value="dennis">Dennis Port Only</option>
            <option value="chatham">Chatham Only</option>
          </select>
          <small style="color:var(--text3);font-size:11px;margin-top:4px;display:block;">Choose "Both" for shared recipes. You can link to Toast menu items after creating the recipe.</small>
        </div>
        <div class="form-group">
          <label class="form-label">Prep Time (minutes)</label>
          <input class="form-input" type="number" name="prep_time_minutes">
        </div>
        <div class="form-group" style="grid-column: 1 / -1">
          <label class="form-label">Description</label>
          <textarea class="form-input" name="description" rows="2"></textarea>
        </div>
        <div class="form-group" style="grid-column: 1 / -1">
          <label class="form-label">Notes</label>
          <textarea class="form-input" name="notes" rows="2"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('modal-recipe')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Recipe</button>
      </div>
    </form>
  </div>
</div>

<div class="modal" id="modal-recipe-detail">
  <div class="modal-content" style="max-width:800px">
    <div class="modal-header">
      <div style="display:flex;align-items:center;gap:8px">
        <div class="modal-title" id="recipe-detail-title">Recipe Details</div>
        <button onclick="editRecipeName()" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:16px;padding:4px" title="Edit recipe name">✏️</button>
      </div>
      <button class="modal-close" onclick="closeModal('modal-recipe-detail')">&times;</button>
    </div>
    <div class="modal-body">
      <div id="recipe-detail-info" style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)"></div>

      <div style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)">
        <h3 style="font-size:16px;font-weight:700;margin:0 0 12px 0">Toast Menu Links</h3>
        <div id="recipe-menu-links"></div>
      </div>

            <!-- Yields -->
      <div style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)">
        <h3 style="font-size:16px;font-weight:700;margin:0 0 12px 0">Yields</h3>
        <div style="display:flex;gap:12px;align-items:center">
          <input type="number" step="0.01" id="recipe-yield-qty" class="form-input" style="width:80px;padding:8px;background:var(--bg);border-color:var(--border);text-align:center" value="1">
          <select id="recipe-yield-unit" class="form-select" style="width:140px;padding:8px;background:var(--bg);border-color:var(--border)">
            <option value="Each">Each</option>
            <option value="Serving">Serving</option>
            <option value="Portion">Portion</option>
            <option value="Batch">Batch</option>
            <option value="oz">oz</option>
            <option value="lb">lb</option>
            <option value="gal">gal</option>
            <option value="liter">liter</option>
            <option value="quart">quart</option>
          </select>
          <button class="btn btn-secondary" onclick="saveRecipeField('yield')" style="padding:6px 14px;font-size:12px">Save</button>
        </div>
      </div>

      <!-- Recipe Settings -->
      <div style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)">
        <h3 style="font-size:16px;font-weight:700;margin:0 0 12px 0">Recipe Settings</h3>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-bottom:10px">
          <input type="checkbox" id="recipe-restricted" onchange="saveRecipeField('settings')" style="width:16px;height:16px">
          <span style="font-size:13px">Recipe should be restricted to certain Restaurants</span>
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
          <input type="checkbox" id="recipe-inventoried" onchange="saveRecipeField('settings')" style="width:16px;height:16px">
          <span style="font-size:13px">Recipe should be inventoried</span>
        </label>
      </div>

      <!-- Shelf Life -->
      <div style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)">
        <h3 style="font-size:16px;font-weight:700;margin:0 0 12px 0">Shelf Life</h3>
        <div style="display:flex;gap:12px;align-items:center">
          <input type="number" id="recipe-shelf-qty" class="form-input" style="width:100px;padding:8px;background:var(--bg);border-color:var(--border)" placeholder="Enter qty">
          <select id="recipe-shelf-unit" class="form-select" style="width:120px;padding:8px;background:var(--bg);border-color:var(--border)">
            <option value="Days">Days</option>
            <option value="Hours">Hours</option>
            <option value="Weeks">Weeks</option>
          </select>
          <button class="btn btn-secondary" onclick="saveRecipeField('shelf')" style="padding:6px 14px;font-size:12px">Save</button>
        </div>
      </div>

      <!-- Preparation -->
      <div style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)">
        <h3 style="font-size:16px;font-weight:700;margin:0 0 12px 0">Preparation</h3>
        <div style="margin-bottom:16px">
          <div style="font-size:13px;font-weight:600;margin-bottom:8px">Equipment</div>
          <div style="font-size:12px;color:var(--text3);margin-bottom:8px">Include any equipment used to make this menu item.</div>
          <input type="text" id="recipe-equipment" class="form-input" style="padding:8px;background:var(--bg);border-color:var(--border)" placeholder="e.g., Flat top grill, Deep fryer, Slicer">
        </div>
        <div>
          <div style="font-size:13px;font-weight:600;margin-bottom:8px">Method</div>
          <div style="font-size:12px;color:var(--text3);margin-bottom:8px">Detail your full process step by step.</div>
          <div id="recipe-method-steps"></div>
          <button class="btn btn-secondary" onclick="addMethodStep()" style="padding:6px 14px;font-size:12px;margin-top:8px">+ Add step</button>
        </div>
        <div style="margin-top:12px;text-align:right">
          <button class="btn btn-primary" onclick="saveRecipeField('prep')" style="padding:6px 14px;font-size:12px">Save Preparation</button>
        </div>
      </div>

      <!-- Ingredients -->
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <h3 style="font-size:16px;font-weight:700;margin:0">Ingredients</h3>
      </div>
      <div id="recipe-ingredients-list"></div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
        <div style="display:flex;gap:24px">
          <div><span style="font-size:12px;color:var(--text3)">Ingredient Total</span> <span id="ingredient-total" style="font-weight:700;margin-left:8px">$0.00</span></div>
          <div><span style="font-size:12px;color:var(--text3)">Menu Price</span> <span id="recipe-menu-price-display" style="font-weight:700;margin-left:8px">--</span></div>
          <div><span style="font-size:12px;color:var(--text3)">Plate Cost</span> <span id="plate-cost-pct" style="font-weight:700;margin-left:8px">--</span></div>
        </div>
      </div>
    </div>
  </div>
</div>


      <!-- Product Setup View -->
      <div class="view" id="view-prodsetup">
        <div class="content-area" style="max-width:1400px">
        <div style="margin-bottom:16px;display:flex;gap:12px;align-items:center;flex-wrap:wrap">
          <input type="text" id="ps-search" class="form-input" placeholder="Search products or vendors..." style="flex:1;min-width:200px;max-width:400px">
          <select id="ps-vendor-filter" class="form-select" style="min-width:160px"><option value="">All Vendors</option></select>
          <select id="ps-cat-filter" class="form-select" style="min-width:140px">
            <option value="">All Categories</option>
            <option value="FOOD">Food</option>
            <option value="BEER">Beer</option>
            <option value="LIQUOR">Liquor</option>
            <option value="WINE">Wine</option>
            <option value="NA_BEVERAGES">NA Beverages</option>
            <option value="OTHER">Other/Supplies</option>
          </select>
          <select id="ps-status-filter" class="form-select" style="min-width:140px">
            <option value="unreviewed">Unreviewed</option>
            <option value="all">All Products</option>
            <option value="reviewed">Reviewed</option>
            <option value="skip">Skip Inventory</option>
          </select>
          <span id="ps-count" style="color:var(--text3);font-size:13px;white-space:nowrap"></span>
        </div>
        <div id="ps-list"></div>
        <div id="ps-pagination" style="display:flex;justify-content:center;gap:8px;margin-top:16px"></div>
      </div>

<script>
// Global location handler
window.currentLocation = localStorage.getItem('globalLocation') || 'dennis';
function setGlobalLocation(v) {
  window.currentLocation = v;
  localStorage.setItem('globalLocation', v);
  // Preserve current view and sub-tab across reload
  if (typeof currentView !== 'undefined') {
    localStorage.setItem('lastView', currentView);
  }
  var activeInvTab = document.querySelector('.inv-tab.active');
  if (activeInvTab) {
    localStorage.setItem('lastInvTab', activeInvTab.dataset.tab);
  }
  location.reload();
}
document.addEventListener('DOMContentLoaded', function() {
  var s = document.getElementById('global-location');
  if (s) s.value = window.currentLocation;
  // Restore last view after location switch
  var lastView = localStorage.getItem('lastView');
  if (lastView) {
    localStorage.removeItem('lastView');
    setTimeout(function() { showView(lastView); }, 50);
  }
});

// State
let currentView = 'dashboard';
const fmt = n => '$' + (n||0).toFixed(2);

// View Management
function showView(view) {
  // Auto-expand recipe subnav when viewing recipe pages
  if (view === 'recipes' || view === 'recipe-edit' || view === 'recipe-analysis' || view === 'recipe-viewer' || view === 'prepared-items' || view === 'prepared-edit') {
    const sub = document.getElementById('recipe-subnav');
    const chev = document.getElementById('recipe-nav-chevron');
    if (sub) { sub.style.display = 'block'; }
    if (chev) { chev.style.transform = 'rotate(90deg)'; }
  }
  console.log('showView called with:', view);
  currentView = view;

  // Save current view to localStorage
  localStorage.setItem('currentView', view);

  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.querySelectorAll('.mobile-nav-item').forEach(n => n.classList.remove('active'));

  const viewElement = document.getElementById('view-' + view);
  if (viewElement) {
    viewElement.classList.add('active');
  }

  // Update active state for the clicked nav item
  document.querySelectorAll('.nav-item').forEach(n => {
    if (n.getAttribute('onclick') && n.getAttribute('onclick') === "showView('" + view + "')") {
      n.classList.add('active');
    }
  });
  document.querySelectorAll('.mobile-nav-item').forEach(n => {
    if (n.getAttribute('onclick') && n.getAttribute('onclick') === "showView('" + view + "')") {
      n.classList.add('active');
    }
  });

  const titles = {
    dashboard: 'Dashboard',
    products: 'Products',
    vendors: 'Vendors',
    inventory: 'Inventory',
    storage: 'Storage Locations',
    storagelayout: 'Storage Layout',
    countsheet: 'Count Sheet',
    inv: 'Inventory',
    recipes: 'Recipes',
    'recipe-edit': 'Edit Recipe',
    'prepared-items': 'Prepared Items',
    'prepared-edit': 'Edit Prepared Item',
    prodsetup: 'Product Setup'
  };
  document.getElementById('pageTitle').textContent = titles[view] || view;

  // Load data
  switch(view) {
    case 'dashboard': loadDashboard(); break;
    case 'products': loadProducts(); break;
    case 'vendors': loadVendors(); break;
    case 'inv': invInit(); break;
    case 'recipes': loadRecipes(); break;
    case 'prepared-items': loadPreparedItems(); break;
    case 'prodsetup': loadProductSetup(); break;
    case 'settings': loadSettings(); break;
  }
}

// Products
async function loadProducts(forceRefresh) {
  try {
    const categoryFilter = document.getElementById('products-category-filter').value;
    let url = '/api/inventory/products?active=true&location=' + window.currentLocation;
    if (categoryFilter) url += '&category=' + categoryFilter;
    
    const [products, setupData] = await Promise.all([
      fetch(url).then(r => r.json()),
      fetch('/api/inventory/products/setup-status?location=' + (window.currentLocation || 'dennis')).then(r => r.json())
    ]);
    
    // Build setup map
    const setupMap = {};
    setupData.forEach(s => { setupMap[s.id] = s; });
    
    // Sort: if setup sort active, put needs-setup first
    let sorted = products;
    if (document.getElementById('sort-setup-btn') && document.getElementById('sort-setup-btn').classList.contains('active')) {
      sorted = [...products].sort((a, b) => {
        const sa = setupMap[a.id], sb = setupMap[b.id];
        const aNeeds = sa ? sa.needs_setup.length + (sa.setup_complete ? 0 : 1) : 0;
        const bNeeds = sb ? sb.needs_setup.length + (sb.setup_complete ? 0 : 1) : 0;
        if (aNeeds !== bNeeds) return bNeeds - aNeeds;
        return a.name.localeCompare(b.name);
      });
    }
    
    document.getElementById('products-table').innerHTML = sorted.map(p => {
      const s = setupMap[p.id] || {};
      const needs = s.needs_setup || [];
      
const conversion = p.unit_conversion && p.unit_conversion > 1 ? ' (' + p.unit_conversion + 'x)' : '';
      const tagClass = 'tag-' + (p.category || 'other').toLowerCase();
      
      return '<tr>' +
        '<td>' + (s.is_ready ? '' : '<span style="color:#FF9F0A;font-size:13px;margin-right:6px" title="Needs setup">\u2b50</span>') + '<strong>' + (p.name || '') + '</strong></td>' +
        '<td><span class="tag ' + tagClass + '">' + (p.category || '--') + '</span></td>' +
        '<td>' + (p.vendor_name || '--') + '</td>' +
        '<td>' + (p.current_price ? '$' + Number(p.current_price).toFixed(2) : '--') + '</td>' +
        '<td style="font-size:12px">' + (s.storage_count || 0) + ' area(s)</td>' +
        '<td>' + (p.unit || '--') + '</td>' +
        '<td>' + (p.inventory_unit || '--') + conversion + '</td>' +
        '<td><button class="btn btn-secondary" style="padding:5px 10px;font-size:11px" onclick="editProduct(' + p.id + ')">Edit</button></td>' +
        '</tr>';
    }).join('');
    
    // Update dashboard stat
    const needsSetup = setupData.filter(s => !s.is_ready).length;
    const statEl = document.getElementById('stat-products');
    if (statEl) statEl.textContent = products.length + (needsSetup > 0 ? ' (' + needsSetup + ' need setup)' : '');
    
  } catch(e) {
    console.error('Error loading products:', e);
  }
}





function clearProductCache() {
  localStorage.removeItem('products_cache');
  localStorage.removeItem('products_cache_time');
  console.log('🗑️ Product cache cleared');
}

let editingProductId = null;

async function editProduct(id) {
  try {
    // Load storage location checkboxes first
    await loadStorageLocationCheckboxes(id);

    // Fetch product details
    const product = await fetch(`/api/inventory/products/${id}`).then(r => r.json());

    // Populate form
    editingProductId = id;
    const form = document.getElementById('form-product');
    form.name.value = product.name || '';
    form.category.value = product.category || 'FOOD';
    form.unit.value = product.unit || '';
    form.pack_size.value = product.pack_size || '';
    form.inventory_unit.value = product.inventory_unit || '';
    form.unit_conversion.value = product.unit_conversion || 1;
    form.current_price.value = product.current_price || '';
    form.par_level.value = product.par_level || '';
    form.reorder_point.value = product.reorder_point || '';
    form.notes.value = product.notes || '';

    // Change modal title
    document.querySelector('#modal-product .modal-title').textContent = 'Edit Product';

    // Open modal
    document.getElementById('modal-product').classList.add('active');
  } catch(e) {
    console.error('Error loading product:', e);
    alert('Error loading product details');
  }
}

async function saveProduct(e) {
  e.preventDefault();
  const form = e.target;
  const formData = new FormData(form);
  const data = Object.fromEntries(formData);

  // Get selected storage location IDs
  const locationCheckboxes = form.querySelectorAll('input[name="location_ids"]:checked');
  const locationIds = Array.from(locationCheckboxes).map(cb => parseInt(cb.value));

  try {
    let productId = editingProductId;

    if (editingProductId) {
      // Update existing product
      await fetch(`/api/inventory/products/${editingProductId}`, {
        method: 'PUT',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
      });
    } else {
      // Create new product
      const response = await fetch('/api/inventory/products', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
      });
      const result = await response.json();
      productId = result.id;
    }

    // Save storage locations for the product
    if (productId) {
      await fetch(`/api/storage/product/${productId}/locations`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ location_ids: locationIds })
      });
    }

    closeModal('modal-product');
    form.reset();
    editingProductId = null;
    clearProductCache(); // Clear cache so next load fetches fresh data
    loadProducts(true); // Force refresh
  } catch(e) {
    console.error('Error saving product:', e);
    alert('Error saving product');
  }
}

// Vendors
async function loadVendors() {
  try {
    const vendors = await fetch('/api/inventory/vendors').then(r => r.json());
    document.getElementById('vendors-table').innerHTML = vendors.map(v => `
      <tr>
        <td>${v.name}</td>
        <td>${v.category||'--'}</td>
        <td>${v.contact_name||'--'}</td>
        <td>${v.email||'--'}</td>
        <td>${v.phone||'--'}</td>
        <td><button class="btn btn-secondary" style="padding:6px 12px;font-size:12px;" onclick="editVendor(${v.id})">Edit</button></td>
      </tr>
    `).join('');
  } catch(e) {
    console.error('Error loading vendors:', e);
  }
}

async function saveVendor(e) {
  e.preventDefault();
  const form = e.target;
  const data = Object.fromEntries(new FormData(form));
  
  try {
    await fetch('/api/inventory/vendors', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(data)
    });
    closeModal('modal-vendor');
    form.reset();
    loadVendors();
  } catch(e) {
    alert('Error saving vendor');
  }
}

// Inventory
async function loadInventory() {
  const location = document.getElementById('inv-location').value;
  try {
    const inventory = await fetch(`/api/inventory/stock?location=${location}`).then(r => r.json());
    document.getElementById('inventory-table').innerHTML = inventory.map(i => {
      const lowStock = i.par_level && i.quantity <= i.par_level;
      return `
        <tr>
          <td>${i.product_name}</td>
          <td><span class="tag tag-${(i.category||'').toLowerCase()}">${i.category||'--'}</span></td>
          <td>${i.location}</td>
          <td><strong>${i.quantity}</strong></td>
          <td>${i.unit}</td>
          <td>${i.par_level||'--'}</td>
          <td><span class="tag ${lowStock?'tag-liquor':'tag-food'}">${lowStock?'LOW':'OK'}</span></td>
          <td><button class="btn btn-secondary" style="padding:6px 12px;font-size:12px;">Adjust</button></td>
        </tr>
      `;
    }).join('');
  } catch(e) {
    console.error('Error loading inventory:', e);
  }
}

let allInventoryProducts = [];
let filteredInventoryProducts = [];

async function openInventoryModal() {
  // Load all products
  try {
    allInventoryProducts = await fetch('/api/inventory/products').then(r => r.json());
    filteredInventoryProducts = allInventoryProducts;
    updateProductSelect();
    document.getElementById('modal-inventory').classList.add('active');
  } catch(e) {
    console.error('Error loading products:', e);
    alert('Error loading products');
  }
}

function updateProductSelect() {
  const select = document.getElementById('inv-product-select');
  select.innerHTML = filteredInventoryProducts.map(p =>
    `<option value="${p.id}" data-unit="${p.inventory_unit||'each'}">${p.name} (${p.category}) - ${p.inventory_unit||'each'}</option>`
  ).join('');

  // Update unit when product selected
  select.onchange = function() {
    const option = this.options[this.selectedIndex];
    document.getElementById('inv-unit').value = option.dataset.unit || 'each';
  };
}

function filterInventoryProducts() {
  const category = document.getElementById('inv-category-filter').value;
  const searchTerm = document.getElementById('inv-product-search').value.toLowerCase();

  filteredInventoryProducts = allInventoryProducts.filter(p => {
    const matchCategory = !category || p.category === category;
    const matchSearch = !searchTerm || p.name.toLowerCase().includes(searchTerm);
    return matchCategory && matchSearch;
  });

  updateProductSelect();
}

function searchInventoryProducts() {
  filterInventoryProducts();
}

async function saveInventoryCount(e) {
  e.preventDefault();
  const form = e.target;
  const data = Object.fromEntries(new FormData(form));

  // Convert to adjustment API format
  const payload = {
    product_id: parseInt(data.product_id),
    location: data.location,
    quantity: parseFloat(data.quantity),
    unit: data.unit,
    type: 'COUNT',
    notes: data.notes || 'Inventory count'
  };

  try {
    await fetch('/api/inventory/stock/adjust', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(payload)
    });

    closeModal('modal-inventory');
    form.reset();
    loadInventory();
    alert('Inventory count saved!');
  } catch(e) {
    console.error('Error saving inventory:', e);
    alert('Error saving inventory count');
  }
}

// Recipes
async function loadRecipes() {
  try {
    const recipes = await fetch('/api/inventory/recipes').then(r => r.json());
    document.getElementById('recipes-table').innerHTML = recipes.map(r => {
      let locLabel = '🏢 Both';
      if (r.location === 'dennis') locLabel = '📍 Dennis';
      else if (r.location === 'chatham') locLabel = '📍 Chatham';

      return `
      <tr>
        <td>
          ${r.name}
          ${r.menu_item_name ? '<br><span style="font-size:11px;color:var(--text3)">🔗 ' + r.menu_item_name + '</span>' : ''}
        </td>
        <td><span style="font-size:12px;color:var(--text2)">${locLabel}</span></td>
        <td>${r.category||'--'}</td>
        <td>${r.menu_price ? fmt(r.menu_price) : '--'}</td>
        <td>--</td>
        <td>--</td>
        <td><button class="btn btn-secondary" style="padding:6px 12px;font-size:12px;" onclick="openRecipePage(${r.id})">View</button></td>
      </tr>
      `;
    }).join('');
  } catch(e) {
    console.error('Error loading recipes:', e);
  }
}

async function saveRecipe(e) {
  e.preventDefault();
  const form = e.target;
  const data = Object.fromEntries(new FormData(form));

  try {
    const response = await fetch('/api/inventory/recipes', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(data)
    });

    if (!response.ok) {
      const error = await response.json();
      alert('Error: ' + (error.error || 'Failed to save recipe'));
      return;
    }

    closeModal('modal-recipe');
    form.reset();
    loadRecipes();
    alert('Recipe saved successfully!');
  } catch(e) {
    console.error('Error saving recipe:', e);
    alert('Error saving recipe');
  }
}

let currentRecipeId = null;

async function editRecipeName() {
  if (!currentRecipeId) return;

  const currentName = document.getElementById('recipe-detail-title').textContent;
  const newName = prompt('Edit recipe name:', currentName);

  if (!newName || newName.trim() === '' || newName === currentName) return;

  try {
    const response = await fetch('/api/inventory/recipes/' + currentRecipeId, {
      method: 'PATCH',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ name: newName.trim() })
    });

    if (!response.ok) {
      alert('Error updating recipe name');
      return;
    }

    document.getElementById('recipe-detail-title').textContent = newName.trim();
    loadRecipes(); // Refresh the recipes list
  } catch(e) {
    console.error('Error updating recipe name:', e);
    alert('Error updating recipe name');
  }
}

async function viewRecipe(recipeId) {
  currentRecipeId = recipeId;
  try {
    const recipe = await fetch('/api/inventory/recipes/' + recipeId).then(r => r.json());

    document.getElementById('recipe-detail-title').textContent = recipe.name;

    let locLabel = recipe.location === 'dennis' ? 'Dennis Port' : recipe.location === 'chatham' ? 'Chatham' : 'Both Locations';

    document.getElementById('recipe-detail-info').innerHTML = `
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px">
        <div><div style="font-size:11px;color:var(--text3);margin-bottom:4px">Location</div><div style="font-weight:600">${locLabel}</div></div>
        <div><div style="font-size:11px;color:var(--text3);margin-bottom:4px">Category</div><div style="font-weight:600">${recipe.category||'--'}</div></div>
        <div><div style="font-size:11px;color:var(--text3);margin-bottom:4px">Menu Price</div><div style="font-weight:600">${recipe.menu_price?'$'+recipe.menu_price:'--'}</div></div>
        <div><div style="font-size:11px;color:var(--text3);margin-bottom:4px">Serving Size</div><div style="font-weight:600">${recipe.serving_size||1} ${recipe.serving_unit||'portion'}</div></div>
      </div>
      ${recipe.description?'<div style="margin-top:12px;color:var(--text2);font-size:13px">'+recipe.description+'</div>':''}
      ${recipe.menu_item_name?'<div style="margin-top:12px;font-size:12px;color:var(--text3)">🔗 Linked to: '+recipe.menu_item_name+'</div>':''}
    `;

    loadRecipeIngredients(recipeId);
    loadRecipeMenuLinks(recipeId);

    document.getElementById('modal-recipe-detail').classList.add('active');
  } catch(e) {
    console.error('Error loading recipe:', e);
    alert('Error loading recipe');
  }
}

async function loadRecipeMenuLinks(recipeId) {
  try {
    const links = await fetch('/api/inventory/recipes/' + recipeId + '/menu-links').then(r => r.json());

    const dennisLink = links.find(l => l.location === 'dennis');
    const chathamLink = links.find(l => l.location === 'chatham');

    document.getElementById('recipe-menu-links').innerHTML = `
      <div style="display:grid;gap:12px">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px;background:var(--card);border-radius:8px">
          <div>
            <div style="font-size:13px;font-weight:600;margin-bottom:2px">📍 Dennis Port</div>
            <div style="font-size:12px;color:var(--text3)" id="dennis-link-text">
              ${dennisLink ? '🔗 ' + dennisLink.menu_item_name : 'Not linked'}
            </div>
          </div>
          <button class="btn btn-secondary" onclick="editMenuLink('dennis')" style="padding:6px 12px;font-size:11px">
            ${dennisLink ? 'Change' : 'Link'}
          </button>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px;background:var(--card);border-radius:8px">
          <div>
            <div style="font-size:13px;font-weight:600;margin-bottom:2px">📍 Chatham</div>
            <div style="font-size:12px;color:var(--text3)" id="chatham-link-text">
              ${chathamLink ? '🔗 ' + chathamLink.menu_item_name : 'Not linked'}
            </div>
          </div>
          <button class="btn btn-secondary" onclick="editMenuLink('chatham')" style="padding:6px 12px;font-size:11px">
            ${chathamLink ? 'Change' : 'Link'}
          </button>
        </div>
      </div>
    `;
  } catch(e) {
    console.error('Error loading menu links:', e);
  }
}

async function editMenuLink(location) {
  try {
    // Load menu items for this location
    const menuItems = await fetch('/api/inventory/menu-items?location=' + location).then(r => r.json());

    if (menuItems.length === 0) {
      alert('No menu items found for ' + (location === 'dennis' ? 'Dennis Port' : 'Chatham') + '. Sync menu data from Toast first.');
      return;
    }

    const locationName = location === 'dennis' ? 'Dennis Port' : 'Chatham';
    const options = menuItems.map(item =>
      `<option value="${item.guid}">${item.name}${item.menu_group_name ? ' (' + item.menu_group_name + ')' : ''}</option>`
    ).join('');

    const selection = prompt(
      locationName + ' - Enter the number of the menu item:\n\n' +
      menuItems.map((item, i) => `${i + 1}. ${item.name}${item.menu_group_name ? ' (' + item.menu_group_name + ')' : ''}`).join('\n') +
      '\n\n(Enter 0 to remove link)'
    );

    if (selection === null) return; // Cancelled

    const idx = parseInt(selection) - 1;

    if (selection === '0') {
      // Remove link
      await fetch('/api/inventory/recipes/' + currentRecipeId + '/menu-links/' + location, {
        method: 'DELETE'
      });
      loadRecipeMenuLinks(currentRecipeId);
      return;
    }

    if (idx < 0 || idx >= menuItems.length) {
      alert('Invalid selection');
      return;
    }

    // Save link
    await fetch('/api/inventory/recipes/' + currentRecipeId + '/menu-links', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        location: location,
        menu_item_guid: menuItems[idx].guid
      })
    });

    loadRecipeMenuLinks(currentRecipeId);
  } catch(e) {
    console.error('Error editing menu link:', e);
    alert('Error updating menu link');
  }
}

let allProducts = [];
async function ensureProductsLoaded() {
  if (allProducts.length === 0) {
    try { allProducts = await fetch('/api/inventory/product-settings').then(r => r.json()); }
    catch(e) { console.error('Error loading products:', e); }
  }
  return allProducts;
}

async function loadRecipeIngredients(recipeId) {
  try {
    const recipe = await fetch('/api/inventory/recipes/' + recipeId).then(r => r.json());
    const ingredients = recipe.ingredients || [];
    await ensureProductsLoaded();
    const productOptions = allProducts.map(p => `<option value="${p.id}">${p.product_name}${p.vendor_name ? ' (' + p.vendor_name + ')' : ''}</option>`).join('');
    const rows = ingredients.map((ing, i) => `
      <tr>
        <td style="color:var(--text3);font-size:12px;text-align:center;width:30px">${i+1}</td>
        <td style="font-weight:500">${ing.product_name||'Unknown'}</td>
        <td style="text-align:center;width:80px">${ing.quantity||0}</td>
        <td style="text-align:center;width:80px">${ing.unit||'--'}</td>
        <td style="text-align:right;width:80px">${ing.current_price?'$'+(ing.quantity*ing.current_price).toFixed(2):'--'}</td>
        <td style="width:40px;text-align:center"><button onclick="removeIngredient(${recipeId},${ing.ingredient_id||ing.product_id})" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px;padding:4px" title="Remove">&#128465;</button></td>
      </tr>`).join('');
    document.getElementById('recipe-ingredients-list').innerHTML = `
      <table class="data-table" style="margin:0">
        <thead><tr>
          <th style="width:30px;text-align:center">#</th>
          <th>Item</th>
          <th style="text-align:center;width:80px">Qty</th>
          <th style="text-align:center;width:80px">Unit</th>
          <th style="text-align:right;width:80px">Cost</th>
          <th style="width:40px"></th>
        </tr></thead>
        <tbody>${rows}
          <tr style="border-top:2px solid var(--border)">
            <td style="color:#22c55e;text-align:center;font-size:14px">+</td>
            <td><select id="inline-ing-product" class="form-select" style="font-size:13px;padding:6px 8px;background:var(--bg);border-color:var(--border)" onchange="onInlineProductSelect(this)"><option value="">+ Add ingredient...</option>${productOptions}</select></td>
            <td><input type="number" step="0.01" id="inline-ing-qty" class="form-input" style="font-size:13px;padding:6px 8px;text-align:center;width:70px;background:var(--bg);border-color:var(--border)" placeholder="0" disabled></td>
            <td><select id="inline-ing-unit" class="form-select" style="font-size:13px;padding:6px 8px;background:var(--bg);border-color:var(--border);width:70px" disabled><option value="">--</option><option value="oz">oz</option><option value="lb">lb</option><option value="each">each</option><option value="cup">cup</option><option value="tbsp">tbsp</option><option value="tsp">tsp</option><option value="gal">gal</option><option value="liter">liter</option><option value="ml">ml</option><option value="g">g</option><option value="kg">kg</option><option value="slice">slice</option><option value="portion">portion</option></select></td>
            <td style="text-align:right"><button onclick="saveInlineIngredient()" id="inline-save-btn" class="btn btn-primary" style="padding:4px 12px;font-size:12px;background:#22c55e;border-color:#22c55e;display:none">Add</button></td>
            <td></td>
          </tr>
        </tbody>
      </table>`;
    updateCostSummary(ingredients, recipe.menu_price);
  } catch(e) { console.error('Error loading ingredients:', e); }
}

function updateCostSummary(ingredients, menuPrice) {
  let total = 0;
  ingredients.forEach(ing => { if (ing.current_price && ing.quantity) total += ing.quantity * ing.current_price; });
  const te = document.getElementById('ingredient-total');
  const pe = document.getElementById('recipe-menu-price-display');
  const ce = document.getElementById('plate-cost-pct');
  if (te) te.textContent = '$' + total.toFixed(2);
  if (pe) pe.textContent = menuPrice ? '$' + parseFloat(menuPrice).toFixed(2) : '--';
  if (ce) {
    if (menuPrice && total > 0) { const pct = (total/parseFloat(menuPrice)*100).toFixed(1); ce.textContent = pct+'%'; ce.style.color = pct>35?'#ef4444':pct>28?'#f59e0b':'#22c55e'; }
    else { ce.textContent = '--'; ce.style.color = ''; }
  }
}

function onInlineProductSelect(sel) {
  const h = sel.value !== '';
  document.getElementById('inline-ing-qty').disabled = !h;
  document.getElementById('inline-ing-unit').disabled = !h;
  document.getElementById('inline-save-btn').style.display = h ? 'inline-block' : 'none';
  if (h) document.getElementById('inline-ing-qty').focus();
}

async function saveInlineIngredient() {
  const pid = document.getElementById('inline-ing-product').value;
  const qty = document.getElementById('inline-ing-qty').value;
  const unit = document.getElementById('inline-ing-unit').value;
  if (!pid||!qty) { alert('Select a product and enter quantity'); return; }
  try {
    const r = await fetch('/api/inventory/recipes/'+currentRecipeId+'/ingredients',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({product_id:parseInt(pid),quantity:parseFloat(qty),unit:unit})});
    if (!r.ok) { const e = await r.json(); alert('Error: '+(e.error||'Failed')); return; }
    loadRecipeIngredients(currentRecipeId);
  } catch(e) { console.error(e); alert('Error saving ingredient'); }
}

async function removeIngredient(recipeId, ingredientId) {
  if (!confirm('Remove this ingredient?')) return;
  try {
    const r = await fetch('/api/inventory/recipes/'+recipeId+'/ingredients/'+ingredientId,{method:'DELETE'});
    if (!r.ok) { alert('Error removing ingredient'); return; }
    loadRecipeIngredients(recipeId);
  } catch(e) { console.error(e); alert('Error removing ingredient'); }
}








async function saveRecipeField(field) {
  if (!currentRecipeId) return;
  let data = {};
  if (field === 'yield') {
    data.yield_qty = parseFloat(document.getElementById('recipe-yield-qty').value) || 1;
    data.yield_unit = document.getElementById('recipe-yield-unit').value;
  } else if (field === 'settings') {
    data.restricted_locations = document.getElementById('recipe-restricted').checked ? 1 : 0;
    data.is_inventoried = document.getElementById('recipe-inventoried').checked ? 1 : 0;
  } else if (field === 'shelf') {
    data.shelf_life_qty = parseFloat(document.getElementById('recipe-shelf-qty').value) || null;
    data.shelf_life_unit = document.getElementById('recipe-shelf-unit').value;
  } else if (field === 'prep') {
    data.equipment = document.getElementById('recipe-equipment').value;
    const steps = [];
    document.querySelectorAll('.method-step-input').forEach(el => {
      if (el.value.trim()) steps.push(el.value.trim());
    });
    data.method_steps = JSON.stringify(steps);
  }
  try {
    const r = await fetch('/api/inventory/recipes/' + currentRecipeId, {
      method: 'PATCH', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data)
    });
    if (r.ok) {
      const indicator = document.createElement('span');
      indicator.textContent = ' Saved!';
      indicator.style.cssText = 'color:#22c55e;font-size:12px;font-weight:600';
      event.target.parentElement.appendChild(indicator);
      setTimeout(() => indicator.remove(), 2000);
    }
  } catch(e) { console.error(e); alert('Error saving'); }
}

function addMethodStep(value) {
  const container = document.getElementById('recipe-method-steps');
  const idx = container.children.length + 1;
  const div = document.createElement('div');
  div.style.cssText = 'display:flex;gap:8px;align-items:flex-start;margin-bottom:8px';
  div.innerHTML = '<span style="color:var(--text3);font-size:12px;min-width:20px;padding-top:10px">' + idx + '.</span>' +
    '<textarea class="form-input method-step-input" rows="2" style="flex:1;padding:8px;background:var(--bg);border-color:var(--border);resize:vertical" placeholder="Describe this step...">' + (value || '') + '</textarea>' +
    '<button onclick="this.parentElement.remove();renumberSteps()" style="background:none;border:none;color:#ef4444;cursor:pointer;padding:8px;font-size:14px" title="Remove step">&#128465;</button>';
  container.appendChild(div);
}

function renumberSteps() {
  document.querySelectorAll('#recipe-method-steps > div').forEach((div, i) => {
    div.querySelector('span').textContent = (i+1) + '.';
  });
}

// Extend viewRecipe to populate the new fields
const _origViewRecipe = viewRecipe;
viewRecipe = async function(recipeId) {
  await _origViewRecipe(recipeId);
  try {
    const recipe = await fetch('/api/inventory/recipes/' + recipeId).then(r => r.json());
    // Yields
    const yqEl = document.getElementById('recipe-yield-qty');
    const yuEl = document.getElementById('recipe-yield-unit');
    if (yqEl) yqEl.value = recipe.yield_qty || 1;
    if (yuEl) yuEl.value = recipe.yield_unit || 'Each';
    // Settings
    const rrEl = document.getElementById('recipe-restricted');
    const riEl = document.getElementById('recipe-inventoried');
    if (rrEl) rrEl.checked = !!recipe.restricted_locations;
    if (riEl) riEl.checked = !!recipe.is_inventoried;
    // Shelf life
    const sqEl = document.getElementById('recipe-shelf-qty');
    const suEl = document.getElementById('recipe-shelf-unit');
    if (sqEl) sqEl.value = recipe.shelf_life_qty || '';
    if (suEl) suEl.value = recipe.shelf_life_unit || 'Days';
    // Equipment
    const eqEl = document.getElementById('recipe-equipment');
    if (eqEl) eqEl.value = recipe.equipment || '';
    // Method steps
    const stepsContainer = document.getElementById('recipe-method-steps');
    if (stepsContainer) {
      stepsContainer.innerHTML = '';
      let steps = [];
      try { steps = JSON.parse(recipe.method_steps || '[]'); } catch(e) {}
      if (steps.length === 0) addMethodStep('');
      else steps.forEach(s => addMethodStep(s));
    }
  } catch(e) { console.error('Error loading recipe details:', e); }
};


let currentEditRecipeId = null;

async function openRecipePage(recipeId) {
  currentEditRecipeId = recipeId;
  currentRecipeId = recipeId;
  showView('recipe-edit');

  try {
    const recipe = await fetch('/api/inventory/recipes/' + recipeId).then(r => r.json());

    // Header
    document.getElementById('recipe-page-title').textContent = recipe.name;
    document.getElementById('recipe-edit-breadcrumb').textContent = recipe.name;

    // Item Details
    document.getElementById('rp-category').value = recipe.category || '';
    document.getElementById('rp-menu-price').value = recipe.menu_price || '';
    document.getElementById('rp-prep-time').value = recipe.prep_time_minutes || '';
    document.getElementById('rp-description').value = recipe.description || '';

    let locLabel = recipe.location === 'dennis' ? 'Dennis Port' : recipe.location === 'chatham' ? 'Chatham' : 'Both Locations';
    document.getElementById('rp-location-display').textContent = locLabel;

    // Yields
    document.getElementById('rp-yield-qty').value = recipe.yield_qty || 1;
    document.getElementById('rp-yield-unit').value = recipe.yield_unit || 'Each';

    // Settings
    document.getElementById('rp-restricted').checked = !!recipe.restricted_locations;
    document.getElementById('rp-inventoried').checked = !!recipe.is_inventoried;

    // Shelf Life
    document.getElementById('rp-shelf-qty').value = recipe.shelf_life_qty || '';
    document.getElementById('rp-shelf-unit').value = recipe.shelf_life_unit || 'Days';

    // Equipment
    document.getElementById('rp-equipment').value = recipe.equipment || '';

    // Method steps
    const stepsContainer = document.getElementById('rp-method-steps');
    stepsContainer.innerHTML = '';
    let steps = [];
    try { steps = JSON.parse(recipe.method_steps || '[]'); } catch(e) {}
    if (steps.length === 0) addMethodStepPage('');
    else steps.forEach(s => addMethodStepPage(s));

    // Notes
    document.getElementById('rp-notes').value = recipe.notes || '';

    // Load ingredients into full page
    await loadPageIngredients(recipeId, recipe.menu_price);

    // Load menu links
    await loadPageMenuLinks(recipeId);

  } catch(e) {
    console.error('Error loading recipe:', e);
    alert('Error loading recipe');
  }
}

async function loadPageIngredients(recipeId, menuPrice) {
  try {
    const recipe = await fetch('/api/inventory/recipes/' + recipeId).then(r => r.json());
    const ingredients = recipe.ingredients || [];
    await ensureProductsLoaded();
    const productOptions = allProducts.map(p => `<option value="${p.id}" data-cost="${p.cost_per_unit||0}" data-unit="${p.inventory_unit||''}" data-ordunit="${p.ordering_unit||''}">${p.product_name}${p.vendor_name ? ' (' + p.vendor_name + ')' : ''}</option>`).join('');

    const unitOptions = '<option value="">--</option><option value="oz">oz</option><option value="lb">lb</option><option value="each">each</option><option value="cup">cup</option><option value="tbsp">tbsp</option><option value="tsp">tsp</option><option value="gal">gal</option><option value="liter">liter</option><option value="ml">ml</option><option value="g">g</option><option value="kg">kg</option><option value="slice">slice</option><option value="portion">portion</option>';

    const rows = ingredients.map((ing, i) => {
      const yld = ing.yield_pct || 100;
      const cost = ing.current_price && ing.quantity ? (ing.quantity * ing.current_price / (yld / 100)).toFixed(2) : '--';
      const selUnit = ing.unit || '';
      return `
      <tr class="rp-ing-row" data-id="${ing.id}" data-product-id="${ing.product_id}">
        <td style="color:var(--text3);font-size:12px;text-align:center;width:30px">${i+1}</td>
        <td>
          <select class="rp-ir-product form-select" style="font-size:13px;padding:6px 8px;background:var(--bg);border-color:var(--border)" onchange="onIngRowProductChange(this)">
            <option value="">Select...</option>${productOptions}
          </select>
        </td>
        <td><input type="number" class="rp-ir-yield form-input" style="font-size:13px;padding:6px 8px;text-align:center;width:60px;background:var(--bg);border-color:var(--border)" value="${yld}" min="1" max="100" oninput="recalcIngCosts()"></td>
        <td><input type="number" step="0.01" class="rp-ir-qty form-input" style="font-size:13px;padding:6px 8px;text-align:center;width:70px;background:var(--bg);border-color:var(--border)" value="${ing.quantity||''}" oninput="recalcIngCosts()"></td>
        <td>
          <select class="rp-ir-unit form-select" style="font-size:13px;padding:6px 8px;background:var(--bg);border-color:var(--border);width:80px">
            ${unitOptions}
          </select>
        </td>
        <td class="rp-ir-cost" style="text-align:right;width:80px;font-weight:600">${cost !== '--' ? '$'+cost : '--'}</td>
        <td style="width:40px;text-align:center"><button onclick="this.closest('tr').remove();recalcIngCosts();" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px;padding:4px">&#128465;</button></td>
      </tr>`;
    }).join('');

    window._rpProductOptions = productOptions;
    window._rpUnitOptions = unitOptions;
    document.getElementById('rp-ingredients-list').innerHTML = `
      <table class="data-table" style="margin:0">
        <thead><tr>
          <th style="width:30px;text-align:center">#</th>
          <th>Item</th>
          <th style="text-align:center;width:70px">Yield</th>
          <th style="text-align:center;width:70px">Qty</th>
          <th style="text-align:center;width:70px">Unit</th>
          <th style="text-align:right;width:80px">Cost</th>
          <th style="width:40px"></th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
      <div style="padding:12px 16px">
        <a href="#" onclick="addIngredientRow();return false;" style="color:#22c55e;font-size:13px;font-weight:600;text-decoration:none">+ Add ingredient</a>
      </div>`;

    // Set select values for existing ingredients
    ingredients.forEach((ing, i) => {
      const row = document.querySelectorAll('.rp-ing-row')[i];
      if (!row) return;
      const prodSel = row.querySelector('.rp-ir-product');
      if (prodSel) prodSel.value = ing.product_id;
      const unitSel = row.querySelector('.rp-ir-unit');
      if (unitSel && ing.unit) unitSel.value = ing.unit;
    });
    // Recalculate costs from the editable rows
    setTimeout(() => recalcIngCosts(), 100);
  } catch(e) { console.error(e); }
}

function onPageProductChange(sel) {
  const hasVal = sel.value !== '';
  document.getElementById('rp-ing-yield').disabled = !hasVal;
  document.getElementById('rp-ing-qty').disabled = !hasVal;
  document.getElementById('rp-ing-unit').disabled = !hasVal;
  document.getElementById('rp-ing-save').style.display = hasVal ? 'inline-block' : 'none';
  document.getElementById('rp-ing-cost-preview').textContent = '';
  if (hasVal) {
    const opt = sel.selectedOptions[0];
    const invUnit = opt.dataset.unit;
    if (invUnit) {
      const unitSel = document.getElementById('rp-ing-unit');
      for (let i = 0; i < unitSel.options.length; i++) {
        if (unitSel.options[i].value === invUnit) { unitSel.selectedIndex = i; break; }
      }
    }
    document.getElementById('rp-ing-qty').focus();
  }
}

function calcInlineCost() {
  const sel = document.getElementById('rp-ing-product');
  if (!sel.value) return;
  const costPerUnit = parseFloat(sel.selectedOptions[0].dataset.cost) || 0;
  const qty = parseFloat(document.getElementById('rp-ing-qty').value) || 0;
  const yld = parseFloat(document.getElementById('rp-ing-yield').value) || 100;
  if (qty > 0 && costPerUnit > 0) {
    const cost = (qty * costPerUnit / (yld / 100)).toFixed(2);
    document.getElementById('rp-ing-cost-preview').textContent = '$' + cost;
  } else {
    document.getElementById('rp-ing-cost-preview').textContent = '';
  }
}

function onPageProductSelect(sel) {
  const h = sel.value !== '';
  document.getElementById('rp-ing-qty').disabled = !h;
  document.getElementById('rp-ing-unit').disabled = !h;
  document.getElementById('rp-ing-save').style.display = h ? 'inline-block' : 'none';
  if (h) document.getElementById('rp-ing-qty').focus();
}

function addIngredientRow() {
  const tbody = document.querySelector('#rp-ingredients-list table tbody');
  if (!tbody) return;
  const n = tbody.children.length + 1;
  const tr = document.createElement('tr');
  tr.className = 'rp-ing-row';
  tr.dataset.id = 'new';
  tr.dataset.productId = '';
  tr.innerHTML = `
    <td style="color:var(--text3);font-size:12px;text-align:center;width:30px">${n}</td>
    <td><select class="rp-ir-product form-select" style="font-size:13px;padding:6px 8px;background:var(--bg);border-color:var(--border)" onchange="onIngRowProductChange(this)"><option value="">Select...</option>${window._rpProductOptions||''}</select></td>
    <td><input type="number" class="rp-ir-yield form-input" style="font-size:13px;padding:6px 8px;text-align:center;width:60px;background:var(--bg);border-color:var(--border)" value="100" min="1" max="100" oninput="recalcIngCosts()"></td>
    <td><input type="number" step="0.01" class="rp-ir-qty form-input" style="font-size:13px;padding:6px 8px;text-align:center;width:70px;background:var(--bg);border-color:var(--border)" placeholder="0" oninput="recalcIngCosts()"></td>
    <td><select class="rp-ir-unit form-select" style="font-size:13px;padding:6px 8px;background:var(--bg);border-color:var(--border);width:80px">${window._rpUnitOptions||''}</select></td>
    <td class="rp-ir-cost" style="text-align:right;width:80px;font-weight:600">--</td>
    <td style="width:40px;text-align:center"><button onclick="this.closest('tr').remove();recalcIngCosts();" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px;padding:4px">&#128465;</button></td>`;
  tbody.appendChild(tr);
  tr.querySelector('.rp-ir-product').focus();
}

function onIngRowProductChange(sel) {
  const tr = sel.closest('tr');
  if (!sel.value) return;
  const opt = sel.selectedOptions[0];
  const invUnit = opt.dataset.unit || '';
  const unitSel = tr.querySelector('.rp-ir-unit');
  if (invUnit) {
    for (let i=0;i<unitSel.options.length;i++){if(unitSel.options[i].value===invUnit){unitSel.selectedIndex=i;break;}}
  }
  tr.querySelector('.rp-ir-qty').focus();
  recalcIngCosts();
}

function recalcIngCosts() {
  let total = 0;
  document.querySelectorAll('.rp-ing-row').forEach(tr => {
    const sel = tr.querySelector('.rp-ir-product');
    if (!sel || !sel.value) return;
    const costPerUnit = parseFloat(sel.selectedOptions[0]?.dataset?.cost) || 0;
    const qty = parseFloat(tr.querySelector('.rp-ir-qty')?.value) || 0;
    const yld = parseFloat(tr.querySelector('.rp-ir-yield')?.value) || 100;
    const costTd = tr.querySelector('.rp-ir-cost');
    if (qty > 0 && costPerUnit > 0) {
      const c = qty * costPerUnit / (yld / 100);
      costTd.textContent = '$' + c.toFixed(2);
      total += c;
    } else {
      costTd.textContent = '--';
    }
  });
  const totalEl = document.getElementById('rp-ingredient-total');
  if (totalEl) totalEl.textContent = '$' + total.toFixed(2);
  const mp = parseFloat(document.getElementById('rp-menu-price')?.value) || 0;
  const mpEl = document.getElementById('rp-menu-price-display');
  if (mpEl) mpEl.textContent = mp ? '$' + mp.toFixed(2) : '--';
  const ce = document.getElementById('rp-plate-cost');
  if (ce) {
    if (mp && total > 0) { const pct = (total/mp*100).toFixed(1); ce.textContent = pct+'%'; ce.style.color = pct>35?'#ef4444':pct>28?'#f59e0b':'#22c55e'; }
    else { ce.textContent = '--'; ce.style.color = ''; }
  }
}

function getIngredientRows() {
  const rows = [];
  document.querySelectorAll('.rp-ing-row').forEach(tr => {
    const pid = tr.querySelector('.rp-ir-product')?.value;
    if (!pid) return;
    rows.push({
      product_id: parseInt(pid),
      quantity: parseFloat(tr.querySelector('.rp-ir-qty')?.value) || 0,
      unit: tr.querySelector('.rp-ir-unit')?.value || '',
      yield_pct: parseFloat(tr.querySelector('.rp-ir-yield')?.value) || 100
    });
  });
  return rows;
}

async function loadPageMenuLinks(recipeId) {
  try {
    const links = await fetch('/api/inventory/recipes/' + recipeId + '/menu-links').then(r => r.json());
    const dennisLink = links.find(l => l.location === 'dennis');
    const chathamLink = links.find(l => l.location === 'chatham');
    document.getElementById('rp-menu-links').innerHTML = `
      <div style="display:grid;gap:12px">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px;background:var(--bg);border-radius:8px">
          <div>
            <div style="font-size:13px;font-weight:600;margin-bottom:2px">Dennis Port</div>
            <div style="font-size:12px;color:var(--text3)">${dennisLink ? dennisLink.menu_item_name : 'Not linked'}</div>
          </div>
          <button class="btn btn-secondary" onclick="editMenuLink('dennis')" style="padding:6px 12px;font-size:11px">${dennisLink ? 'Change' : 'Link'}</button>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px;background:var(--bg);border-radius:8px">
          <div>
            <div style="font-size:13px;font-weight:600;margin-bottom:2px">Chatham</div>
            <div style="font-size:12px;color:var(--text3)">${chathamLink ? chathamLink.menu_item_name : 'Not linked'}</div>
          </div>
          <button class="btn btn-secondary" onclick="editMenuLink('chatham')" style="padding:6px 12px;font-size:11px">${chathamLink ? 'Change' : 'Link'}</button>
        </div>
      </div>`;
  } catch(e) { console.error(e); }
}

function addMethodStepPage(value) {
  const container = document.getElementById('rp-method-steps');
  const idx = container.children.length + 1;
  const div = document.createElement('div');
  div.style.cssText = 'display:flex;gap:8px;align-items:flex-start;margin-bottom:8px';
  div.innerHTML = '<span style="color:var(--text3);font-size:12px;min-width:20px;padding-top:10px">' + idx + '.</span>' +
    '<textarea class="form-input rp-method-step" rows="2" style="flex:1;padding:8px;background:var(--bg);border-color:var(--border);resize:vertical" placeholder="Describe this step...">' + (value || '') + '</textarea>' +
    '<button onclick="this.parentElement.remove();renumberPageSteps()" style="background:none;border:none;color:#ef4444;cursor:pointer;padding:8px;font-size:14px">&#128465;</button>';
  container.appendChild(div);
}

function renumberPageSteps() {
  document.querySelectorAll('#rp-method-steps > div').forEach((div, i) => {
    div.querySelector('span').textContent = (i+1) + '.';
  });
}

async function editRecipeNamePage() {
  if (!currentEditRecipeId) return;
  const current = document.getElementById('recipe-page-title').textContent;
  const newName = prompt('Edit recipe name:', current);
  if (!newName || newName.trim() === '' || newName === current) return;
  try {
    await fetch('/api/inventory/recipes/' + currentEditRecipeId, {
      method: 'PATCH', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ name: newName.trim() })
    });
    document.getElementById('recipe-page-title').textContent = newName.trim();
    document.getElementById('recipe-edit-breadcrumb').textContent = newName.trim();
  } catch(e) { console.error(e); }
}

async function saveFullRecipe() {
  if (!currentEditRecipeId) return;
  const data = {
    category: document.getElementById('rp-category').value,
    menu_price: parseFloat(document.getElementById('rp-menu-price').value) || null,
    prep_time_minutes: parseInt(document.getElementById('rp-prep-time').value) || null,
    description: document.getElementById('rp-description').value,
    yield_qty: parseFloat(document.getElementById('rp-yield-qty').value) || 1,
    yield_unit: document.getElementById('rp-yield-unit').value,
    restricted_locations: document.getElementById('rp-restricted').checked ? 1 : 0,
    is_inventoried: document.getElementById('rp-inventoried').checked ? 1 : 0,
    shelf_life_qty: parseFloat(document.getElementById('rp-shelf-qty').value) || null,
    shelf_life_unit: document.getElementById('rp-shelf-unit').value,
    equipment: document.getElementById('rp-equipment').value,
    notes: document.getElementById('rp-notes').value
  };
  // Method steps
  const steps = [];
  document.querySelectorAll('.rp-method-step').forEach(el => {
    if (el.value.trim()) steps.push(el.value.trim());
  });
  data.method_steps = JSON.stringify(steps);

  try {
    // Validate ingredients
    const ingRows = getIngredientRows();
    const incomplete = document.querySelectorAll('.rp-ing-row').length > 0 && ingRows.some(r => !r.quantity);
    if (incomplete) { alert('Please ensure all ingredients have a quantity'); return; }

    const r = await fetch('/api/inventory/recipes/' + currentEditRecipeId, {
      method: 'PATCH', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(data)
    });
    // Save ingredients via bulk endpoint
    const ir = await fetch('/api/inventory/recipes/' + currentEditRecipeId + '/ingredients/bulk', {
      method: 'PUT', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ingredients: ingRows})
    });
    if (r.ok && ir.ok) {
      alert('Recipe saved!');
      showView('recipes');
      loadRecipes();
    } else {
      alert('Error saving recipe');
    }
  } catch(e) { console.error(e); alert('Error saving recipe'); }
}

async function deleteRecipe() {
  if (!currentEditRecipeId) return;
  if (!confirm('Are you sure you want to delete this recipe? This cannot be undone.')) return;
  try {
    await fetch('/api/inventory/recipes/' + currentEditRecipeId, { method: 'DELETE' });
    showView('recipes');
    loadRecipes();
  } catch(e) { console.error(e); alert('Error deleting recipe'); }
}

async function deactivateRecipe() {
  if (!currentEditRecipeId) return;
  try {
    await fetch('/api/inventory/recipes/' + currentEditRecipeId, {
      method: 'PATCH', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ active: 0 })
    });
    alert('Recipe deactivated');
    showView('recipes');
    loadRecipes();
  } catch(e) { console.error(e); alert('Error deactivating recipe'); }
}


function toggleRecipeNav() {
  const sub = document.getElementById('recipe-subnav');
  const chev = document.getElementById('recipe-nav-chevron');
  if (sub.style.display === 'none') {
    sub.style.display = 'block';
    chev.style.transform = 'rotate(90deg)';
  } else {
    sub.style.display = 'none';
    chev.style.transform = 'rotate(0deg)';
  }
}

// ===== PREPARED ITEMS =====
// Prepared items use the same recipes table but with category = sauce/dressing/etc
// They're sub-recipes used as ingredients in menu item recipes

let currentPrepId = null;

async function loadPreparedItems() {
  try {
    const recipes = await fetch('/api/inventory/recipes').then(r => r.json());
    const preps = recipes.filter(r => ['sauce','dressing','marinade','batter','base','garnish','mix','other'].includes(r.category));
    document.getElementById('prepared-items-table').innerHTML = preps.length === 0
      ? '<tr><td colspan="6" style="text-align:center;color:var(--text3);padding:20px">No prepared items yet. Click "+ Add Prepared Item" to create one.</td></tr>'
      : preps.map(r => {
        let locLabel = r.location === 'dennis' ? 'Dennis' : r.location === 'chatham' ? 'Chatham' : 'Both';
        return `<tr>
          <td style="font-weight:500">${r.name}</td>
          <td>${r.category || '--'}</td>
          <td>${(r.yield_qty||1)} ${r.yield_unit||'Each'}</td>
          <td>--</td>
          <td>--</td>
          <td><button class="btn btn-secondary" style="padding:6px 12px;font-size:12px" onclick="openPrepPage(${r.id})">View</button></td>
        </tr>`;
      }).join('');
  } catch(e) { console.error(e); }
}

function openPrepItemModal() {
  // Reuse recipe modal but set category default
  document.getElementById('form-recipe').reset();
  document.querySelector('#modal-recipe .modal-title').textContent = 'Add Prepared Item';
  const catSelect = document.querySelector('#form-recipe select[name="category"]');
  // Add prep categories if not present
  const prepCats = ['sauce','dressing','marinade','batter','base','garnish','mix','other'];
  const existingVals = Array.from(catSelect.options).map(o => o.value);
  prepCats.forEach(c => {
    if (!existingVals.includes(c)) {
      const opt = document.createElement('option');
      opt.value = c;
      opt.textContent = c.charAt(0).toUpperCase() + c.slice(1);
      catSelect.appendChild(opt);
    }
  });
  catSelect.value = 'sauce';
  document.getElementById('modal-recipe').classList.add('active');
}

async function openPrepPage(prepId) {
  currentPrepId = prepId;
  currentRecipeId = prepId;
  showView('prepared-edit');
  try {
    const recipe = await fetch('/api/inventory/recipes/' + prepId).then(r => r.json());
    document.getElementById('prep-page-title').textContent = recipe.name;
    document.getElementById('prep-edit-breadcrumb').textContent = recipe.name;
    document.getElementById('pp-category').value = recipe.category || '';
    document.getElementById('pp-prep-time').value = recipe.prep_time_minutes || '';
    document.getElementById('pp-description').value = recipe.description || '';
    let locLabel = recipe.location === 'dennis' ? 'Dennis Port' : recipe.location === 'chatham' ? 'Chatham' : 'Both Locations';
    document.getElementById('pp-location-display').textContent = locLabel;
    document.getElementById('pp-yield-qty').value = recipe.yield_qty || 1;
    document.getElementById('pp-yield-unit').value = recipe.yield_unit || 'Each';
    document.getElementById('pp-shelf-qty').value = recipe.shelf_life_qty || '';
    document.getElementById('pp-shelf-unit').value = recipe.shelf_life_unit || 'Days';
    document.getElementById('pp-equipment').value = recipe.equipment || '';
    document.getElementById('pp-notes').value = recipe.notes || '';
    // Method steps
    const sc = document.getElementById('pp-method-steps');
    sc.innerHTML = '';
    let steps = [];
    try { steps = JSON.parse(recipe.method_steps || '[]'); } catch(e) {}
    if (steps.length === 0) addPrepMethodStep('');
    else steps.forEach(s => addPrepMethodStep(s));
    // Ingredients
    await loadPrepIngredients(prepId);
  } catch(e) { console.error(e); alert('Error loading prepared item'); }
}

async function loadPrepIngredients(prepId) {
  try {
    const recipe = await fetch('/api/inventory/recipes/' + prepId).then(r => r.json());
    const ingredients = recipe.ingredients || [];
    await ensureProductsLoaded();
    const productOptions = allProducts.map(p => `<option value="${p.id}">${p.product_name}${p.vendor_name ? ' (' + p.vendor_name + ')' : ''}</option>`).join('');
    const rows = ingredients.map((ing, i) => `
      <tr>
        <td style="color:var(--text3);font-size:12px;text-align:center;width:30px">${i+1}</td>
        <td style="font-weight:500">${ing.product_name||'Unknown'}</td>
        <td style="text-align:center;width:80px">${ing.quantity||0}</td>
        <td style="text-align:center;width:80px">${ing.unit||'--'}</td>
        <td style="text-align:right;width:80px">${ing.current_price?'$'+(ing.quantity*ing.current_price).toFixed(2):'--'}</td>
        <td style="width:40px;text-align:center"><button onclick="removePrepIngredient(${prepId},${ing.id})" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px;padding:4px">&#128465;</button></td>
      </tr>`).join('');
    document.getElementById('pp-ingredients-list').innerHTML = `
      <table class="data-table" style="margin:0">
        <thead><tr><th style="width:30px;text-align:center">#</th><th>Item</th><th style="text-align:center;width:80px">Qty</th><th style="text-align:center;width:80px">Unit</th><th style="text-align:right;width:80px">Cost</th><th style="width:40px"></th></tr></thead>
        <tbody>${rows}
          <tr style="border-top:2px solid var(--border)">
            <td style="color:#22c55e;text-align:center">+</td>
            <td><select id="pp-ing-product" class="form-select" style="font-size:13px;padding:6px 8px;background:var(--bg);border-color:var(--border)" onchange="onPrepProductSelect(this)"><option value="">+ Add ingredient...</option>${productOptions}</select></td>
            <td><input type="number" step="0.01" id="pp-ing-qty" class="form-input" style="font-size:13px;padding:6px 8px;text-align:center;width:70px;background:var(--bg);border-color:var(--border)" placeholder="0" disabled></td>
            <td><select id="pp-ing-unit" class="form-select" style="font-size:13px;padding:6px 8px;background:var(--bg);border-color:var(--border);width:70px" disabled><option value="">--</option><option value="oz">oz</option><option value="lb">lb</option><option value="each">each</option><option value="cup">cup</option><option value="tbsp">tbsp</option><option value="tsp">tsp</option><option value="gal">gal</option><option value="liter">liter</option><option value="ml">ml</option><option value="g">g</option></select></td>
            <td style="text-align:right"><button onclick="savePrepIngredient()" id="pp-ing-save" class="btn btn-primary" style="padding:4px 12px;font-size:12px;background:#22c55e;border-color:#22c55e;display:none">Add</button></td>
            <td></td>
          </tr>
        </tbody></table>`;
    let total = 0;
    ingredients.forEach(ing => { if (ing.current_price && ing.quantity) total += ing.quantity * ing.current_price; });
    document.getElementById('pp-ingredient-total').textContent = '$' + total.toFixed(2);
    const yieldQty = parseFloat(document.getElementById('pp-yield-qty').value) || 1;
    document.getElementById('pp-cost-per-unit').textContent = total > 0 ? '$' + (total / yieldQty).toFixed(2) : '--';
  } catch(e) { console.error(e); }
}

function onPrepProductSelect(sel) {
  const h = sel.value !== '';
  document.getElementById('pp-ing-qty').disabled = !h;
  document.getElementById('pp-ing-unit').disabled = !h;
  document.getElementById('pp-ing-save').style.display = h ? 'inline-block' : 'none';
  if (h) document.getElementById('pp-ing-qty').focus();
}

async function savePrepIngredient() {
  const pid = document.getElementById('pp-ing-product').value;
  const qty = document.getElementById('pp-ing-qty').value;
  const unit = document.getElementById('pp-ing-unit').value;
  if (!pid||!qty) { alert('Select a product and enter quantity'); return; }
  try {
    const r = await fetch('/api/inventory/recipes/'+currentPrepId+'/ingredients',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({product_id:parseInt(pid),quantity:parseFloat(qty),unit:unit})});
    if (!r.ok) { const e = await r.json(); alert('Error: '+(e.error||'Failed')); return; }
    loadPrepIngredients(currentPrepId);
  } catch(e) { console.error(e); }
}

async function removePrepIngredient(prepId, ingredientId) {
  if (!confirm('Remove this ingredient?')) return;
  try {
    await fetch('/api/inventory/recipes/'+prepId+'/ingredients/'+ingredientId,{method:'DELETE'});
    loadPrepIngredients(prepId);
  } catch(e) { console.error(e); }
}

function addPrepMethodStep(value) {
  const container = document.getElementById('pp-method-steps');
  const idx = container.children.length + 1;
  const div = document.createElement('div');
  div.style.cssText = 'display:flex;gap:8px;align-items:flex-start;margin-bottom:8px';
  div.innerHTML = '<span style="color:var(--text3);font-size:12px;min-width:20px;padding-top:10px">' + idx + '.</span>' +
    '<textarea class="form-input pp-method-step" rows="2" style="flex:1;padding:8px;background:var(--bg);border-color:var(--border);resize:vertical" placeholder="Describe this step...">' + (value || '') + '</textarea>' +
    '<button onclick="this.parentElement.remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;padding:8px;font-size:14px">&#128465;</button>';
  container.appendChild(div);
}

function editPrepNamePage() {
  if (!currentPrepId) return;
  const current = document.getElementById('prep-page-title').textContent;
  const newName = prompt('Edit name:', current);
  if (!newName || newName.trim() === '' || newName === current) return;
  fetch('/api/inventory/recipes/' + currentPrepId, {
    method: 'PATCH', headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ name: newName.trim() })
  }).then(() => {
    document.getElementById('prep-page-title').textContent = newName.trim();
    document.getElementById('prep-edit-breadcrumb').textContent = newName.trim();
  });
}

async function saveFullPrepItem() {
  if (!currentPrepId) return;
  const steps = [];
  document.querySelectorAll('.pp-method-step').forEach(el => { if (el.value.trim()) steps.push(el.value.trim()); });
  const data = {
    category: document.getElementById('pp-category').value,
    prep_time_minutes: parseInt(document.getElementById('pp-prep-time').value) || null,
    description: document.getElementById('pp-description').value,
    yield_qty: parseFloat(document.getElementById('pp-yield-qty').value) || 1,
    yield_unit: document.getElementById('pp-yield-unit').value,
    shelf_life_qty: parseFloat(document.getElementById('pp-shelf-qty').value) || null,
    shelf_life_unit: document.getElementById('pp-shelf-unit').value,
    equipment: document.getElementById('pp-equipment').value,
    notes: document.getElementById('pp-notes').value,
    method_steps: JSON.stringify(steps)
  };
  try {
    const r = await fetch('/api/inventory/recipes/' + currentPrepId, {
      method: 'PATCH', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data)
    });
    if (r.ok) { alert('Saved!'); showView('prepared-items'); loadPreparedItems(); }
    else alert('Error saving');
  } catch(e) { console.error(e); alert('Error saving'); }
}

async function deletePrepItem() {
  if (!currentPrepId) return;
  if (!confirm('Delete this prepared item?')) return;
  try {
    await fetch('/api/inventory/recipes/' + currentPrepId, { method: 'DELETE' });
    showView('prepared-items');
    loadPreparedItems();
  } catch(e) { console.error(e); alert('Error deleting'); }
}

// Modals
async function openProductModal() {
  editingProductId = null;
  document.getElementById('form-product').reset();
  document.querySelector('#modal-product .modal-title').textContent = 'Add Product';
  await loadStorageLocationCheckboxes(null);
  document.getElementById('modal-product').classList.add('active');
}
function openVendorModal() { document.getElementById('modal-vendor').classList.add('active'); }
function openRecipeModal() {
  document.getElementById('form-recipe').reset();
  document.getElementById('modal-recipe').classList.add('active');
}
function closeModal(id) {
  document.getElementById(id).classList.remove('active');
  if (id === 'modal-product') {
    editingProductId = null;
    document.getElementById('form-product').reset();
  }
  if (id === 'modal-inventory') {
    document.getElementById('form-inventory').reset();
  }
  if (id === 'modal-recipe') {
    document.getElementById('form-recipe').reset();
  }
  if (id === 'modal-recipe-detail') {
    currentRecipeId = null;
  }
}

// Search functionality
function setupSearch() {
  const searchInput = document.getElementById('globalSearch');
  if (!searchInput) return;

  searchInput.addEventListener('input', function(e) {
    const searchTerm = e.target.value.toLowerCase();

    // Find the active view
    const activeView = document.querySelector('.view.active');
    if (!activeView) return;

    // Find the table in the active view
    const table = activeView.querySelector('.data-table tbody');
    if (!table) return;

    // Filter rows
    const rows = table.querySelectorAll('tr');
    rows.forEach(row => {
      const text = row.textContent.toLowerCase();
      if (text.includes(searchTerm)) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  });

  // Clear search when switching views
  const navLinks = document.querySelectorAll('.nav-link');
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      searchInput.value = '';
    });
  });
}

// ==================== Storage Locations ====================

let allStorageLocations = [];

async function loadStorageLocations() {
  try {
    const response = await fetch('/api/storage/locations');
    allStorageLocations = await response.json();

    const tbody = document.getElementById('storage-locations-table');
    if (allStorageLocations.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" style="text-align:center;color:var(--text3);">No storage locations yet. Click "Add Location" to create one.</td></tr>';
      return;
    }

    tbody.innerHTML = allStorageLocations.map(loc => `
      <tr>
        <td><strong>${loc.name}</strong></td>
        <td>${new Date(loc.created_at).toLocaleDateString()}</td>
        <td>
          <button class="btn btn-secondary" onclick="deleteStorageLocation(${loc.id}, '${loc.name}')" style="padding:6px 12px;font-size:12px;">Delete</button>
        </td>
      </tr>
    `).join('');
  } catch(e) {
    console.error('Error loading storage locations:', e);
  }
}

function openAddLocationModal() {
  document.getElementById('form-add-location').reset();
  document.getElementById('modal-add-location').classList.add('active');
}

async function saveStorageLocation(e) {
  e.preventDefault();
  const formData = new FormData(e.target);
  const data = { name: formData.get('name') };

  try {
    const response = await fetch('/api/storage/locations', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });

    if (!response.ok) {
      const error = await response.json();
      alert(error.error || 'Failed to add location');
      return;
    }

    closeModal('modal-add-location');
    loadStorageLocations();
  } catch(e) {
    alert('Error adding storage location: ' + e.message);
  }
}

async function deleteStorageLocation(id, name) {
  if (!confirm('Delete storage location "' + name + '"? This will remove it from all products.')) {
    return;
  }
  try {
    const response = await fetch('/api/storage/locations/' + id, {
      method: 'DELETE'
    });

    if (!response.ok) {
      throw new Error('Failed to delete location');
    }

    loadStorageLocations();
  } catch(e) {
    alert('Error deleting storage location: ' + e.message);
  }
}

async function loadStorageLocationCheckboxes(productId) {
  try {
    var curLoc = window.currentLocation || localStorage.getItem('globalLocation') || 'dennis';
    var response = await fetch('/api/storage/locations');
    var rawLocs = await response.json();
    var allLocations = rawLocs.filter(function(l) { return l.location === curLoc; });
    var productLocationIds = [];
    if (productId) {
      var prodLocResponse = await fetch('/api/storage/product/' + productId + '/locations');
      var productLocations = await prodLocResponse.json();
      productLocationIds = productLocations.map(function(l) { return l.id; });
    }
    var container = document.getElementById('storage-location-checkboxes');
    if (allLocations.length === 0) {
      container.innerHTML = '<div style="color:var(--text3);font-size:13px;">No storage locations for this restaurant.</div>';
      return;
    }
    container.innerHTML = allLocations.map(function(l) {
      var checked = productLocationIds.indexOf(l.id) >= 0 ? 'checked' : '';
      return '<label style="display:flex;align-items:center;gap:8px;padding:6px 0;cursor:pointer;">' +
        '<input type="checkbox" name="location_ids" value="' + l.id + '" ' + checked + ' style="width:auto;margin:0;">' +
        '<span>' + l.name + '</span></label>';
    }).join('');
  } catch(e) {
    console.error('Error loading storage checkboxes:', e);
  }
}

// Init - Restore last viewed tab
function initPage() {
  const savedView = localStorage.getItem('currentView') || 'dashboard';
  currentView = savedView;

  // Set active view
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + savedView).classList.add('active');

  // Set active nav item (desktop sidebar)
  document.querySelectorAll('.nav-item').forEach((n, i) => {
    n.classList.remove('active');
    const views = ['dashboard', 'products', 'vendors', 'inventory', 'storage', 'recipes'];
    if (views[i] === savedView) {
      n.classList.add('active');
    }
  });

  // Set active mobile nav item
  document.querySelectorAll('.mobile-nav-item').forEach((n, i) => {
    n.classList.remove('active');
    const views = ['dashboard', 'products', 'vendors', 'inventory', 'storage', 'recipes'];
    if (views[i] === savedView) {
      n.classList.add('active');
    }
  });

  // Set page title
  const titles = {
    dashboard: 'Dashboard',
    products: 'Products',
    vendors: 'Vendors',
    inventory: 'Inventory',
    storage: 'Storage Locations',
    countsheet: 'Count Sheet',
    inv: 'Inventory',
    recipes: 'Recipes',
    'recipe-edit': 'Edit Recipe',
    'prepared-items': 'Prepared Items',
    'prepared-edit': 'Edit Prepared Item',
    prodsetup: 'Product Setup'
  };
  document.getElementById('pageTitle').textContent = titles[savedView] || savedView;

  // Load data for the view
  switch(savedView) {
    case 'dashboard': if (typeof loadDashboard === 'function') loadDashboard(); break;
    case 'products': if (typeof loadProducts === 'function') loadProducts(); break;
    case 'vendors': if (typeof loadVendors === 'function') loadVendors(); break;
    case 'inv': if (typeof invInit === 'function') invInit(); break;
    case 'recipes': if (typeof loadRecipes === 'function') loadRecipes(); break;
    case 'prodsetup': if (typeof loadProductSetup === 'function') loadProductSetup(); break;
    case 'settings': if (typeof loadSettings === 'function') loadSettings(); break;
    case 'orderguide': if (typeof loadOrderGuide === 'function') loadOrderGuide(); break;
  }
}

// Initialize immediately (script is at end of body)
console.log('Script running, initializing navigation...');

// Initialize navigation click handlers
document.querySelectorAll('.nav-item').forEach((item, index) => {
  console.log('Found nav-item', index, item.textContent.trim());
  item.addEventListener('click', function(e) {
    console.log('Nav item clicked!', this.textContent.trim());
    e.preventDefault();
    e.stopPropagation();
    const onclickAttr = this.getAttribute('onclick');
    console.log('onclick attr:', onclickAttr);
    if (onclickAttr) {
      const match = onclickAttr.match(/showView\('([^']+)'\)/);
      console.log('Matched view:', match);
      if (match) {
        console.log('Calling showView with:', match[1]);
        showView(match[1]);
      }
    }
  });
});

console.log('Calling initPage and setupSearch...');
initPage();
setupSearch();

// ============================================
// STORAGE LAYOUT
// ============================================
const SL = { restaurant: 'dennis', locations: [], selectedLoc: null, unassignedCount: 0 };

function slInit() { SL.restaurant = window.currentLocation || localStorage.getItem('globalLocation') || 'dennis'; slLoadLocations(); }

function slPickRest(el) {
  document.querySelectorAll('.sl-rest-btn').forEach(b => { b.style.borderColor='var(--border)'; b.style.background='var(--card-bg)'; b.style.color='var(--text2)'; });
  el.style.borderColor='var(--red)'; el.style.background='rgba(255,69,58,0.1)'; el.style.color='var(--red)';
  // Using global location now
  SL.restaurant = window.currentLocation;
  SL.selectedLoc = null;
  slLoadLocations();
}

async function slLoadLocations() {
  try {
    const [locsRes, unRes] = await Promise.all([
      fetch('/api/storage/locations'),
      fetch('/api/storage/unassigned?location=' + (SL.restaurant || window.currentLocation || localStorage.getItem('globalLocation') || 'dennis'))
    ]);
    const allLocs = await locsRes.json();
    const unassigned = await unRes.json();
    SL.locations = allLocs.filter(l => l.location === SL.restaurant);
    SL.unassignedCount = unassigned.length;

    const counts = await Promise.all(SL.locations.map(l => fetch('/api/storage/locations/' + l.id + '/products').then(r => r.json())));
    const list = document.getElementById('sl-loc-list');

    let h = '<div class="sl-loc-item unassigned' + (SL.selectedLoc === 'unassigned' ? ' active' : '') + '" onclick="slSelectUnassigned()">' +
      '<div style="font-size:13px;font-weight:600">⚠️ Unassigned' + (SL.unassignedCount > 0 ? '<span class="sl-badge">' + SL.unassignedCount + '</span>' : '') + '</div>' +
      '<div class="sl-count' + (SL.unassignedCount > 0 ? ' warn' : '') + '">' + SL.unassignedCount + '</div></div>';

    SL.locations.forEach((loc, i) => {
      h += '<div class="sl-loc-item' + (SL.selectedLoc === loc.id ? ' active' : '') + '" data-locid="' + loc.id + '" data-locname="' + loc.name + '" style="position:relative">' +
        '<div style="font-size:13px;font-weight:600;flex:1">' + loc.name + '</div>' +
        '<div class="sl-count">' + counts[i].length + '</div>' +
        '<button onclick="event.stopPropagation();slDeleteArea(' + loc.id + ',&quot;' + loc.name + '&quot;)" style="background:none;border:none;color:var(--text3);font-size:14px;cursor:pointer;padding:0 4px;margin-left:4px;opacity:0.4" title="Delete area" onmouseover="this.style.opacity=1;this.style.color=\'var(--red)\'" onmouseout="this.style.opacity=0.4;this.style.color=\'var(--text3)\'">✕</button></div>';
    });
    list.innerHTML = h;
    list.querySelectorAll('.sl-loc-item:not(.unassigned)').forEach(el => {
      el.onclick = () => slSelectLoc(parseInt(el.dataset.locid), el.dataset.locname);
    });

    if (!SL.selectedLoc && SL.unassignedCount > 0) slSelectUnassigned();
    else if (SL.selectedLoc === 'unassigned') slSelectUnassigned();
    else if (SL.selectedLoc) { const loc = SL.locations.find(l => l.id === SL.selectedLoc); if (loc) slSelectLoc(loc.id, loc.name); }
  } catch(e) { console.error('slLoadLocations error:', e); }
}

async function slSelectLoc(locId, locName) {
  SL.selectedLoc = locId;
  document.getElementById('sl-main-title').textContent = locName;
  document.getElementById('sl-main-sub').textContent = 'Drag to reorder • Click ✕ to remove';
  document.querySelectorAll('.sl-loc-item').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.sl-loc-item').forEach(el => { if (el.onclick && el.onclick.toString().includes(locId)) el.classList.add('active'); });
  const res = await fetch('/api/storage/locations/' + locId + '/products');
  const products = await res.json();
  const search = (document.getElementById('sl-search').value || '').toLowerCase();
  let filtered = search ? products.filter(p => p.name.toLowerCase().includes(search)) : products;
  const main = document.getElementById('sl-main-content');
  if (!filtered.length) { main.innerHTML = '<div style="padding:40px;text-align:center;color:var(--text3)"><div style="font-size:36px;opacity:0.4;margin-bottom:8px">📦</div>No products here yet. Select Unassigned to add.</div>'; return; }
  main.innerHTML = filtered.map((p, i) => {
    const tc = 'tag-' + (p.category||'other').toLowerCase();
    return '<div class="sl-product" draggable="true" data-pid="' + p.id + '">' +
      '<div class="sl-order">' + (i+1) + '</div><div class="sl-handle">⠿</div>' +
      '<div class="sl-name">' + p.name + '</div>' +
      '<span class="pc-tag ' + tc + '" style="font-size:9px;padding:2px 6px;border-radius:4px">' + slCatLabel(p.category) + '</span>' +
      '<button class="sl-remove" onclick="slRemove(' + locId + ',' + p.id + ')">✕</button></div>';
  }).join('');
  slSetupDrag(locId);
}

async function slSelectUnassigned() {
  SL.selectedLoc = 'unassigned';
  document.getElementById('sl-main-title').textContent = '⚠️ Unassigned Products';
  document.getElementById('sl-main-sub').textContent = 'Select products then click a storage area button to assign';
  document.querySelectorAll('.sl-loc-item').forEach(el => el.classList.remove('active'));
  document.querySelector('.sl-loc-item.unassigned')?.classList.add('active');
  const res = await fetch('/api/storage/unassigned?location=' + (SL.restaurant || window.currentLocation || localStorage.getItem('globalLocation') || 'dennis'));
  const products = await res.json();
  const main = document.getElementById('sl-main-content');
  if (!products.length) { main.innerHTML = '<div style="padding:40px;text-align:center;color:var(--text3)"><div style="font-size:36px;opacity:0.4;margin-bottom:8px">✅</div>All products assigned!</div>'; return; }
  const locBtns = SL.locations.map(l => '<button class="sl-assign-btn" onclick="slBatchAssign(' + l.id + ',this)">' + l.name + '</button>').join(' ');
  let h = '<div style="padding:12px;background:var(--card-bg);border:1px solid rgba(255,69,58,0.2);border-radius:8px;margin-bottom:12px">' +
    '<div style="font-size:12px;font-weight:700;color:var(--red);margin-bottom:8px">Select products, then click a storage area:</div>' +
    '<div style="display:flex;flex-wrap:wrap;gap:4px">' + locBtns + '</div>' +
    '<label style="display:block;margin-top:8px;font-size:12px;color:var(--text2);cursor:pointer"><input type="checkbox" id="sl-select-all" onchange="document.querySelectorAll(&quot;.sl-check&quot;).forEach(c=>c.checked=this.checked)" style="margin-right:6px">Select All</label></div>';
  const cats = {};
  products.forEach(p => { const c = p.category||'OTHER'; if (!cats[c]) cats[c]=[]; cats[c].push(p); });
  for (const [cat, prods] of Object.entries(cats).sort()) {
    h += '<div style="font-size:11px;font-weight:700;color:var(--text3);padding:10px 0 4px;text-transform:uppercase">' + slCatLabel(cat) + ' (' + prods.length + ')</div>';
    h += prods.map(p => '<div class="sl-unassigned"><input type="checkbox" class="sl-check" value="' + p.id + '">' +
      '<div style="flex:1;font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + p.name + '</div>' +
      '<span class="pc-tag tag-' + (cat||'other').toLowerCase() + '" style="font-size:9px;padding:2px 6px;border-radius:4px">' + slCatLabel(cat) + '</span></div>').join('');
  }
  main.innerHTML = h;
}

async function slBatchAssign(locId, btn) {
  const ids = [...document.querySelectorAll('.sl-check:checked')].map(c => parseInt(c.value));
  if (!ids.length) { alert('Select products first'); return; }
  await fetch('/api/storage/locations/' + locId + '/products/batch', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({product_ids:ids}) });
  slLoadLocations();
}

async function slRemove(locId, pid) {
  await fetch('/api/storage/locations/' + locId + '/products/' + pid, { method:'DELETE' });
  slSelectLoc(locId, document.getElementById('sl-main-title').textContent);
  slLoadLocations();
}

function slSetupDrag(locId) {
  let dragEl = null;
  document.querySelectorAll('.sl-product').forEach(card => {
    card.addEventListener('dragstart', () => { dragEl = card; card.classList.add('dragging'); });
    card.addEventListener('dragend', () => {
      card.classList.remove('dragging');
      document.querySelectorAll('.sl-product').forEach(c => c.classList.remove('drag-over'));
      const order = [...document.querySelectorAll('.sl-product')].map(c => parseInt(c.dataset.pid));
      fetch('/api/storage/locations/' + locId + '/reorder', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({product_ids:order}) });
      document.querySelectorAll('.sl-product .sl-order').forEach((el, i) => el.textContent = i + 1);
    });
    card.addEventListener('dragover', e => {
      e.preventDefault();
      if (card !== dragEl) {
        card.classList.add('drag-over');
        const rect = card.getBoundingClientRect();
        if (e.clientY < rect.top + rect.height/2) card.parentNode.insertBefore(dragEl, card);
        else card.parentNode.insertBefore(dragEl, card.nextSibling);
      }
    });
    card.addEventListener('dragleave', () => card.classList.remove('drag-over'));
  });
}

function slRenderMain() { if (SL.selectedLoc === 'unassigned') slSelectUnassigned(); else if (SL.selectedLoc) slSelectLoc(SL.selectedLoc, document.getElementById('sl-main-title').textContent); }
function slCatLabel(c) { return {BEER:'Beer',LIQUOR:'Liquor',WINE:'Wine',FOOD:'Food',NA_BEVERAGES:'NA Bev',OTHER:'Other',SUPPLIES:'Supplies'}[c]||c; }

// ============================================
// COUNT SHEET
// ============================================
const CS = { location: null, sections: [], counts: {}, countId: null, total: 0 };

function csInit() { csLoadHistory(); }

async function csLoadSheet() {
  CS.location = window.currentLocation || localStorage.getItem('globalLocation') || 'dennis';
  if (!CS.location) { CS.location = 'dennis'; }

  const res = await fetch('/api/storage/count-sheet?location=' + CS.location);
  CS.sections = await res.json();
  CS.counts = {};
  CS.total = CS.sections.reduce((s, sec) => s + sec.products.length, 0);

  if (!CS.sections.length) {
    document.getElementById('cs-content').innerHTML = '<div style="padding:40px;text-align:center;color:var(--text3)"><div style="font-size:36px;opacity:0.4;margin-bottom:8px">📦</div>No products assigned to storage areas yet.<br>Go to Storage Layout to set up.</div>';
    document.getElementById('cs-save-btn').disabled = true;
    return;
  }

  // Create count session
  try {
    const r = await fetch('/api/inventory/counts', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({location:CS.location, notes:'Full count'}) });
    CS.countId = (await r.json()).id;
  } catch(e) {}

  document.getElementById('cs-save-btn').disabled = false;
  csRender();
  csUpdateStats();
}

function csRender() {
  const el = document.getElementById('cs-content');
  const icons = n => { n = n.toLowerCase(); if (n.includes('walk-in')||n.includes('cooler')) return '❄️'; if (n.includes('freezer')) return '🧊'; if (n.includes('bar')) return '🍸'; if (n.includes('dry')) return '📦'; return '📍'; };

  el.innerHTML = CS.sections.map((sec, si) => {
    const counted = sec.products.filter(p => CS.counts[p.id] !== undefined).length;
    return '<div class="cs-section">' +
      '<div class="cs-section-hdr">' + icons(sec.location_name) + ' ' + sec.location_name +
      '<span class="cs-section-count" id="cs-sec-' + si + '">' + counted + '/' + sec.products.length + '</span></div>' +
      sec.products.map(p => {
        const val = CS.counts[p.id] !== undefined ? CS.counts[p.id] : '';
        const prev = p.current_qty;
        return '<div class="cs-row">' +
          '<div class="cs-name">' + p.name + '</div>' +
          (prev !== null && prev !== undefined ? '<div class="cs-prev">Last: ' + prev + '</div>' : '') +
          '<div style="text-align:center"><input class="cs-input' + (val !== '' ? ' has-val' : '') + '" type="number" inputmode="decimal" step="0.5" placeholder="—" value="' + val + '" ' +
            'onfocus="this.select()" oninput="csSetQty(' + p.id + ',' + si + ',this)">' +
          '<div class="cs-unit">' + (p.inventory_unit || p.unit || 'ea') + '</div></div></div>';
      }).join('') + '</div>';
  }).join('');
}

function csSetQty(pid, si, el) {
  if (el.value.trim() === '') { delete CS.counts[pid]; el.classList.remove('has-val'); }
  else { CS.counts[pid] = parseFloat(el.value); el.classList.add('has-val'); }
  csUpdateStats();
  const sec = CS.sections[si];
  const cel = document.getElementById('cs-sec-' + si);
  if (sec && cel) cel.textContent = sec.products.filter(p => CS.counts[p.id] !== undefined).length + '/' + sec.products.length;
}

function csUpdateStats() {
  const counted = Object.keys(CS.counts).length;
  const pct = CS.total > 0 ? Math.round(counted / CS.total * 100) : 0;
  let val = 0;
  for (const [pid, qty] of Object.entries(CS.counts)) {
    for (const sec of CS.sections) { const p = sec.products.find(x => x.id == pid); if (p && p.current_price) { val += qty * p.current_price; break; } }
  }
  document.getElementById('cs-stats').innerHTML =
    '<div class="cs-stat"><div class="cs-stat-label">Progress</div><div class="cs-stat-val">' + pct + '%</div></div>' +
    '<div class="cs-stat"><div class="cs-stat-label">Counted</div><div class="cs-stat-val">' + counted + '/' + CS.total + '</div></div>' +
    '<div class="cs-stat"><div class="cs-stat-label">Est. Value</div><div class="cs-stat-val">$' + val.toLocaleString(undefined,{maximumFractionDigits:0}) + '</div></div>';
}

async function csSaveCount() {
  const counted = Object.keys(CS.counts).length;
  if (!counted) { alert('No items counted'); return; }
  const btn = document.getElementById('cs-save-btn');
  btn.disabled = true; btn.textContent = 'Saving...';
  try {
    const items = Object.entries(CS.counts).map(([pid, qty]) => {
      let unit = 'ea';
      for (const sec of CS.sections) { const p = sec.products.find(x => x.id == pid); if (p) { unit = p.inventory_unit || p.unit || 'ea'; break; } }
      return { product_id: parseInt(pid), quantity: qty, unit };
    });
    const res = await fetch('/api/inventory/counts/batch', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({count_id:CS.countId, location:CS.location, items}) });
    if (!res.ok) throw new Error();
    alert('✓ ' + counted + ' items saved!');
    CS.counts = {};
    
    document.getElementById('cs-content').innerHTML = '<div style="padding:40px;text-align:center;color:var(--text3)"><div style="font-size:36px;opacity:0.4;margin-bottom:8px">✅</div>Count saved!</div>';
    document.getElementById('cs-stats').innerHTML = '';
    btn.textContent = 'Save Count';
    csLoadHistory();
  } catch(e) { alert('Error saving'); btn.disabled = false; btn.textContent = 'Save Count'; }
}

async function csLoadHistory() {
  try {
    const data = await fetch('/api/inventory/counts/history').then(r => r.json());
    const el = document.getElementById('cs-history');
    if (!data.length) { el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text3)">No counts yet</div>'; return; }
    el.innerHTML = '<table class="data-table"><thead><tr><th>Date</th><th>Location</th><th>Items</th><th>Status</th></tr></thead><tbody>' +
      data.slice(0,10).map(c => {
        const d = new Date(c.created_at);
        return '<tr><td>' + d.toLocaleDateString('en-US',{month:'short',day:'numeric'}) + ' ' + d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'}) + '</td>' +
          '<td>' + (c.location==='dennis'?'Dennis':'Chatham') + '</td>' +
          '<td>' + (c.item_count||0) + '</td>' +
          '<td><span style="color:var(--green);font-weight:600">Complete</span></td></tr>';
      }).join('') + '</tbody></table>';
  } catch(e) {}
}


// ============================================
// INVENTORY TAB SWITCHER
// ============================================
function invTab(btn) {
  document.querySelectorAll('.inv-tab').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.inv-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  var panel = document.getElementById('panel-' + btn.dataset.tab);
  if (panel) panel.classList.add('active');
  if (btn.dataset.tab === 'storagesetup') slInit();
  if (btn.dataset.tab === 'countsheet') csRefresh();
  if (btn.dataset.tab === 'counthistory') csLoadHistory();
}

function invInit() {
  var lastTab = localStorage.getItem('lastInvTab');
  if (lastTab) {
    localStorage.removeItem('lastInvTab');
    var tabBtn = document.querySelector('.inv-tab[data-tab="' + lastTab + '"]');
    if (tabBtn) { setTimeout(function() { tabBtn.click(); }, 50); return; }
  }
  // Default to count sheet tab
  csRefresh();
}

// ============================================
// PRODUCT SETUP TRACKING
// ============================================
var _origLoadProducts = loadProducts;
var _setupSortActive = false;

loadProducts = async function(forceRefresh) {
  await _origLoadProducts(forceRefresh);
  try {
    var data = await fetch('/api/inventory/products/setup-status?location=' + (window.currentLocation || 'dennis')).then(function(r) { return r.json(); });
    var rows = document.querySelectorAll('#products-table tr');
    var setupMap = {};
    data.forEach(function(s) { setupMap[s.name] = s; });
    
    rows.forEach(function(row) {
      var nameCell = row.querySelector('td:first-child strong');
      if (!nameCell) return;
      var name = nameCell.textContent.trim();
      var s = setupMap[name];
      // stars handled in loadProducts directly
    });
    

  } catch(e) { console.error('Setup status error:', e); }
};

var _origEditProduct = typeof editProduct === 'function' ? editProduct : null;
if (_origEditProduct) {
  editProduct = async function(id) {
    await _origEditProduct(id);
    try {
      var data = await fetch('/api/inventory/products/setup-status?location=' + (window.currentLocation || 'dennis')).then(function(r) { return r.json(); });
      var setup = data.find(function(s) { return s.id === id; });
      var container = document.getElementById('product-setup-status');
      if (!container) {
        var mh = document.querySelector('#modal-product .modal-header');
        if (mh) { container = document.createElement('div'); container.id = 'product-setup-status'; mh.after(container); }
      }
      if (!container) return;
      if (setup && !setup.is_ready) {
        var needs = setup.needs_setup || [];
        var h = '';
        h += '<span style="font-size:12px;' + (needs.indexOf('purchase_unit')>=0?'color:#FF9F0A':'color:#30D158') + '">' + (needs.indexOf('purchase_unit')>=0?'\u25cb':'\u25cf') + ' Purchase Unit</span> ';
        h += '<span style="font-size:12px;' + (needs.indexOf('inventory_unit')>=0?'color:#FF9F0A':'color:#30D158') + '">' + (needs.indexOf('inventory_unit')>=0?'\u25cb':'\u25cf') + ' Inventory Unit</span> ';
        h += '<span style="font-size:12px;' + (needs.indexOf('storage')>=0?'color:#FF9F0A':'color:#30D158') + '">' + (needs.indexOf('storage')>=0?'\u25cb':'\u25cf') + ' Storage Area</span>';
        container.innerHTML = '<div style="display:flex;gap:8px;align-items:center;padding:8px 12px;margin-bottom:12px;background:rgba(255,159,10,0.08);border:1px solid rgba(255,159,10,0.2);border-radius:8px;flex-wrap:wrap"><span style="font-size:12px;font-weight:700;color:#FF9F0A">\u2b50 Needs Setup:</span> ' + h + '</div>';
        container.style.display = 'block';
      } else {
        container.innerHTML = setup ? '<div style="padding:6px 12px;margin-bottom:12px;background:rgba(48,209,88,0.08);border:1px solid rgba(48,209,88,0.2);border-radius:8px;font-size:12px;color:#30D158;font-weight:600">\u2705 Setup Complete</div>' : '';
        container.style.display = setup ? 'block' : 'none';
      }
    } catch(e) { console.error('Edit setup error:', e); }
  };
}

function toggleSetup(productId, complete) {
  fetch('/api/inventory/products/' + productId + '/setup', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ complete: complete })
  }).then(function() { closeModal('modal-product'); loadProducts(); });
}

function toggleSetupSort() {
  _setupSortActive = !_setupSortActive;
  document.getElementById('sort-setup-btn').classList.toggle('active', _setupSortActive);
  var tbody = document.getElementById('products-table');
  var rows = Array.from(tbody.querySelectorAll('tr'));
  rows.sort(function(a, b) {
    var aStar = a.querySelector('.star-badge') ? 0 : 1;
    var bStar = b.querySelector('.star-badge') ? 0 : 1;
    if (_setupSortActive) return aStar - bStar;
    return 0;
  });
  rows.forEach(function(r) { tbody.appendChild(r); });
}


// ============================================
// TABLE SORTING
// ============================================
var _sortCol = null;
var _sortDir = 1;

function sortProducts(col) {
  if (_sortCol === col) { _sortDir *= -1; }
  else { _sortCol = col; _sortDir = 1; }
  
  // Update indicators
  document.querySelectorAll('[id^="sort-ind-"]').forEach(function(el) { el.textContent = ''; });
  var ind = document.getElementById('sort-ind-' + col);
  if (ind) ind.textContent = _sortDir > 0 ? '▲' : '▼';
  
  var tbody = document.getElementById('products-table');
  var rows = Array.from(tbody.querySelectorAll('tr'));
  
  rows.sort(function(a, b) {
    var av, bv;
    var cells_a = a.querySelectorAll('td');
    var cells_b = b.querySelectorAll('td');
    
    switch(col) {
      case 'name':
        av = (cells_a[0] && cells_a[0].textContent || '').trim().toLowerCase();
        bv = (cells_b[0] && cells_b[0].textContent || '').trim().toLowerCase();
        return _sortDir * av.localeCompare(bv);
      case 'category':
        av = (cells_a[1] && cells_a[1].textContent || '').trim().toLowerCase();
        bv = (cells_b[1] && cells_b[1].textContent || '').trim().toLowerCase();
        return _sortDir * av.localeCompare(bv);
      case 'storage':
        av = parseInt(cells_a[4] && cells_a[4].textContent) || 0;
        bv = parseInt(cells_b[4] && cells_b[4].textContent) || 0;
        return _sortDir * (av - bv);
      case 'unit':
        av = (cells_a[3] && cells_a[3].textContent || '').trim().toLowerCase();
        bv = (cells_b[3] && cells_b[3].textContent || '').trim().toLowerCase();
        return _sortDir * av.localeCompare(bv);
      case 'inventory_unit':
        av = (cells_a[4] && cells_a[4].textContent || '').trim().toLowerCase();
        bv = (cells_b[4] && cells_b[4].textContent || '').trim().toLowerCase();
        return _sortDir * av.localeCompare(bv);
      case 'vendor':
        av = (cells_a[2] && cells_a[2].textContent || '').trim().toLowerCase();
        bv = (cells_b[2] && cells_b[2].textContent || '').trim().toLowerCase();
        return _sortDir * av.localeCompare(bv);
      case 'price':
        av = parseFloat((cells_a[3] && cells_a[3].textContent || '0').replace(/[^0-9.]/g, '')) || 0;
        bv = parseFloat((cells_b[3] && cells_b[3].textContent || '0').replace(/[^0-9.]/g, '')) || 0;
        return _sortDir * (av - bv);
      case 'setup':
        av = a.querySelector('.star-badge') ? 0 : 1;
        bv = b.querySelector('.star-badge') ? 0 : 1;
        return _sortDir * (av - bv);
      default:
        return 0;
    }
  });
  
  rows.forEach(function(r) { tbody.appendChild(r); });
}


function slAddArea() {
  var name = prompt('Storage area name (e.g. Walk-in Cooler, Bar, Freezer):');
  if (!name || !name.trim()) return;
  fetch('/api/storage/locations', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ name: name.trim(), location: window.currentLocation })
  }).then(function(r) {
    if (r.ok) { slLoadLocations(); }
    else { r.json().then(function(d) { alert(d.error || 'Error creating area'); }); }
  });
}


function slDeleteArea(locId, locName) {
  if (!confirm('Delete "' + locName + '"? Products will be unassigned from this area.')) return;
  fetch('/api/storage/locations/' + locId, { method: 'DELETE' }).then(function(r) {
    if (r.ok) { SL.selectedLoc = null; slLoadLocations(); }
    else { alert('Error deleting'); }
  });
}


// ============================================
// COUNT SHEET FUNCTIONS
// ============================================
var csActiveArea = null;

async function csRefresh() {
  var loc = window.currentLocation || localStorage.getItem('globalLocation') || 'dennis';
  
  // Check for active count
  try {
    var activeRes = await fetch('/api/inventory/count/active?location=' + loc);
    var active = await activeRes.json();
    var banner = document.getElementById('cs-active-banner');
    if (banner) {
      if (active && active.id) {
        banner.style.display = 'block';
        document.getElementById('cs-active-date').textContent = 'Started ' + new Date(active.started_at).toLocaleString();
        document.getElementById('cs-active-link').href = '/count?session=' + active.id;
      } else { banner.style.display = 'none'; }
    }
  } catch(e) {}
  
  try {
    var res = await fetch('/api/inventory/count/sheet?location=' + loc);
    window._csAreas = await res.json();
    var nav = document.getElementById('cs-area-nav');
    if (!nav) return;
    
    if (window._csAreas.length === 0) {
      nav.innerHTML = '<div style="padding:20px;color:var(--text3);font-size:12px">No storage areas</div>';
      return;
    }
    
    var totalProducts = 0;
    var h = '<div style="padding:10px 12px;font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px">Storage Areas</div>';
    window._csAreas.forEach(function(area) {
      totalProducts += area.products.length;
      var isActive = area.id === csActiveArea;
      h += '<div class="cs-nav-item" data-areaid="' + area.id + '" onclick="csSelectArea(' + area.id + ')" style="padding:10px 14px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;border-left:3px solid ' + (isActive ? 'var(--red)' : 'transparent') + ';background:' + (isActive ? 'rgba(255,69,58,0.08)' : 'transparent') + ';transition:all 0.15s">';
      h += '<span style="font-size:13px;font-weight:' + (isActive ? '700' : '500') + '">' + area.name + '</span>';
      h += '<span style="font-size:11px;color:var(--text3);background:rgba(255,255,255,0.06);padding:1px 6px;border-radius:8px">' + area.products.length + '</span>';
      h += '</div>';
    });
    nav.innerHTML = h;
    
    document.getElementById('cs-subtitle').textContent = totalProducts + ' products across ' + window._csAreas.length + ' areas';
    
    // Set default active area
    if (!csActiveArea) { csActiveArea = window._csAreas[0].id; }
    var areaFound = false;
    window._csAreas.forEach(function(a) { if (a.id === csActiveArea) areaFound = true; });
    if (!areaFound) { csActiveArea = window._csAreas[0].id; }
    csSelectArea(csActiveArea);
  } catch(e) { console.error('Count sheet error:', e); }
}

function csSelectArea(areaId) {
  csActiveArea = areaId;
  document.querySelectorAll('.cs-nav-item').forEach(function(el) {
    var isActive = parseInt(el.dataset.areaid) === areaId;
    el.style.borderLeftColor = isActive ? 'var(--red)' : 'transparent';
    el.style.background = isActive ? 'rgba(255,69,58,0.08)' : 'transparent';
    var nameSpan = el.querySelector('span');
    if (nameSpan) nameSpan.style.fontWeight = isActive ? '700' : '500';
  });
  csRenderAreaContent();
}

function csRenderAreaContent() {
  var area = (window._csAreas || []).find(function(a) { return a.id === csActiveArea; });
  var content = document.getElementById('cs-area-content');
  if (!area || !content) return;
  
  // Initialize section filters if not set for this area
  if (!window._csSectionFilters) window._csSectionFilters = {};
  if (!window._csSectionFilters[area.id]) window._csSectionFilters[area.id] = 'all';
  var filter = window._csSectionFilters[area.id];
  
  var sections = {};
  var unsectioned = [];
  area.products.forEach(function(p) {
    if (p.section_id) {
      if (!sections[p.section_id]) sections[p.section_id] = [];
      sections[p.section_id].push(p);
    } else { unsectioned.push(p); }
  });
  
  var h = '';
  // Area header with section filter tabs
  h += '<div style="padding:12px 16px;border-bottom:1px solid var(--border);background:rgba(255,255,255,0.02);position:sticky;top:0;z-index:1">';
  h += '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">';
  h += '<span style="font-size:15px;font-weight:700">' + area.name + '</span>';
  h += '<span style="font-size:12px;color:var(--text3)">' + area.products.length + ' items</span>';
  h += '<button style="background:none;border:none;color:var(--blue);font-size:12px;cursor:pointer;font-weight:600" onclick="csAddSection(' + area.id + ')">+ section</button>';
  
  // Section filter tabs (only show if there are sections)
  if (area.sections.length > 0) {
    h += '<div style="display:flex;gap:4px;margin-left:12px">';
    var allActive = filter === "all";
    h += '<button class="cs-filter-tab" style="padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid ' + (allActive ? 'var(--blue)' : 'var(--border)') + ';background:' + (allActive ? 'rgba(10,132,255,0.15)' : 'transparent') + ';color:' + (allActive ? 'var(--blue)' : 'var(--text3)') + '" onclick="csToggleFilter(' + area.id + ', &quot;all&quot;)">All</button>';
    area.sections.forEach(function(sec) {
      var isOn = filter === "all" || (typeof filter === "object" && filter.indexOf(sec.id) >= 0);
      h += '<button class="cs-filter-tab" style="padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid ' + (isOn && filter !== "all" ? 'var(--blue)' : 'var(--border)') + ';background:' + (isOn && filter !== "all" ? 'rgba(10,132,255,0.15)' : 'transparent') + ';color:' + (isOn && filter !== "all" ? 'var(--blue)' : 'var(--text3)') + '" onclick="csToggleFilter(' + area.id + ', ' + sec.id + ')">' + sec.name + ' (' + (sections[sec.id] || []).length + ')</button>';
    });
    var genActive = filter === "all" || (typeof filter === "object" && filter.indexOf(0) >= 0);
    h += '<button class="cs-filter-tab" style="padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid ' + (genActive && filter !== "all" ? 'var(--blue)' : 'var(--border)') + ';background:' + (genActive && filter !== "all" ? 'rgba(10,132,255,0.15)' : 'transparent') + ';color:' + (genActive && filter !== "all" ? 'var(--blue)' : 'var(--text3)') + '" onclick="csToggleFilter(' + area.id + ', 0)">General (' + unsectioned.length + ')</button>';
    h += '</div>';
  }
  h += '</div></div>';
  
  // Determine which sections to show
  var showAll = filter === "all";
  var showSections = typeof filter === "object" ? filter : [];
  
  // Sections
  area.sections.forEach(function(sec) {
    if (!showAll && showSections.indexOf(sec.id) < 0) return;
    var secProducts = sections[sec.id] || [];
    h += '<div class="cs-branch">';
    h += '<div class="cs-branch-header" onclick="this.parentElement.classList.toggle(&quot;collapsed&quot;)">';
    h += '<span class="cs-chevron">\u25BC</span>';
    h += '<span class="cs-branch-name">' + sec.name + '</span>';
    h += '<span class="cs-branch-count">' + secProducts.length + '</span>';
    h += '<button class="cs-branch-del" onclick="event.stopPropagation();csDeleteSection(' + sec.id + ')">\u2715</button>';
    h += '</div>';
    h += '<div class="cs-branch-body cs-sortable" data-areaid="' + area.id + '" data-sectionid="' + sec.id + '">';
    secProducts.forEach(function(p, i) { h += csProductRow(p, i + 1); });
    if (secProducts.length === 0) h += '<div class="cs-empty-drop">Drag products here</div>';
    h += '</div></div>';
  });
  
  // Unsectioned
  if (showAll || showSections.indexOf(0) >= 0) {
    if (area.sections.length > 0 && unsectioned.length > 0) {
      h += '<div style="padding:6px 16px;font-size:11px;color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid rgba(255,255,255,0.04)">General</div>';
    }
    h += '<div class="cs-sortable" data-areaid="' + area.id + '" data-sectionid="null">';
    unsectioned.forEach(function(p, i) { h += csProductRow(p, i + 1); });
    if (area.products.length === 0) h += '<div style="padding:30px;text-align:center;color:var(--text3);font-size:13px">No products in this area.</div>';
    h += '</div>';
  }
  
  content.innerHTML = h;
  csSetupDrag();
}

function csToggleFilter(areaId, sectionId) {
  if (!window._csSectionFilters) window._csSectionFilters = {};
  var current = window._csSectionFilters[areaId] || 'all';
  
  if (sectionId === 'all') {
    window._csSectionFilters[areaId] = 'all';
  } else {
    if (current === 'all') {
      // Switch from all to just this section
      window._csSectionFilters[areaId] = [sectionId];
    } else {
      // Toggle this section in the array
      var arr = current.slice ? current.slice() : [];
      var idx = arr.indexOf(sectionId);
      if (idx >= 0) {
        arr.splice(idx, 1);
        if (arr.length === 0) { window._csSectionFilters[areaId] = 'all'; }
        else { window._csSectionFilters[areaId] = arr; }
      } else {
        arr.push(sectionId);
        window._csSectionFilters[areaId] = arr;
      }
    }
  }
  csRenderAreaContent();
}

function csProductRow(p, idx) {
  var catClass = 'tag-' + (p.category || 'other').toLowerCase();
  return '<div class="cs-row" draggable="true" data-pslid="' + p.psl_id + '" data-productid="' + p.id + '">' +
    '<span class="cs-row-num">' + idx + '</span>' +
    '<span class="cs-row-grip">\u2807</span>' +
    '<span class="cs-row-name">' + p.name + '</span>' +
    '<span class="tag ' + catClass + '" style="font-size:10px">' + (p.category || '') + '</span>' +
    '<span class="cs-row-unit">' + (p.inventory_unit || 'each') + '</span></div>';
}

function csSetupDrag() {
  var dragItem = null;
  var containers = document.querySelectorAll('.cs-sortable');
  containers.forEach(function(container) {
    container.addEventListener('dragover', function(e) {
      e.preventDefault();
      this.classList.add('drag-over');
      var afterElement = csDragAfterElement(container, e.clientY);
      if (dragItem) {
        if (afterElement) { container.insertBefore(dragItem, afterElement); }
        else { container.appendChild(dragItem); }
      }
    });
    container.addEventListener('dragleave', function(e) {
      if (!this.contains(e.relatedTarget)) this.classList.remove('drag-over');
    });
    container.addEventListener('drop', function() { this.classList.remove('drag-over'); });
  });
  document.querySelectorAll('.cs-row').forEach(function(row) {
    row.addEventListener('dragstart', function(e) {
      dragItem = this;
      this.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    row.addEventListener('dragend', function() {
      this.classList.remove('dragging');
      dragItem = null;
      csSaveOrder();
    });
  });
}

function csDragAfterElement(container, y) {
  var elements = Array.from(container.querySelectorAll('.cs-row:not(.dragging)'));
  var closest = null;
  var closestOffset = Number.NEGATIVE_INFINITY;
  elements.forEach(function(el) {
    var box = el.getBoundingClientRect();
    var offset = y - box.top - box.height / 2;
    if (offset < 0 && offset > closestOffset) { closestOffset = offset; closest = el; }
  });
  return closest;
}

async function csSaveOrder() {
  var containers = document.querySelectorAll('.cs-sortable');
  var updates = [];
  containers.forEach(function(container) {
    var areaId = container.dataset.areaid;
    var sectionId = container.dataset.sectionid;
    var rows = container.querySelectorAll('.cs-row');
    rows.forEach(function(row, i) {
      updates.push({
        psl_id: parseInt(row.dataset.pslid),
        sort_order: i + 1,
        section_id: sectionId === 'null' ? null : parseInt(sectionId)
      });
    });
  });
  try {
    await fetch('/api/inventory/count/reorder', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ updates: updates })
    });
    document.querySelectorAll('.cs-sortable').forEach(function(container) {
      var rows = container.querySelectorAll('.cs-row');
      rows.forEach(function(row, i) {
        var numSpan = row.querySelector('.cs-row-num');
        if (numSpan) numSpan.textContent = i + 1;
      });
    });
  } catch(e) { console.error('Save order error:', e); }
}

function csAddSection(areaId) {
  var name = prompt('Section name (e.g. Shelf 1, Top Rack, Door):');
  if (!name || !name.trim()) return;
  fetch('/api/inventory/count/sections', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ storage_location_id: areaId, name: name.trim() }) }).then(function(r) { if (r.ok) csRefresh(); });
}

function csDeleteSection(sectionId) {
  if (!confirm('Remove this section? Products will become unsectioned.')) return;
  fetch('/api/inventory/count/sections/' + sectionId, { method: 'DELETE' }).then(function(r) { if (r.ok) csRefresh(); });
}

async function csStartCount() {
  var loc = window.currentLocation || localStorage.getItem('globalLocation') || 'dennis';
  if (!confirm('Start a new inventory count for ' + (loc === 'dennis' ? 'Dennis Port' : 'Chatham') + '?')) return;
  try {
    var res = await fetch('/api/inventory/count/start', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ location: loc }) });
    var data = await res.json();
    if (res.ok) {
      window.open('/count?session=' + data.session_id, '_blank');
      csRefresh();
    } else {
      if (data.session_id) { if (confirm(data.error + '. Continue?')) window.open('/count?session=' + data.session_id, '_blank'); }
      else alert(data.error || 'Error');
    }
  } catch(e) { alert('Error: ' + e.message); }
}

</script>
<script src="/static/sidebar.js"></script>
<script>

// ── Dashboard ──────────────────────────────────────────────
async function loadDashboard() {
  var tb=document.querySelector('.top-bar');if(tb)tb.style.display='none';
  var loc = window.currentLocation || 'dennis';
  try { var resp = await fetch('/api/dashboard/overview?location=' + loc); var d = await resp.json(); }
  catch(e) { return; }

  var fmt = function(n) { return '$' + Number(n).toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}); };
  var fmt2 = function(n) { return '$' + Number(n).toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}); };
  var chg = function(cur, prev) {
    if (!prev || !cur) return '';
    var ch = ((cur - prev) / prev * 100);
    var color = ch >= 0 ? 'var(--green)' : 'var(--red)';
    var arrow = ch >= 0 ? '&#9650;' : '&#9660;';
    return '<span style="color:'+color+'">'+arrow+' '+Math.abs(ch).toFixed(0)+'%</span>';
  };

  // Week label
  var twDaily = d.this_week.daily;
  var wl = document.getElementById('dash-week-label');
  if (wl) {
    var today = new Date();
    var dow = today.getDay(); var diff = dow === 0 ? 6 : dow - 1;
    var mon = new Date(today); mon.setDate(today.getDate() - diff);
    wl.textContent = 'Week of ' + (mon.getMonth()+1) + '/' + mon.getDate() + '/' + String(mon.getFullYear()).substring(2);
  }

  var days = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  var lwD = d.last_week.daily;
  var lyD = d.last_year_week.daily;
  var body = document.getElementById('dash-daily-body');
  var totTW=0, totLW=0, totLY=0;
  var rows = '';

  for (var i=0; i<7; i++) {
    var twVal = (twDaily[i] && twDaily[i].sales) ? twDaily[i].sales : null;
    var lwVal = (lwD[i] && lwD[i].sales) ? lwD[i].sales : null;
    var lyVal = (lyD[i] && lyD[i].sales) ? lyD[i].sales : null;
    if(twVal) totTW+=twVal;
    if(lwVal) totLW+=lwVal;
    if(lyVal) totLY+=lyVal;

    rows += '<tr style="border-bottom:1px solid var(--border)">';
    rows += '<td style="padding:5px 6px;font-weight:600">'+days[i]+'</td>';
    rows += '<td style="text-align:right;padding:8px;border-left:2px solid var(--border)">'+(twVal ? fmt2(twVal) : '')+'</td>';
    rows += '<td style="text-align:right;padding:8px;border-left:2px solid var(--border)">'+(lwVal ? fmt2(lwVal) : '')+'</td>';
    rows += '<td style="text-align:right;padding:8px;font-size:12px">'+(lwVal && twVal ? chg(twVal, lwVal) : '')+'</td>';
    rows += '<td style="text-align:right;padding:8px;border-left:2px solid var(--border)">'+(lyVal ? fmt2(lyVal) : '')+'</td>';
    rows += '<td style="text-align:right;padding:8px;font-size:12px">'+(lyVal && twVal ? chg(twVal, lyVal) : '')+'</td>';
    rows += '</tr>';
  }

  rows += '<tr style="font-weight:700;border-top:2px solid var(--border);background:rgba(255,255,255,0.03)">';
  rows += '<td style="padding:8px">Total</td>';
  rows += '<td style="text-align:right;padding:8px;border-left:2px solid var(--border)">'+fmt2(totTW)+'</td>';
  rows += '<td style="text-align:right;padding:8px;border-left:2px solid var(--border)">'+fmt2(totLW)+'</td>';
  rows += '<td style="text-align:right;padding:8px;font-size:12px">'+chg(totTW, totLW)+'</td>';
  rows += '<td style="text-align:right;padding:8px;border-left:2px solid var(--border)">'+fmt2(totLY)+'</td>';
  rows += '<td style="text-align:right;padding:8px;font-size:12px">'+chg(totTW, totLY)+'</td>';
  rows += '</tr>';
  body.innerHTML = rows;

  // PTD / YTD
  document.getElementById('dash-ptd-ty').textContent = fmt(d.period_to_date.this_year);
  document.getElementById('dash-ptd-ly').textContent = fmt(d.period_to_date.last_year);
  document.getElementById('dash-ptd-change').innerHTML = chg(d.period_to_date.this_year, d.period_to_date.last_year);
  document.getElementById('dash-ytd-ty').textContent = fmt(d.year_to_date.this_year);
  document.getElementById('dash-ytd-ly').textContent = fmt(d.year_to_date.last_year);
  document.getElementById('dash-ytd-change').innerHTML = chg(d.year_to_date.this_year, d.year_to_date.last_year);

  // Monthly trend
  var mt = d.monthly_trend;
  var maxSales = Math.max.apply(null, mt.map(function(m){return m.sales;}));
  var chart = document.getElementById('dash-monthly-chart');
  var labels = document.getElementById('dash-monthly-labels');
  if(chart) {
    chart.innerHTML = mt.map(function(m) {
      var h = maxSales ? Math.round(m.sales / maxSales * 140) : 0;
      var color = m.sales > 0 ? 'var(--green)' : 'var(--border)';
      return '<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px">'
        + '<div style="font-size:10px;color:var(--text2)">' + (m.sales > 0 ? fmt(m.sales) : '') + '</div>'
        + '<div style="width:100%;height:'+Math.max(h,2)+'px;background:'+color+';border-radius:3px 3px 0 0"></div>'
        + '</div>';
    }).join('');
  }
  if(labels) {
    labels.innerHTML = mt.map(function(m) {
      return '<div style="flex:1;text-align:center;font-size:9px;color:var(--text3)">'+m.month.split(' ')[0]+'</div>';
    }).join('');
  }

  // Labor
  var tw = d.this_week.total;
  var labTW = d.labor.this_week;
  var labLW = d.labor.last_week;
  var labPct = tw.sales ? (labTW / tw.sales * 100).toFixed(1) + '%' : '--';
  document.getElementById('dash-labor-tw').textContent = fmt(labTW);
  document.getElementById('dash-labor-lw').textContent = fmt(labLW);
  document.getElementById('dash-labor-pct').textContent = labPct;

  // Mobile cards
  var isMobile = window.innerWidth <= 768;

  if (isMobile) {
    try {
      var todaySales = 0, todayOrders = 0;
      for (var mi = twDaily.length - 1; mi >= 0; mi--) {
        if (twDaily[mi] && twDaily[mi].sales) { todaySales = twDaily[mi].sales; todayOrders = twDaily[mi].orders; break; }
      }
      var mobToday = document.getElementById('dash-mob-today-sales');
      if (mobToday) mobToday.textContent = fmt(todaySales);
      var mobTodayOrd = document.getElementById('dash-mob-today-orders');
      if (mobTodayOrd) mobTodayOrd.textContent = todayOrders + ' orders';
      var mobWeek = document.getElementById('dash-mob-week-sales');
      if (mobWeek) mobWeek.textContent = fmt(tw.sales);
      var mobWeekVs = document.getElementById('dash-mob-week-vs');
      if (mobWeekVs && lw && lw.sales) mobWeekVs.innerHTML = 'vs ' + fmt(lw.sales) + ' ' + chg(tw.sales, lw.sales);
    } catch(e) { console.error('Mobile sales error:', e); }
  }


  // Thermostats
  var td = {};
  try {
    var tr2 = await fetch('/api/thermostats?_=' + Date.now());
    td = await tr2.json();
  } catch(e) { 
    console.error('Thermo fetch error:', e);
    var mt0 = document.getElementById('dash-mobile-thermo');
    if (mt0) mt0.innerHTML = '<div style="color:red;padding:8px">Fetch failed: ' + e.message + '</div>';
  }

  try {
    var trow = document.getElementById('dash-thermo-row');
    if (trow) {
      var thtml = '';
      var locs = {dennis:'Dennis Port', chatham:'Chatham'};
      for (var lk in locs) {
        if (lk !== loc) continue;
        var devs = td[lk] || [];
        if (!devs.length) continue;
        thtml += '<div style="background:linear-gradient(135deg,#1a2a2a,#1e3d3d);border-radius:10px;padding:16px 20px;border:1px solid rgba(0,200,180,0.25);flex:1;min-width:280px">';
        thtml += '<div style="font-size:14px;font-weight:700;color:#00c8b4;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px">&#127777; ' + locs[lk] + ' Thermostats</div>';
        for (var ti = 0; ti < devs.length; ti++) {
          var t = devs[ti];
          var statusColor = t.equipment_status === 'off' ? 'var(--text3)' : 'var(--orange)';
          var statusIcon = t.equipment_status === 'off' ? '&#9679;' : '&#9650;';
          var aliveColor = t.is_alive ? 'var(--green)' : 'var(--red)';
          if (ti > 0) thtml += '<div style="border-top:1px solid rgba(0,200,180,0.15);margin:12px 0"></div>';
          thtml += '<div style="display:flex;justify-content:space-between;align-items:center">';
          thtml += '<div>';
          thtml += '<div style="font-size:12px;color:var(--text3);text-transform:uppercase;margin-bottom:4px">' + t.label + ' <span style="color:' + aliveColor + ';font-size:8px">&#9679;</span></div>';
          thtml += '<div style="font-size:32px;font-weight:700">' + Math.round(t.current_temp) + '&deg;</div>';
          thtml += '</div>';
          thtml += '<div style="text-align:right">';
          thtml += '<div style="font-size:11px;color:var(--text3)">Setpoint</div>';
          thtml += '<div style="display:flex;align-items:center;gap:6px">';
          thtml += '<button onclick="thermoAdj(\'' + lk + '\',' + t.id + ',-1)" style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:var(--text1);width:28px;height:28px;border-radius:6px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center">&#8722;</button>';
          thtml += '<div style="font-size:20px;font-weight:600" id="thermo-sp-' + t.id + '">' + Math.round(t.heat_setpoint) + '&deg;</div>';
          thtml += '<button onclick="thermoAdj(\'' + lk + '\',' + t.id + ',1)" style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:var(--text1);width:28px;height:28px;border-radius:6px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center">+</button>';
          thtml += '</div>';
          thtml += '<div style="font-size:11px;color:' + statusColor + '">' + statusIcon + ' ' + t.equipment_status + '</div>';
          if (t.humidity) thtml += '<div style="font-size:11px;color:var(--text3)">&#128167; ' + t.humidity + '%</div>';
          thtml += '</div></div>';
        }
        thtml += '</div>';
      }
      trow.innerHTML = thtml;
    }
  } catch(e) { console.error('Desktop thermo error:', e); }
  try {
    // Mobile thermostats
    var mobileThermo = document.getElementById('dash-mobile-thermo');
    if (mobileThermo) {
      if (!td || Object.keys(td).length === 0) {
        mobileThermo.innerHTML = '<div style="color:var(--red);padding:8px;font-size:12px">No thermostat data - td=' + JSON.stringify(td) + '</div>';
        return;
      }
      var cards = [];
      var mlocs = {dennis:'Dennis Port', chatham:'Chatham'};
      for (var mlk in mlocs) {
        if (mlk !== loc) continue;
        var mdevs = td[mlk] || [];
        for (var mi2 = 0; mi2 < mdevs.length; mi2++) {
          var mt = mdevs[mi2];
          var mStatusColor = mt.equipment_status === 'off' ? 'var(--text3)' : 'var(--orange)';
          var statusLabel = mt.equipment_status === 'off' ? 'Idle' : mt.equipment_status.charAt(0).toUpperCase() + mt.equipment_status.slice(1) + 'ing';
          var c = '<div onclick="thermoToggle(' + mt.id + ')" style="flex:1;background:linear-gradient(135deg,#1a2a2a,#1e3d3d);border-radius:10px;padding:16px;border:1px solid rgba(0,200,180,0.25);cursor:pointer">';
          c += '<div style="font-size:11px;color:#00c8b4;text-transform:uppercase;margin-bottom:6px">' + mt.label + '</div>';
          c += '<div style="font-size:28px;font-weight:700">' + Math.round(mt.current_temp) + '&deg;F</div>';
          c += '<div style="font-size:12px;color:' + mStatusColor + ';margin-top:4px">' + statusLabel + ' &middot; Set <span id="thermo-mob-sp-' + mt.id + '">' + Math.round(mt.heat_setpoint) + '</span>&deg;</div>';
          c += '<div id="thermo-expand-' + mt.id + '" style="display:none;margin-top:14px;padding-top:14px;border-top:1px solid rgba(0,200,180,0.15)">';
          c += '<div style="display:flex;justify-content:center;align-items:center;gap:16px">';
          c += '<button onclick="event.stopPropagation();thermoAdj(\'' + mlk + '\',' + mt.id + ',-1)" style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:var(--text1);width:44px;height:44px;border-radius:10px;cursor:pointer;font-size:22px">&#8722;</button>';
          c += '<div style="font-size:32px;font-weight:700" id="thermo-mob-big-' + mt.id + '">' + Math.round(mt.heat_setpoint) + '&deg;</div>';
          c += '<button onclick="event.stopPropagation();thermoAdj(\'' + mlk + '\',' + mt.id + ',1)" style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:var(--text1);width:44px;height:44px;border-radius:10px;cursor:pointer;font-size:22px">+</button>';
          c += '</div>';
          if (mt.humidity) c += '<div style="text-align:center;margin-top:8px;font-size:12px;color:var(--text3)">&#128167; ' + mt.humidity + '%</div>';
          c += '</div></div>';
          cards.push(c);
        }
      }
      // Pad to 2 cards per row
      if (cards.length === 1) {
        cards.push('<div style="flex:1;background:linear-gradient(135deg,#1a2a2a,#1e3d3d);border-radius:10px;padding:16px;border:1px solid rgba(0,200,180,0.15);opacity:0.5"><div style="font-size:11px;color:var(--text3);text-transform:uppercase;margin-bottom:6px">Cameras</div><div style="font-size:28px;font-weight:700;color:var(--text3)">--</div><div style="font-size:12px;color:var(--text3);margin-top:4px">Coming soon</div></div>');
      }
      var mthtml = '<div style="display:flex;gap:12px">' + cards.join('') + '</div>';
      mobileThermo.innerHTML = mthtml;
    }
  } catch(e) { console.error('Mobile thermo error:', e); }

  // Pending invoices badge
  try {
    var piResp = await fetch('/api/invoices?status=pending&limit=200');
    var piData = await piResp.json();
    var piCount = Array.isArray(piData) ? piData.length : 0;
    var piBadge = document.getElementById('dash-pending-inv-badge');
    if (piBadge) {
      if (piCount > 0) {
        piBadge.innerHTML = '<span style="background:#f59e0b22;color:#f59e0b;border:1px solid #f59e0b55;padding:3px 12px;border-radius:20px;font-weight:700">' + piCount + ' pending review</span>';
      } else {
        piBadge.innerHTML = '<span style="color:var(--green);font-weight:600">&#10003; All clear</span>';
      }
    }
  } catch(e) { console.error('Pending invoices badge error:', e); }

  // Price Movers
  try {
    var pmBody = document.getElementById('dash-price-movers-body');
    if (pmBody) {
      var pmResp = await fetch('/api/price-movers');
      var pm = await pmResp.json();
      var fmtP = function(n) { return '$' + Number(n).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}); };
      var fmtD = function(s) { if(!s) return ''; var p=s.split('-'); return p[1]+'/'+p[2]; };
      if ((!pm.increases || !pm.increases.length) && (!pm.decreases || !pm.decreases.length)) {
        pmBody.innerHTML = '<div style="color:var(--text3);font-size:13px;padding:8px 0">No price changes in the last 30 days.</div>';
      } else {
        var pmHtml = '<div style="display:flex;gap:24px;flex-wrap:wrap">';
        if (pm.increases && pm.increases.length) {
          pmHtml += '<div style="flex:1;min-width:220px">';
          pmHtml += '<div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:var(--red);margin-bottom:8px">&#9650; Top Increases</div>';
          for (var pi = 0; pi < pm.increases.length; pi++) {
            var inc = pm.increases[pi];
            var name = inc.product_name.replace(/\s+/g,' ').trim();
            pmHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);cursor:default" title="' + fmtP(inc.previous_price) + ' (' + fmtD(inc.previous_date) + ') \u2192 ' + fmtP(inc.current_price) + ' (' + fmtD(inc.current_date) + ')">';
            pmHtml += '<div style="font-size:13px;color:var(--text1);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding-right:12px">' + name + '</div>';
            pmHtml += '<div style="font-size:13px;font-weight:700;color:var(--red);flex-shrink:0">+' + inc.change_pct.toFixed(1) + '%</div>';
            pmHtml += '</div>';
          }
          pmHtml += '</div>';
        }
        if (pm.decreases && pm.decreases.length) {
          pmHtml += '<div style="flex:1;min-width:220px">';
          pmHtml += '<div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:var(--green);margin-bottom:8px">&#9660; Top Decreases</div>';
          for (var di = 0; di < pm.decreases.length; di++) {
            var dec = pm.decreases[di];
            var dname = dec.product_name.replace(/\s+/g,' ').trim();
            pmHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);cursor:default" title="' + fmtP(dec.previous_price) + ' (' + fmtD(dec.previous_date) + ') \u2192 ' + fmtP(dec.current_price) + ' (' + fmtD(dec.current_date) + ')">';
            pmHtml += '<div style="font-size:13px;color:var(--text1);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding-right:12px">' + dname + '</div>';
            pmHtml += '<div style="font-size:13px;font-weight:700;color:var(--green);flex-shrink:0">' + dec.change_pct.toFixed(1) + '%</div>';
            pmHtml += '</div>';
          }
          pmHtml += '</div>';
        }
        pmHtml += '</div>';
        pmBody.innerHTML = pmHtml;
      }
    }
  } catch(e) { console.error('Price movers error:', e); }
}

function thermoToggle(deviceId) {
  var el = document.getElementById('thermo-expand-' + deviceId);
  if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

async function thermoAdj(location, deviceId, delta) {
  var spEl = document.getElementById('thermo-sp-' + deviceId);
  var mobSpEl = document.getElementById('thermo-mob-sp-' + deviceId);
  var mobBigEl = document.getElementById('thermo-mob-big-' + deviceId);
  var current = spEl ? parseInt(spEl.textContent) : (mobSpEl ? parseInt(mobSpEl.textContent) : null);
  if (current === null) return;
  var newSp = current + delta;
  if (newSp < 40 || newSp > 90) return;
  spEl.textContent = newSp + '°';
  spEl.style.color = 'var(--orange)';
  try {
    var resp = await fetch('/api/thermostats/set', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({location: location, device_id: deviceId, heat_setpoint: newSp})
    });
    var result = await resp.json();
    if (result.error) {
      if (spEl) { spEl.textContent = current + '°'; spEl.style.color = ''; }
      if (mobSpEl) { mobSpEl.textContent = current; mobSpEl.style.color = ''; }
      if (mobBigEl) { mobBigEl.textContent = current + '°'; mobBigEl.style.color = ''; }
      alert('Error: ' + result.error);
    } else {
      setTimeout(function() { 
        if (spEl) spEl.style.color = '';
        if (mobSpEl) mobSpEl.style.color = '';
        if (mobBigEl) mobBigEl.style.color = '';
      }, 2000);
    }
  } catch(e) {
    if (spEl) { spEl.textContent = current + '°'; spEl.style.color = ''; }
    if (mobSpEl) { mobSpEl.textContent = current; mobSpEl.style.color = ''; }
    if (mobBigEl) { mobBigEl.textContent = current + '°'; mobBigEl.style.color = ''; }
    alert('Failed to update thermostat');
  }
}

// ── Product Setup ──────────────────────────────────────────
let psProducts = [];
let psFiltered = [];
let psPage = 0;
const PS_PER_PAGE = 50;
let psExpanded = null;

const PS_UNITS = ['each','case','lb','oz','gal','liter','bottle','can','bag','box',
  'keg (1/2 BBL)','keg (1/6 BBL)','keg (1/4 BBL)','sleeve','pack','jar','tub','roll','bunch'];
const PS_CATS = {'':'—','FOOD':'Food','BEER':'Beer','LIQUOR':'Liquor',
  'WINE':'Wine','NA_BEVERAGES':'NA Bev','OTHER':'Other/Supplies'};

async function loadProductSetup() {
  const loc = window.currentLocation || 'dennis';
  try { const r = await fetch('/api/inventory/product-settings?location='+loc); psProducts = await r.json(); }
  catch(e) { psProducts = []; }
  const vendors = [...new Set(psProducts.map(p=>p.vendor_name).filter(Boolean))].sort();
  const vf = document.getElementById('ps-vendor-filter');
  const cv = vf.value;
  vf.innerHTML = '<option value="">All Vendors</option>'+vendors.map(v=>'<option value="'+v+'">'+v+' ('+psProducts.filter(p=>p.vendor_name===v).length+')</option>').join('');
  vf.value = cv;
  psPage=0; psExpanded=null; psApplyFilters();
}

function psApplyFilters() {
  const s=(document.getElementById('ps-search').value||'').toLowerCase();
  const v=document.getElementById('ps-vendor-filter').value;
  const c=document.getElementById('ps-cat-filter').value;
  const st=document.getElementById('ps-status-filter').value;
  psFiltered=psProducts.filter(p=>{
    if(s&&!(p.product_name||'').toLowerCase().includes(s)&&!(p.vendor_name||'').toLowerCase().includes(s))return false;
    if(v&&p.vendor_name!==v)return false;
    if(c){const pc=p.category||p.me_category_type||'';if(pc!==c)return false;}
    if(st==='unreviewed'&&p.reviewed)return false;
    if(st==='reviewed'&&!p.reviewed)return false;
    if(st==='skip'&&!p.skip_inventory)return false;
    return true;
  });
  document.getElementById('ps-count').textContent=psFiltered.length+' of '+psProducts.length+' products';
  psPage=0; psRenderPage();
}

function psRenderPage() {
  const start=psPage*PS_PER_PAGE;
  const pg=psFiltered.slice(start,start+PS_PER_PAGE);
  const con=document.getElementById('ps-list');
  if(!pg.length){con.innerHTML='<div class="card" style="text-align:center;padding:40px;color:var(--text3)">No products match filters</div>';document.getElementById('ps-pagination').innerHTML='';return;}
  con.innerHTML=pg.map(p=>{
    const ec=p.category||p.me_category_type||'';
    const cl=PS_CATS[ec]||ec;
    const cc={'FOOD':'var(--green)','BEER':'var(--orange)','LIQUOR':'var(--red)','WINE':'var(--purple)','NA_BEVERAGES':'var(--blue)','OTHER':'var(--text3)'}[ec]||'var(--text3)';
    const isN=!p.reviewed,isS=p.skip_inventory;
    const pr=p.purchase_price||p.me_latest_price;
    const ps2=pr?'$'+Number(pr).toFixed(2):'';
    const mu=p.me_unit||'';
    const cpu=p.cost_per_unit?'$'+Number(p.cost_per_unit).toFixed(3)+'/'+(p.contains_unit||'unit'):'';
    const isO=psExpanded===p.id;
    let sm='';
    if(p.ordering_unit&&p.contains_qty&&p.contains_unit){var cpk=p.case_pack_size&&p.case_pack_size>1?p.case_pack_size:'';var cpu2=p.case_pack_unit||'';sm='1 '+p.ordering_unit+' = '+(cpk?cpk+' '+(cpu2?cpu2+' @ ':'× '):'')+p.contains_qty+' '+p.contains_unit;if(p.cost_per_unit)sm+=' · '+cpu;}
    else if(ps2){sm=ps2+(mu?' / '+mu:'');}
    let r='<div class="card" style="padding:0;margin-bottom:2px;'+(isS?'opacity:0.4;':'')+'cursor:pointer;transition:all 0.15s" onclick="psToggle('+p.id+')">';
    r+='<div style="display:flex;align-items:center;padding:14px 16px;gap:12px">';
    if(isN)r+='<span style="background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px;flex-shrink:0">NEW</span>';
    else if(isS)r+='<span style="color:var(--text3);font-size:10px;font-weight:600;flex-shrink:0">SKIP</span>';
    else r+='<span style="color:var(--green);font-size:14px;flex-shrink:0">&#10003;</span>';
    r+='<div style="flex:1;min-width:0"><div style="font-weight:600;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+(p.product_name||'')+'</div>';
    r+='<div style="font-size:12px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+(p.vendor_name||'')+'</div></div>';
    if(cl&&cl!=='—')r+='<span style="font-size:11px;font-weight:600;padding:3px 8px;border-radius:6px;background:rgba(255,255,255,0.05);color:'+cc+';flex-shrink:0">'+cl+'</span>';
    if(sm)r+='<span style="font-size:12px;color:var(--text2);white-space:nowrap;flex-shrink:0">'+sm+'</span>';
    r+='<span style="color:var(--text3);font-size:12px;transition:transform 0.2s;transform:rotate('+(isO?'90':'0')+'deg)">&#9654;</span>';
    r+='</div>';
    if(isO){r+='<div style="border-top:1px solid var(--border);padding:16px;background:rgba(255,255,255,0.02)" onclick="event.stopPropagation()">'+psRenderDetail(p)+'</div>';}
    r+='</div>';return r;
  }).join('');
  const tp=Math.ceil(psFiltered.length/PS_PER_PAGE);
  const pa=document.getElementById('ps-pagination');
  if(tp<=1){pa.innerHTML='';return;}
  let ph='';
  if(psPage>0)ph+='<button class="btn btn-secondary" onclick="psPage--;psRenderPage()">&#8592; Prev</button>';
  ph+='<span style="color:var(--text2);font-size:13px;padding:8px">Page '+(psPage+1)+' of '+tp+'</span>';
  if(psPage<tp-1)ph+='<button class="btn btn-secondary" onclick="psPage++;psRenderPage()">Next &#8594;</button>';
  pa.innerHTML=ph;
}

function psRenderDetail(p) {
  var ec=p.category||p.me_category_type||'';
  var eu=(p.ordering_unit||'').toLowerCase();
  var pr=p.purchase_price||p.me_latest_price||'';
  var mu=p.me_unit||'';
  var mcn=p.me_category_name||'';
  var cUnit=(p.contains_unit||'').toLowerCase();
  var rUnit=p.recipe_unit||'';

  var h='<div style="display:flex;flex-direction:column;gap:20px">';

  // Row 1: Category + Purchase Unit + Price
  h+='<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px">';
  h+=psField('Category','select','category',ec,p.id,Object.entries(PS_CATS).map(function(e){return '<option value="'+e[0]+'"'+(e[0]===ec?' selected':'')+'>'+e[1]+'</option>';}).join(''));
  h+=psField('Purchase Unit','select','ordering_unit',eu,p.id,'<option value="">—</option>'+PS_UNITS.map(function(u){return '<option value="'+u+'"'+(u===eu?' selected':'')+'>'+u+'</option>';}).join(''));
  h+='<div style="margin-bottom:12px"><div style="font-size:12px;color:var(--text2);margin-bottom:4px">Purchase Price</div>';
  h+='<div style="position:relative"><span style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text2);font-size:14px;pointer-events:none">$</span>';
  h+='<input type="text" inputmode="decimal" class="form-input ps-detail" data-field="purchase_price" data-id="'+p.id+'" value="'+(pr?Number(pr).toFixed(2):'')+'" style="width:100%;padding:8px 10px 8px 24px;font-size:14px"></div>';
  if(mu)h+='<div style="font-size:11px;color:var(--text3);margin-top:3px">ME: $'+Number(p.me_latest_price||0).toFixed(2)+' / '+mu+'</div>';
  if(mcn)h+='<div style="font-size:11px;color:var(--text3)">ME Category: '+mcn+'</div>';
  h+='</div></div>';

  // Row 2: Conversion Chain
  h+='<div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:16px">';
  h+='<div style="font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;margin-bottom:12px">Conversion Chain</div>';

  // Step 1: Purchase -> Inventory
  h+='<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px">';
  h+='<span style="font-size:14px;font-weight:600;color:var(--text1);white-space:nowrap">1 '+(eu||'purchase unit')+'</span>';
  h+='<span style="color:var(--text3)">=</span>';
  h+='<input type="number" step="any" class="form-input ps-detail" data-field="case_pack_size" data-id="'+p.id+'" value="'+(p.case_pack_size||'')+'" placeholder="qty" style="width:70px;padding:6px 8px;font-size:14px;text-align:center">';
  var cpkUnit=(p.case_pack_unit||'').toLowerCase();
  var CPK_UNITS=['bottle','bag','can','box','sleeve','patty','piece','each','roll','jar','tub','bunch','pack','portion','fillet'];
  h+='<select class="form-select ps-detail" data-field="case_pack_unit" data-id="'+p.id+'" style="width:100px;padding:6px 8px;font-size:14px"><option value="">—</option>'+CPK_UNITS.map(function(u){return '<option value="'+u+'"'+(u===cpkUnit?' selected':'')+'>'+u+'</option>';}).join('')+'</select>';
  h+='<span style="color:var(--text3)">@</span>';
  h+='<input type="number" step="any" class="form-input ps-detail" data-field="contains_qty" data-id="'+p.id+'" value="'+(p.contains_qty||'')+'" placeholder="qty" style="width:70px;padding:6px 8px;font-size:14px;text-align:center">';
  h+='<select class="form-select ps-detail" data-field="contains_unit" data-id="'+p.id+'" style="width:120px;padding:6px 8px;font-size:14px"><option value="">\u2014</option>'+PS_UNITS.map(function(u){return '<option value="'+u+'"'+(u===cUnit?' selected':'')+'>'+u+'</option>';}).join('')+'</select>';
  h+='<span id="ps-cost-inv-'+p.id+'" style="font-size:13px;font-weight:600;color:var(--green);margin-left:8px"></span>';
  h+='</div>';

  // Step 2: Inventory -> Recipe Unit
  h+='<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px">';
  h+='<span style="font-size:14px;font-weight:600;color:var(--text1);white-space:nowrap" id="ps-inv-label-'+p.id+'">Recipe unit</span>';
  h+='<span style="color:var(--text3)">:</span>';
  var recipeUnits=PS_UNITS.concat(["stick","piece","slice","patty","portion","fillet","wing","shrimp","strip"]);
  h+='<select class="form-select ps-detail" data-field="recipe_unit" data-id="'+p.id+'" style="width:120px;padding:6px 8px;font-size:14px"><option value="">—</option>'+recipeUnits.map(function(u){return '<option value="'+u+'"'+(u===rUnit?' selected':'')+'>'+u+'</option>';}).join('')+'</select>';
  h+='<span id="ps-cost-recipe-'+p.id+'" style="font-size:13px;font-weight:600;color:var(--green);margin-left:8px"></span>';
  h+='</div>';

  // Cost summary
  h+='<div id="ps-cost-summary-'+p.id+'" style="font-size:15px;font-weight:700;padding:10px 0;border-top:1px solid var(--border);margin-top:8px"></div>';
  h+='</div>';

  // Row 3: Par Levels & Order Guide
  h+='<div style="background:rgba(48,209,88,0.05);border-radius:8px;padding:16px;border:1px solid rgba(48,209,88,0.15)">';
  h+='<div style="font-size:11px;font-weight:700;color:var(--green);text-transform:uppercase;margin-bottom:12px">Inventory Management</div>';
  h+='<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px">';
  h+='<div><div style="font-size:12px;color:var(--text2);margin-bottom:4px">Par Level (Min Stock)</div>';
  h+='<input type="number" step="any" class="form-input ps-detail" data-field="par_level" data-id="'+p.id+'" value="'+(p.par_level||'')+'" placeholder="0" style="width:100%;padding:8px 10px;font-size:14px"></div>';
  h+='<div><div style="font-size:12px;color:var(--text2);margin-bottom:4px">Order Guide Qty</div>';
  h+='<input type="number" step="any" class="form-input ps-detail" data-field="order_guide_qty" data-id="'+p.id+'" value="'+(p.order_guide_qty||'')+'" placeholder="0" style="width:100%;padding:8px 10px;font-size:14px"></div>';
  h+='</div>';
  h+='<div style="font-size:11px;color:var(--text2);margin-top:8px">💡 Par Level: minimum stock to maintain. Order Guide: suggested reorder quantity when below par.</div>';
  h+='</div>';

  // Row 4: Options
  h+='<div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">';
  h+='<label style="display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="ps-detail" data-field="skip_inventory" data-id="'+p.id+'"'+(p.skip_inventory?' checked':'')+' style="width:18px;height:18px;accent-color:var(--red)"><span style="font-size:14px">Skip Inventory</span></label>';
  h+='<input type="text" class="form-input ps-detail" data-field="notes" data-id="'+p.id+'" value="'+((p.notes||'').replace(/"/g,'&quot;'))+'" placeholder="Notes..." style="flex:1;min-width:200px;padding:8px 10px;font-size:13px">';
  h+='<button class="btn btn-primary" onclick="psSave('+p.id+')" id="ps-savebtn-'+p.id+'" style="min-width:180px">Save &amp; Mark Reviewed</button>';
  h+='</div>';

  h+='</div>';
  setTimeout(function(){psCalcCost(p.id);},50);
  return h;
}

function psField(label,type,field,value,id,optHtml,hint) {
  var h='<div style="margin-bottom:12px"><div style="font-size:12px;color:var(--text2);margin-bottom:4px">'+label+'</div>';
  if(type==='select')h+='<select class="form-select ps-detail" data-field="'+field+'" data-id="'+id+'" style="width:100%;padding:8px 10px;font-size:14px">'+optHtml+'</select>';
  else h+='<input type="'+type+'" step="any" class="form-input ps-detail" data-field="'+field+'" data-id="'+id+'" value="'+(value||'')+'" style="width:100%;padding:8px 10px;font-size:14px">';
  if(hint)h+='<div style="font-size:11px;color:var(--text3);margin-top:3px">'+hint+'</div>';
  h+='</div>';return h;
}

function psToggle(id){psExpanded=(psExpanded===id)?null:id;psRenderPage();}

document.addEventListener('input',function(e){if(!e.target.classList.contains('ps-detail'))return;var f=e.target.dataset.field;if(f==='purchase_price'||f==='contains_qty'||f==='case_pack_size'||f==='inventory_to_recipe')psCalcCost(parseInt(e.target.dataset.id));});
document.addEventListener('change',function(e){if(!e.target.classList.contains('ps-detail'))return;var cf=e.target.dataset.field;if(cf==='contains_unit'||cf==='recipe_unit')psCalcCost(parseInt(e.target.dataset.id));});

function psCalcCost(id){
  var prEl=document.querySelector('.ps-detail[data-field="purchase_price"][data-id="'+id+'"]');
  var cpEl=document.querySelector('.ps-detail[data-field="case_pack_size"][data-id="'+id+'"]');
  var q1El=document.querySelector('.ps-detail[data-field="contains_qty"][data-id="'+id+'"]');
  var u1El=document.querySelector('.ps-detail[data-field="contains_unit"][data-id="'+id+'"]');
  var q2El=document.querySelector('.ps-detail[data-field="inventory_to_recipe"][data-id="'+id+'"]');
  var u2El=document.querySelector('.ps-detail[data-field="recipe_unit"][data-id="'+id+'"]');
  var costInv=document.getElementById('ps-cost-inv-'+id);
  var costRec=document.getElementById('ps-cost-recipe-'+id);
  var costSum=document.getElementById('ps-cost-summary-'+id);
  var invLabel=document.getElementById('ps-inv-label-'+id);
  var price=parseFloat(prEl&&prEl.value)||0;
  var qty1=parseFloat(q1El&&q1El.value)||0;
  var cpack=parseFloat(cpEl&&cpEl.value)||1;
  var unit1=(u1El&&u1El.value)||'';
  var qty2=parseFloat(q2El&&q2El.value)||0;
  var unit2=(u2El&&u2El.value)||'';
  if(invLabel)invLabel.textContent='Recipe unit';
  var costPerInv=0;
  if(price&&qty1){
    costPerInv=price/(cpack*qty1);
    if(costInv)costInv.textContent='$'+costPerInv.toFixed(3)+' / '+(unit1||'unit');
  } else { if(costInv)costInv.textContent=''; }
  if(costPerInv&&qty2){
    var costPerRec=costPerInv/qty2;
    if(costRec)costRec.textContent='$'+costPerRec.toFixed(3)+' / '+(unit2||'unit');
    if(costSum)costSum.innerHTML='<span style="color:var(--green)">Recipe unit cost: $'+costPerRec.toFixed(3)+' / '+(unit2||'unit')+'</span>';
  } else if(costPerInv){
    if(costRec)costRec.textContent='';
    if(costSum)costSum.innerHTML='<span style="color:var(--green)">Inventory unit cost: $'+costPerInv.toFixed(3)+' / '+(unit1||'unit')+'</span>';
  } else {
    if(costRec)costRec.textContent='';
    if(costSum)costSum.innerHTML='<span style="color:var(--text3)">Enter price and breakdown to calculate costs</span>';
  }
}

async function psSave(id){
  var btn=document.getElementById('ps-savebtn-'+id);btn.textContent='Saving...';btn.style.pointerEvents='none';
  var fields={};
  document.querySelectorAll('.ps-detail[data-id="'+id+'"]').forEach(function(el){
    var f=el.dataset.field;
    if(el.type==='checkbox')fields[f]=el.checked?1:0;
    else if(el.type==='number')fields[f]=el.value?parseFloat(el.value):null;
    else fields[f]=el.value||null;
  });
  if(fields.purchase_price&&fields.contains_qty){var totalQty=(fields.case_pack_size||1)*fields.contains_qty;fields.cost_per_unit=Math.round((fields.purchase_price/totalQty)*1000)/1000;if(fields.inventory_to_recipe)fields.cost_per_recipe_unit=Math.round((fields.cost_per_unit/fields.inventory_to_recipe)*1000)/1000;}
  fields.reviewed=1;
  try{
    var resp=await fetch('/api/inventory/product-settings/'+id,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(fields)});
    if(resp.ok){var prod=psProducts.find(function(p){return p.id===id;});if(prod)Object.assign(prod,fields);btn.textContent='Saved!';btn.style.background='var(--green)';setTimeout(function(){psExpanded=null;psRenderPage();},800);}
    else{btn.textContent='Error';setTimeout(function(){btn.textContent='Save & Mark Reviewed';btn.style.pointerEvents='auto';btn.style.background='';},2000);}
  }catch(e){btn.textContent='Error';setTimeout(function(){btn.textContent='Save & Mark Reviewed';btn.style.pointerEvents='auto';btn.style.background='';},2000);}
}

var psSearchTimer;
if(document.getElementById('ps-search'))document.getElementById('ps-search').addEventListener('input',function(){clearTimeout(psSearchTimer);psSearchTimer=setTimeout(psApplyFilters,300);});
if(document.getElementById('ps-vendor-filter'))document.getElementById('ps-vendor-filter').addEventListener('change',psApplyFilters);
if(document.getElementById('ps-cat-filter'))document.getElementById('ps-cat-filter').addEventListener('change',psApplyFilters);
if(document.getElementById('ps-status-filter'))document.getElementById('ps-status-filter').addEventListener('change',psApplyFilters);

// Auto-categorize: when category is set, pre-fill from ME data
// (already handled by effectiveCat in render)

// ── Settings ──────────────────────────────────────────
function loadSettings() {
  console.log('Settings view loaded');
}

// ── Order Guide ──────────────────────────────────────────
async function loadOrderGuide() {
  const loc = window.currentLocation || 'dennis';
  try {
    const resp = await fetch('/api/inventory/order-guide?location=' + loc);
    const data = await resp.json();

    // Summary
    const summary = document.getElementById('og-summary');
    summary.innerHTML = `
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px">
        <div>
          <div style="font-size:13px;color:var(--text2);margin-bottom:4px">Total Items Below Par</div>
          <div style="font-size:24px;font-weight:700;color:var(--green)">${data.total_items}</div>
        </div>
        <div>
          <div style="font-size:13px;color:var(--text2);margin-bottom:4px">Estimated Order Cost</div>
          <div style="font-size:24px;font-weight:700;color:var(--green)">$${data.total_cost.toLocaleString('en-US',{minimumFractionDigits:2})}</div>
        </div>
        <div style="font-size:11px;color:var(--text3)">Generated: ${new Date(data.generated_at).toLocaleTimeString()}</div>
      </div>
    `;

    // Vendors
    const vendors = document.getElementById('og-vendors');
    if (!data.vendors.length) {
      vendors.innerHTML = '<div style="padding:40px;text-align:center;color:var(--text3)">No items below par level. Set par levels in Product Setup.</div>';
      return;
    }

    vendors.innerHTML = data.vendors.map(v => `
      <div style="border-bottom:1px solid var(--border)">
        <div style="padding:16px;background:rgba(255,255,255,0.02);cursor:pointer" onclick="ogToggleVendor('${v.vendor}')">
          <div style="display:flex;align-items:center;justify-content:space-between">
            <div>
              <div style="font-size:16px;font-weight:600">${v.vendor}</div>
              <div style="font-size:12px;color:var(--text2);margin-top:2px">${v.item_count} items</div>
            </div>
            <div style="text-align:right">
              <div style="font-size:18px;font-weight:700;color:var(--green)">$${v.total_cost.toLocaleString('en-US',{minimumFractionDigits:2})}</div>
              <div id="og-arrow-${v.vendor.replace(/[^a-z0-9]/gi,'_')}" style="font-size:12px;color:var(--text3);transition:transform 0.2s">▶</div>
            </div>
          </div>
        </div>
        <div id="og-items-${v.vendor.replace(/[^a-z0-9]/gi,'_')}" style="display:none">
          <table class="data-table">
            <thead>
              <tr>
                <th>Product</th>
                <th>Par Level</th>
                <th>Current</th>
                <th>Needed</th>
                <th>Order Qty</th>
                <th style="text-align:right">Cost</th>
              </tr>
            </thead>
            <tbody>
              ${v.items.map(item => `
                <tr>
                  <td>
                    <div style="font-weight:600">${item.product_name}</div>
                    <div style="font-size:11px;color:var(--text3)">${item.category || ''} ${item.unit ? '· '+item.unit : ''}</div>
                  </td>
                  <td>${item.par_level}</td>
                  <td style="color:var(--red)">${item.current_stock}</td>
                  <td>${item.needed}</td>
                  <td style="font-weight:600;color:var(--green)">${item.order_qty}</td>
                  <td style="text-align:right;font-weight:600">$${item.total_cost.toFixed(2)}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      </div>
    `).join('');

  } catch (e) {
    console.error('Error loading order guide:', e);
    document.getElementById('og-vendors').innerHTML = '<div style="padding:40px;text-align:center;color:var(--red)">Error loading order guide</div>';
  }
}

function ogToggleVendor(vendor) {
  const id = vendor.replace(/[^a-z0-9]/gi,'_');
  const items = document.getElementById('og-items-'+id);
  const arrow = document.getElementById('og-arrow-'+id);
  if (items.style.display === 'none') {
    items.style.display = 'block';
    arrow.style.transform = 'rotate(90deg)';
  } else {
    items.style.display = 'none';
    arrow.style.transform = 'rotate(0deg)';
  }
}
</script>
</body>
</html>
